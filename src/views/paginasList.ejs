</div>


<%- include('partials/templateModalPagina'); %>
<%- include('partials/templateModalRegeneracion'); %>
<%- include('partials/footerNoMx'); %>

<script>

    $(function () {
        $('#lockscreen').hide();
        if ($('#tb-inicial').length) {
            $('#tb-inicial').DataTable({
                lengthChange: false,
                searching: false
            });
        }
        if ($('#tb-paginas').length) {
            $('#tb-paginas').DataTable();
        }
        if ($('#tb-entradas').length) {
            $('#tb-entradas').DataTable();
        }
        if ($('#tb-regeneracion').length) {
            $('#tb-regeneracion').DataTable();
        }

        window.addEventListener('pageshow', function (event) {
            if (event.persisted) {
                window.location.reload();
            }
        });

        $(document).on('change', "#namepag", function () {
            var tipopag = $('#tipopag').val();
            if(parseInt(tipopag)!==1){
                let name = $(this).val();
                name = name.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
                name = name.toLowerCase();
                name = name.replace(/\s+/g, '-');
                name = name.replace(/[^a-z0-9\-]/g, '');
                name = name.substring(0, 50);
                name = name.replace(/-+$/, '');
                name = encodeURIComponent(name);
                $('#url').val(name);
            }
        });
        $(document).on('change', "#url", function () {
            let name = $(this).val();
            name = name.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
            name = name.toLowerCase();
            name = name.replace(/\s+/g, '-');
            name = name.replace(/[^a-z0-9\-]/g, '');
            name = name.substring(0, 50);
            name = name.replace(/-+$/, '');
            name = encodeURIComponent(name);
            $('#url').val(name);
        });
        $(document).on('click', ".editpag", function () {
            let cy = $(this).data('cy');
            let tipo_duplicado = $(this).data('tipo-duplicado');

            if (tipo_duplicado === 1) {
                let id_bor = $(this).data('idborrador');
                let hasBo = $(this).data('borrador');
                const tieneBorrador = (hasBo === true || hasBo === 'true');
                const noTieneBorrador = (hasBo === false || hasBo === 'false' || hasBo == null);

                // Mostrar confirm SIEMPRE para tener UX consistente (principal/secundarias)
                if (tieneBorrador) {
                    $.confirm({
                        title: "Advertencia",
                        content: "<strong>La página ya tiene un borrador, ¿desea continuar editando el borrador vigente o descartarlo y crear uno nuevo?</strong>",
                        theme: 'modern',
                        type: "orange",
                        buttons: {
                            continuar: {
                                text: 'Continuar editando',
                                btnClass: 'btn-success',
                                action: function () {
                                    getBor(id_bor, hasBo, cy, tipo_duplicado, 'Continuar')
                                }
                            },
                            decartar: {
                                text: 'Descartar borrador',
                                btnClass: 'btn-alert descartar-bor',
                                action: function () {
                                    getBor(id_bor, hasBo, cy, tipo_duplicado, 'Descartar')
                                },
                            },
                            Cancelar: {
                                text: 'Cancelar',
                                btnClass: 'btn-alert btn-descartar',
                                action: function () { }
                            }
                        }
                    });
                } else if (noTieneBorrador) {
                    // Como antes: si no hay borrador, editar directo (sin confirm)
                    window.location.href = '/editarpagina?p=' + cy;
                } else {
                    $.alert({
                        title: "Error inesperado",
                        content: "Ocurrió un problema al verificar si la página tiene un borrador.",
                        theme: 'modern',
                        type: 'red'
                    });
                }
            } else if (tipo_duplicado === 2) {
                let type = $(this).data('type');
                NuevaPagPrincipalModal(type, cy, tipo_duplicado);
            } else {
                $.alert({
                    title: "Error inesperado",
                    content: "Ocurrió un problema al verificar si la página tiene un borrador.",
                    theme: 'modern',
                    type: 'red'
                });
            }

        });
        $(document).on('click', ".deletepag", function () {
            let cy = $(this).data('cy');
            $.alert({
                title: "Advertencia",
                content: "¿Está seguro de eliminar esta página?",
                theme: 'modern',
                icon: 'fa-solid fa-triangle-exclamation',
                type: "red",
                buttons: {
                    Aceptar: {
                        text: 'Si, Eliminar',
                        btnClass: 'btn-success',
                        action: function () {
                            $.ajax({
                                url: '/DeletePag?p='+cy,
                                method: 'GET',
                                beforeSend(jqXHR, settings) {
                                    $('#lockscreen').show();
                                },
                                success: function(data) {
                                    window.location.reload();
                                }
                            });
                        }
                    },
                    Cancelar: {
                        text: 'Cancelar',
                        btnClass: 'btn-alert',
                        action: function () {
                        }
                    }
                }
            });
        });
        
        $(document).on('click', ".editentrance", function () {
            let cy = $(this).data('cy');
            var formData = new FormData();
            formData.append('cy', cy);

            fetch('/GetPostContent', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ cy: cy })
            })
                .then(response => response.json())
                .then(data => {
                    // console.log(data.entrada);
                    NuevaPagPrincipalModal(5)
                    $('#idpag').val(data.entrada.id_wb_pagina);
                    $('#namepag').val(data.entrada.nombre_pagina);
                    $('#url').val(data.entrada.url_safe);
                    $('#tipo_tag').val(data.entrada.cat_tags[0].id_cat_tag);
                    $('#cont_alt').val(data.entrada.contenido_alt);
                    $('#cont_full').summernote('code', data.entrada.contenido);
                    let fecha = new Date(data.entrada.f_publicacion).toISOString().split('T')[0];
                    $('#f_pub').val(fecha);
                    let filepath= 'https://cdn.morena.app/'+data.entrada.archivo.file_path;
                    let htmlimg='<img src="'+filepath+'" class="imgcargada">';
                    $('#imgcargada').html(htmlimg);

                })
                .catch(error => {
                    console.error('Error:', error);
                });
        });
    });

    if (typeof FilePond !== 'undefined') {
        FilePond.registerPlugin(FilePondPluginFileValidateType, FilePondPluginFileValidateSize, FilePondPluginImagePreview);
    }
    function destroyFilePondPagina() {
        window._lastFilePagina = null;
        if (window.pondPagina) {
            try { FilePond.destroy(window.pondPagina); } catch (e) {}
            window.pondPagina = null;
        }
    }
    function initFilePondPagina() {
        var input = document.getElementById('cargar-imagpag');
        if (!input) return;
        window._lastFilePagina = null;
        var fpMaxPag = 2 * 1024 * 1024;
        window.pondPagina = FilePond.create(input, {
            allowMultiple: false,
            allowDrop: true,
            dropOnElement: true,
            dropOnPage: false,
            beforeAddFile: function (item) {
                var sz = item && (typeof item.fileSize === 'number' ? item.fileSize : (item.file && item.file.size));
                if (sz > fpMaxPag) {
                    $.alert({
                        title: 'Archivo demasiado grande',
                        content: 'El tamaño máximo permitido es 2 MB.',
                        theme: 'modern',
                        type: 'red',
                    });
                    return false;
                }
                return true;
            },
            acceptedFileTypes: ['image/jpeg', 'image/png'],
            maxFileSize: '2MB',
            allowImagePreview: true,
            imagePreviewMaxHeight: 140,
            labelMaxFileSize: 'Tamaño máximo: {filesize}',
            labelMaxFileSizeExceeded: 'El archivo supera el tamaño máximo permitido ({filesize}).',
            labelFileTypeNotAllowed: 'Tipo de archivo no permitido',
            labelIdle: 'Arrastre aquí o <span class="filepond--label-action">seleccione</span><br><small class="text-muted">JPG o PNG, máx. 2 MB</small>',
            labelFileProcessing: 'Subiendo',
            labelFileProcessingComplete: 'Listo',
            labelTapToCancel: 'cancelar',
            labelTapToRetry: 'reintentar',
            onupdatefiles: function (items) {
                window._lastFilePagina = null;
                if (!items.length || !items[0]) return;
                var it = items[0];
                var f = it.file;
                var sz = typeof it.fileSize === 'number' ? it.fileSize : (f && f.size);
                if (!f || sz > fpMaxPag) return;
                window._lastFilePagina = f;
            }
        });
    }
    function getFileFromPondPagina() {
        var maxBytes = 2 * 1024 * 1024;
        if (window._lastFilePagina instanceof File && window._lastFilePagina.size <= maxBytes) return window._lastFilePagina;
        var pond = window.pondPagina;
        if (pond && pond.files && pond.files.length) {
            var first = pond.files[0];
            if (first && first.file && first.file.size <= maxBytes) return first.file;
        }
        var input = document.getElementById('cargar-imagpag');
        if (input && input.files && input.files.length && input.files[0].size <= maxBytes) return input.files[0];
        return null;
    }

    $(".cargapagina").on('click', NuevaPagPrincipalModal);

    function NuevaPagPrincipalModal(type, cy, tipo_duplicado) {
        if(typeof(type)==='object'){
            type = $(this).data('idtype');
        }
        let typetext = ''
        let subtitulo = ''
        if (type === 1) {
            typetext = 'Principal';
            subtitulo = 'Sólo se permite tener una página principal por sitio, mientras no se publique no se remplazará la que está vigente.'
        } else if (type === 2) {
            typetext = 'Página interior';
            subtitulo = 'Página interior administrable';
        } else if (type === 5) {
            typetext = 'Entrada';
            subtitulo = 'Entrada de blog. Opcionalmente agrega una imagen (JPG o PNG, máx. 2 MB).';
        }

        destroyFilePondPagina();
        limpieza_modalGral();
        modalGral_addTit('NUEVA PÁGINA');
        modalGral_addSubtit(subtitulo);
        modalGral_bodyAppend(getHtmlTemplate('Nuevapag'));
        $('#tipo_pagina').val(typetext);
        $('#tipopag').val(type);

        var modalEl = document.getElementById('modalGral');
        if (modalEl) {
            modalEl.addEventListener('hidden.bs.modal', function onHidden() {
                modalEl.removeEventListener('hidden.bs.modal', onHidden);
                destroyFilePondPagina();
            }, { once: true });
        }

        modalGral_addFooter(`
            <input type="hidden" id="h_cy" value="${cy}">
            <input type="hidden" id="h_tipo_duplicado" value="${tipo_duplicado}">
            <button class="btnGral guinda_t" type="button" data-bs-dismiss="modal">
                <p>CANCELAR</p>
                <div class="btnIcon">
                    <div class="boxIcon guinda"><img src="assets/img/TIMES.svg"></div>
                    <span class="s-guinda"></span>
                </div>
            </button>
            <a href="#" class="btnGral verde_t" onclick="CrearPag('${cy}', '${tipo_duplicado}')">
                <p>CREAR</p>
                <div class="btnIcon">
                    <div class="boxIcon verde"><img src="assets/img/GUARDAR.svg"></div>
                    <span class="s-verde"></span>
                </div>
            </a>`
        );

        (new bootstrap.Modal($('#modalGral')[0], {backdrop: "static", keyboard: false})).show();

        var today = new Date();
        var day = String(today.getDate()).padStart(2, '0');
        var month = String(today.getMonth() + 1).padStart(2, '0'); // Los meses son de 0 a 11
        var year = today.getFullYear();
        var minDate = year + '-' + month + '-' + day;

        var nextWeek = new Date();
        nextWeek.setDate(today.getDate() + 7);
        var maxDay = String(nextWeek.getDate()).padStart(2, '0');
        var maxMonth = String(nextWeek.getMonth() + 1).padStart(2, '0');
        var maxYear = nextWeek.getFullYear();
        var maxDate = maxYear + '-' + maxMonth + '-' + maxDay;

        $('#f_pub').attr('min',minDate).attr('max',maxDate).val(minDate);

        if (type === 1) {
            $('#cont_full').hide();
            $('#imgcarga').hide();
            $('#tagentrada').hide();
            $('#fullcom').hide();
            $('#url').val("/").attr('readonly',true);
        } else if (type === 2) {
            $('#imgcarga').hide();
            $('#tagentrada').hide();
            $('#cont_full').hide();
            $('#fullcom').hide();
        } else if(type===5) {
            $('#imgcarga').show();
            setTimeout(function () {
                initFilePondPagina();
            }, 80);
            $('#cont_full').summernote({
                placeholder: 'Escribe aquí tu contenido',
                tabsize: 2,
                height: 100,
                toolbar: [
                    // [groupName, [list of button]]
                    ['style', ['bold', 'italic', 'underline', 'clear']],
                    ['font', ['superscript', 'subscript']],
                    ['color', ['forecolor']],
                    ['para', ['ul', 'ol', 'paragraph']],
                    ['height', ['height']],
                    ['view', ['codeview']],
                ]
            });
        }
    }

    let __crearPagInFlight = false;
    function CrearPag (cy, tipo_duplicado){
        if (__crearPagInFlight) return;
        __crearPagInFlight = true;

        var tipopag = $('#tipopag').val();
        var cyphval = $('#cyphval').val();
        var namepag = $('#namepag').val();
        var url = $('#url').val();
        var tipo_tag = $('#tipo_tag').val();
        var cont_alt = $('#cont_alt').val();
        var cont_full = $('#cont_full').val();
        var f_pub = $('#f_pub').val();
        var idpag = $('#idpag').val();

        var formData = new FormData();
        formData.append('url', url);
        formData.append('tipo_tag', tipo_tag);
        formData.append('namepag', namepag);
        formData.append('cyphval', cyphval);
        formData.append('tipopag', tipopag);
        formData.append('cont_alt', cont_alt);
        formData.append('cont_full', cont_full);
        formData.append('f_pub', f_pub);
        formData.append('idpag', idpag);

        var archivo = getFileFromPondPagina();
        if (archivo) {
            formData.append('cargar-imagpag', archivo);
        }
        // console.log(typeof tipo_duplicado, tipo_duplicado);

        if (parseInt(tipo_duplicado) === 2){
            console.log("cae en tipo de duplicado 2");
            formData.append('tipo_duplicado', tipo_duplicado);
            formData.append('id_pag_nueva', idpag);
        }
        if (cy){
            formData.append('cy', cy);
        }

        $.ajax({
            url: '/CreatePag',
            method: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            beforeSend: function () {
                $('#lockscreen').stop(true, true).fadeIn(150);
                // Deshabilitar el botón de CREAR del modal para evitar múltiples clicks
                const $crearBtn = $('#modalGral .modal-footer a.btnGral.verde_t');
                $crearBtn.addClass('disabled').attr('aria-disabled', 'true').css('pointer-events', 'none').css('opacity', '0.7');
            },
            success: function (data) {
                if(data && data.success){
                    $.alert({
                        title: "Se guardó correctamente",
                        content: "Se ha guardado la página correctamente",
                        theme: 'modern',
                        icon: 'fa-solid fa-check',
                        type: "green",
                        buttons: {
                            Aceptar: {
                                text: 'Aceptar',
                                btnClass: 'btn-success',
                                action: function () {
                                    if (parseInt(tipopag) === 1 || parseInt(tipopag) === 2 ){
                                        window.location.href = '/editarpagina?p='+data.pag;
                                    } else {
                                        window.location.reload();
                                    }
                                }
                            }
                        }
                    });
                } else {
                    $.alert({
                        title: "Advertencia",
                        content: (data && data.message) ? data.message : 'Ocurrió un error al guardar.',
                        theme: 'modern',
                        icon: 'fa-solid fa-triangle-exclamation',
                        type: "red"
                    });
                }
            },
            error: function (xhr, status, err) {
                console.error('Error:', status, err);
                $.alert({
                    title: "Error",
                    content: xhr.responseJSON?.message || 'Ocurrió un error inesperado.',
                    theme: 'modern',
                    type: "red"
                });
            },
            complete: function () {
                __crearPagInFlight = false;
                $('#lockscreen').stop(true, true).fadeOut(150);
                const $crearBtn = $('#modalGral .modal-footer a.btnGral.verde_t');
                $crearBtn.removeClass('disabled').removeAttr('aria-disabled').css('pointer-events', '').css('opacity', '');
            }
        });
    }

    function CreateBor (cy, tipo_duplicado){
        $.ajax({
            url: '/DuplicarPag',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ cy, tipo_duplicado: tipo_duplicado }),
            beforeSend() {
                $('#lockscreen').show();
            },
            success: function (resp) {
                $('#lockscreen').hide();
                if (resp.success) {
                    window.location.href = '/editarpagina?p=' + resp.cy;
                } else {
                    $.alert({
                        title: "Error",
                        content: resp.message || 'No se pudo duplicar',
                        theme: 'modern',
                        type: "red"
                    });
                }
            },
            error: function (xhr, status, err) {
                $('#lockscreen').hide();
                console.error("Error:", status, err);
                $.alert({
                    title: "Error al editar",
                    content: xhr.responseJSON?.message || 'Ocurrió un error inesperado.',
                    theme: 'modern',
                    type: "red"
                });
            }
        });
    }
    
    function getBor (id_bor, hasBo, cy, tipo_duplicado, accion){
        $.ajax({
            url: '/getBorPag',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ id_bor, hasBo, cy, tipo_duplicado, accion }),
            beforeSend(){
                $('#lockscreen').show();
            },
            success: function (resp) {
                if (resp.success && resp.tipos===1) {
                    window.location.href = '/editarpagina?p=' + resp.cy;
                } else if(resp.success && resp.tipos===2) {
                    // Borrador descartado: volver a editar la página original (sin crear nuevo registro)
                    window.location.href = '/editarpagina?p=' + cy;
                } else {
                    $.alert({ title: 'Listo', content: resp.message });
                    window.location.reload();
                }
            },
            error: function (xhr, status, err) {
                $('#lockscreen').hide();
                console.error("Error:", status, err);
                $.alert({
                    title: "Error al editar",
                    content: xhr.responseJSON?.message || 'Ocurrió un error inesperado.',
                    theme: 'modern',
                    type: "red"
                });
            }
        });
    }

    function mostrarRenderizado(event, idpagcy, esEntrada){
        event.preventDefault();
        event.stopPropagation();
        if (typeof event.stopImmediatePropagation === 'function') {
            event.stopImmediatePropagation();
        }
        fetch('/consultarURL', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                idpagcy: idpagcy,
                entrada: !!esEntrada,
            })
        })
        .then(response => response.json())
        .then(data => {
          
            if(data.success){
                var previewUrl = data.url;
                if (previewUrl) {
                    var w = window.open(previewUrl, '_blank', 'noopener,noreferrer');
                    if (!w) window.location.href = previewUrl;
                }
                return;
            }

            return $.alert({
                title: "LA URL no pudo ser construida",
                content: 'Ocurrió un error inesperado.',
                theme: 'modern',
                type: "red"
            });
        }).catch(error => {
            return $.alert({
                title: "LA URL no pudo ser construida",
                content: error.responseJSON?.message || 'Ocurrió un error inesperado.',
                theme: 'modern',
                type: "red"
            });
        });
    }


    $(document).on('click', ".pubpag", function () {
            var $btn = $(this);
            let cy = $btn.data('cy');
            let stat = $btn.data('stat');
            let type = $btn.data('type');
            // Misma lógica que editpag: entrada/página ya publicada → solo regenerar HTML (update=1), no despublicar.
            var pagePublicada = $btn.attr('data-page-publicada') === '1';
            var updateOnly = $btn.attr('data-update-only') === '1' || pagePublicada;
            var typeNum = type === undefined || type === '' ? 0 : Number(type);
            var cambio;
            var avisoDominio = '<p style="margin-top:12px;font-size:0.92rem;color:#555;line-height:1.45;">Después de aplicar los cambios, por caché y propagación del dominio puede tardar <strong>al menos 2 minutos</strong> en verse en el sitio público.</p>';
            if (updateOnly) {
                cambio = "¿Actualizar la entrada publicada con los últimos cambios? El HTML estático se regenerará (listado y detalle)." + avisoDominio;
            } else if (stat) {
                cambio = "¿Está seguro de ocultar esta página y dejarla como borrador?";
            } else if (typeNum === 1) {
                cambio = "¿Está seguro de publicar esta página inicial? <strong>Esto despublicará automáticamente cualquier otra página inicial que esté actualmente publicada.</strong>" + avisoDominio;
            } else {
                cambio = "¿Está seguro de publicar esta entrada? Se generará el HTML estático en el sitio (con dominio asignado)." + avisoDominio;
            }
            var url = '/PubPag?p=' + encodeURIComponent(cy) + '&stat=' + stat + '&t=' + typeNum;
            if (updateOnly) {
                url += '&update=1';
            }
            $.alert({
                title: "Advertencia",
                content: cambio,
                theme: 'modern',
                icon: 'fa-solid fa-triangle-exclamation',
                type: "red",
                buttons: {
                    Aceptar: {
                        text: 'Si, continuar',
                        btnClass: 'btn-success',
                        action: function () {
                            var $lock = $('#lockscreen');
                            var $lockText = $lock.find('.textBlockScreen');
                            var defaultLockHtml = '<i class="fas fa-spinner fa-spin"></i>&nbsp;Cargando ...';
                            $.ajax({
                                url: url,
                                method: 'GET',
                                beforeSend(jqXHR, settings) {
                                    $lockText.html(
                                        '<i class="fas fa-spinner fa-spin"></i>&nbsp;Aplicando cambios y generando HTML estático…' +
                                        '<br><span style="display:block;margin-top:14px;font-size:15px;font-weight:500;max-width:440px;margin-left:auto;margin-right:auto;line-height:1.45;color:#444;">Puede tardar unos momentos. No cierre esta pestaña.</span>'
                                    );
                                    $lock.addClass('lockscreen-light').show();
                                },
                                success: function(data) {
                                    window.location.reload();
                                },
                                error: function (xhr) {
                                    $lock.removeClass('lockscreen-light').hide();
                                    $lockText.html(defaultLockHtml);
                                    var errMsg = (xhr.responseJSON && xhr.responseJSON.message)
                                        ? xhr.responseJSON.message
                                        : 'No se pudo completar la acción.';
                                    $.alert({
                                        title: 'Error',
                                        content: errMsg,
                                        theme: 'modern',
                                        type: 'red'
                                    });
                                },
                                complete: function () {
                                    $lock.removeClass('lockscreen-light').hide();
                                    $lockText.html(defaultLockHtml);
                                }
                            });
                        }
                    },
                    Cancelar: {
                        text: 'Cancelar',
                        btnClass: 'btn-alert',
                        action: function () {
                        }
                    }
                }
            });
        });
</script>