        <div class="accordion-item">
            <div class="accordion-header" id="acordeon-regeneracion">
                <button 
                    class="accordion-button aco-perfil"
                    type="button" data-bs-toggle="collapse"
                    data-bs-target="#acordeon-perfil-regeneracion"
