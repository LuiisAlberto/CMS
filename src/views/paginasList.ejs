                    </div>
                </button>
            </div>
            <div id="acordeon-perfil-regeneracion" class="accordion-collapse collapse" aria-labelledby="acordeon-perfil-regeneracion">
                <div class="accordion-body aco-body scroll-hor">
                    <div class="t-r">
                        <button class="btnAco rojo_guinda mt-2" id="crear_regeneracion" onclick="NuevaRegeneracionModal()">
