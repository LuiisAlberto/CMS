        background-color: #6d8373 !important;
    }
    
    .card-header h6 {
        font-size: 1.1rem;
    }
    
    .form-control-lg {
        font-size: 1.1rem;
        padding: 0.75rem 1rem;
    }
    
    .form-label {
        color: #333;
        margin-bottom: 0.5rem;
    }
    
