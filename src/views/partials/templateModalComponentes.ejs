    $(document).on('click', ".btn_save_comp", function (e) {
        e.preventDefault();

        let dataComp = parseInt($(this).data('comp'));
        let table_comp = $(this).data('tablecomp');

        let has_file = $(this).data('hasfile');
        let requiredFields = $(this).data('required') || [];

        let cy = $('.cyphval').val();
        let idpag = <%- datapagina.id_wb_pagina %>;
        let idsec = $(this).data('idsec');
        let idcol = $(this).data('idcol');
        let ordenVisible = $(`.pub_columna[data-idcol="${idcol}"] .pub_componente`).length + 1;

        let dataFormComp = $(this).data('form');
        // Carrusel / galería / línea del tiempo: no usar /CreateComp (imágenes van como fk_id_file[] y el flujo es AGREGAR SLIDE + GUARDAR TODO).
        if (dataFormComp === 'CompSlidesModel_Form') {
            $.alert({
                title: 'Guardar componente',
                content: 'Para este componente use «AGREGAR SLIDE» o «GUARDAR TODO». El botón «GUARDAR» no aplica aquí.',
                theme: 'modern',
                icon: 'fa-solid fa-circle-info',
                type: 'blue'
            });
            return;
        }
        let $form = $('#' + dataFormComp);
        if (dataComp === 3) {
            var $ta = $form.find('textarea[name="texto"]');
            if ($ta.length && $ta.data('summernote')) $ta.val(getEditorTextoValue($form));
        }
        if (dataFormComp === 'CompSlidesModel_Form') {
            finalizeCarruselColorAccentForSubmit();
        }
        if (dataFormComp === 'CompTextImgModel_Form' || dataFormComp === 'RedesModel_Form') {
            finalizeAcentoColorsForSubmit();
        }
        formData = new FormData($form[0]);

        // Validación de campos requeridos
        const { isValid } = validateForm($form, requiredFields);
        if (!isValid) {
            $.alert({
                title: "Campos requeridos",
                content: "Por favor completa todos los campos obligatorios",
                theme: 'modern',
                icon: 'fa-solid fa-triangle-exclamation',
                type: "red"
            });
            return;
        }
        if (has_file === true || has_file === "true") {
            var imgErr = null;
            if (table_comp === 'wb_comp_titulopag') {
                imgErr = validateImageSelectionForForm($form, { tableComp: 'wb_comp_titulopag' });
            } else {
                imgErr = validateImageSelectionForForm($form, { tableComp: table_comp, requiresImage: true });
            }
            if (imgErr) {
                $.alert({
                    title: "Imagen requerida",
                    content: imgErr,
                    theme: 'modern',
                    icon: 'fa-solid fa-triangle-exclamation',
                    type: "orange"
                });
                return;
            }
        }
        if (table_comp === 'wb_comp_cards_regeneracion') {
            const anioInput = $form.find('input[name="year_regeneracion"]');
            const anioValue = parseInt(anioInput.val());
            const anioActual = new Date().getFullYear();

            if (anioValue < 2018 || anioValue > anioActual) {
                $.alert({
                    title: "Advertencia",
                    content: `<strong>El año debe ser entre 2018 y ${anioActual}.</strong>`,
                    theme: 'modern',
                    icon: 'fa-solid fa-triangle-exclamation',
                    type: "red"
                });
                anioInput.focus();
                return;
            }
        }

        formData.append('dataComp', dataComp);
        formData.append('tablecomp', table_comp);
        formData.append('hasfile', has_file);
        formData.append('cy', cy);
        formData.append('idpag', idpag);
        formData.append('idsec', idsec);
        formData.append('idcol', idcol);
        formData.append('orden', ordenVisible);
        
        var $btnSave = $(this);
        if ($btnSave.prop('disabled')) return;
        $btnSave.prop('disabled', true);
        
        $.ajax({
            url: '/CreateComp',
            method: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            beforeSend: function () {
                $('#lockscreen').css('z-index', '1060').fadeIn(200);
            },
            success: function (res){
                if(res.success){
                    // Mantener el lockscreen visible hasta que recargue la página
                    window.location.reload();
                } else {
                    $('#lockscreen').fadeOut(200);
                    $btnSave.prop('disabled', false);
                    alert(res.message || "Ocurrió un error al crear el componente");
                }
            },
            error: function (xhr, status, err){
                $('#lockscreen').fadeOut(200);
                $btnSave.prop('disabled', false);
                console.error("Error:", status, err);
                $.alert({
                    title: "Error al editar",
                    content: xhr.responseJSON?.message || 'Ocurrió un error inesperado.',
                    theme: 'modern',
                    type: "red"
                });
            }
        });
    });
    
