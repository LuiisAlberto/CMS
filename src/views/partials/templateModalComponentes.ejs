    // ============= Guardar acordeón principal (título + descripción) =============
    // opts.silent = true: no muestra alert de éxito ni llama a publicar (para uso desde validarFinalizarAcordeon)
    async function guardarAcordeonPrincipal(opts) {
        const silent = opts && opts.silent === true;
        const titulo = ($('#acordeonTitulo').val() || '').trim();
        const descripcion = ($('#acordeonDescripcion').val() || '').trim();
        const acordeonId = $('#acordeonComponentId').val() || '0';
        const cypherval = $('.cyphval').val();
        
        const idpag = $('#acordeonIdPag').val() || '<%- datapagina.id_wb_pagina %>';
        const idsec = $('#acordeonIdSec').val();
        const idcol = $('#acordeonIdCol').val();
        const dataComp = $('#acordeonDataComp').val() || 25;
        const orden = $('#acordeonOrden').val() || 1;
        
        if (!titulo) {
            showJConfirm('Por favor, ingresa un título para el acordeón');
            throw new Error('Falta título');
        }
        if ((!acordeonId || acordeonId === '0') && (!idcol || idcol === '')) {
            showJConfirm('Error: No se encontró la información de la columna. Por favor, recarga la página e intenta de nuevo.');
            throw new Error('Falta columna');
        }

        try {
            const formData = new FormData();
            formData.append('titulo', titulo);
            formData.append('descripcion', descripcion);
            formData.append('acordeonId', acordeonId);
            formData.append('i', cypherval);
            if (!acordeonId || acordeonId === '0') {
                formData.append('idpag', idpag);
                formData.append('idsec', idsec);
                formData.append('idcol', idcol);
                formData.append('dataComp', dataComp);
                formData.append('orden', orden);
            }

            const response = await fetch('/crear-componente-acordeon', {
                method: 'POST',
                body: JSON.stringify(Object.fromEntries(formData)),
                headers: { 'Content-Type': 'application/json' }
            });
            const result = await response.json();

            if (result.success) {
                $('#acordeonComponentId').val(result.data.acordeonId);
                if (result.data.componenteContenedorAcordeon != null) {
                    $('#acordeonContenedorId').val(result.data.componenteContenedorAcordeon);
                }
                $('#acordeonTableComp').val(result.data.tablecomp || 'wb_comp_acordeon');
                if (!silent) {
                    await publicarAcordeon(result.data.acordeonId, cypherval);
                    $.alert({
                        title: 'Éxito',
                        content: result.message || 'Acordeón guardado correctamente',
                        type: 'green',
                        buttons: { ok: { text: 'Aceptar', btnClass: 'btn-success' } }
                    });
                }
            } else {
                throw new Error(result.message || 'Error al guardar el acordeón');
            }
        } catch (error) {
            console.error('Error:', error);
            $.alert({
                title: 'Error',
                content: error.message || 'No se pudo guardar el acordeón',
                type: 'red'
            });
            throw error;
        }
    }

    // Guardar categoría (tab = categoría de documentos desde el select)
    function agregarCategoria() {
        const $sel = $('#acordeonSelectCategoriaDoc');
        const fk_id_cat_tag = $sel.val();
        const nombreCategoria = $sel.find('option:selected').text().trim();
        const acordeonId = $('#acordeonComponentId').val();
        const cypherval = $('.cyphval').val();

        if (!acordeonId || acordeonId === '0') {
            showJConfirm('Primero debes guardar el acordeón principal antes de agregar pestañas.');
            return;
        }
        if (!fk_id_cat_tag) {
            showJConfirm('Selecciona una categoría de documentos.');
            return;
        }

        fetch('/agregar-categoria-acordeon', {
            method: 'POST',
            body: JSON.stringify({
                nombreCategoria: nombreCategoria,
                fk_id_cat_tag: fk_id_cat_tag,
                acordeonId: acordeonId,
                contenedor: $('#acordeonContenedorId').val(),
                i: cypherval,
                pagina: <%= typeof datapagina !== 'undefined' ? datapagina.id_wb_pagina : '""' %>
            }),
            headers: { 'Content-Type': 'application/json' }
        })
        .then(res => res.json())
        .then(data => {
            if (!data.success) {
                showJConfirm(data.message || 'No se pudo agregar la pestaña.');
                return;
            }
            acordeonAgregarCategoria({
                id_wb_categoria_acordeon: data.data.categoriaId,
                id: data.data.categoriaId,
                descripcion: nombreCategoria,
                fk_id_cat_tag: parseInt(fk_id_cat_tag, 10),
                documentos: []
            });
            $sel.val('');
            $.alert({ title: 'Éxito', content: 'Pestaña agregada.', type: 'green', buttons: { ok: { text: 'Aceptar', btnClass: 'btn-success' } } });
        })
        .catch(err => {
            console.error('Error al agregar categoría:', err);
            showJConfirm('Error inesperado al agregar la pestaña.');
        });
    }

    // Cambiar categoría activa
    $(document).on('click', '.acordeon-tab-btn', function () {
        const catId = Number($(this).data('cat-id'));
        if (!catId) return;

        acordeonActiveCategoryId = catId;

        $('.acordeon-tab-btn').removeClass('is-active');
        $(this).addClass('is-active');

        $('.acordeon-tab-panel').removeClass('is-active').hide();
        $(`.acordeon-tab-panel[data-cat-panel="${catId}"]`)
            .addClass('is-active')
            .show();
    });

    // Scroll horizontal de tabs
    $(document).on('click', '.acordeon-tabs-scroll-btn', function () {
        const dir   = $(this).data('dir');
        const $wrap = $(this).closest('.acordeon-wrapper');
        const $tabs = $wrap.find('.acordeon-tabs');
        if (!$tabs.length) return;

        const delta   = (dir === 'prev') ? -150 : 150;
        const current = $tabs.scrollLeft();
        $tabs.animate({ scrollLeft: current + delta }, 200);
    });

    // Agregar ítem (subcategoría) desde el formulario inline del panel
    $(document).on('click', '.acordeon-btn-agregar-item', function () {
        const catId = Number($(this).data('cat-id'));
        const $panel = $(this).closest('.acordeon-tab-panel');
        const titulo = ($panel.find('.acordeon-input-titulo-item').val() || '').trim();
        const acordeonId = $('#acordeonComponentId').val();
        const cypherval = $('.cyphval').val();

        if (!acordeonId || acordeonId === '0') {
            showJConfirm('No se encontró el ID del acordeón.');
