    function deleteSlide(slideIndex, compType, compSlide, slideId, tablecomp_slide, $slideForm){
        let formData = new FormData();

        formData.append('slideIndex', slideIndex);
        formData.append('compType', compType);
        formData.append('compSlide', compSlide);
        formData.append('slideId', slideId);
        formData.append('tablecomp', tablecomp_slide);
        formData.append('cy', $('.cyphval').val());

        if(!slideId){
            $("#CompSlides_Form_"+slideIndex).remove();
        }else{
            $.ajax({
                url: '/DeleteSlide',
                method: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                beforeSend: function() {
                    $('#lockscreen').fadeIn();
                },
                success: function(res) {
                    $('#lockscreen').fadeOut();
                    if (res.success) {
                        $("#CompSlides_Form_"+slideIndex).remove();
                    } else {
                        console.error(res.message || "Error al eliminar el slide");
                    }
                },
                error: function(xhr, status, err) {
                    $('#lockscreen').fadeOut();
                    console.error("Error:", status, err);
                }
            });
        }
    }

    function addFirstSlide(comp, form, idsec, idcol, colwidth, hasfile, tablecomp, required){

        if($("#CompSlidesId").val() > 0 ){
            renderSlidesForm($("#index_slide").val());
        }else{
            let slideId = 1;
            let dataComp = parseInt(comp);
            let table_comp = tablecomp;

            let has_file = hasfile;
            let requiredFields = required || [];

            let cy = $('.cyphval').val();
            let idpag = <%- datapagina.id_wb_pagina %>;
            
            let ordenVisible = $(`.pub_columna[data-idcol="${idcol}"] .pub_componente`).length + 1;

            let dataFormComp = form;
            let $form = $('#' + dataFormComp);
            finalizeCarruselColorAccentForSubmit();
            formData = new FormData($form[0]);

            // Validación de campos requeridos
            const { isValid } = validateForm($form, requiredFields);
            if (!isValid) {
                $.alert({
                    title: "Campos requeridos",
                    content: "Por favor completa todos los campos obligatorios",
                    theme: 'modern',
                    icon: 'fa-solid fa-triangle-exclamation',
                    type: "red"
                });
                return;
            }
            if (has_file === true || has_file === "true") {
                $form.find('.image-selector-container[data-role="slide-images"]').each(function() { syncHiddenInputsForSelector($(this)); });
                let hasFile = false;
                $form.find('input[type="file"]:visible').each(function () {
                    if (this.files && this.files.length > 0) hasFile = true;
                });
                if (!hasFile) {
                    var idsFromSelector = $form.find('input[name="fk_id_file[]"]').map(function() { return $(this).val(); }).get().filter(Boolean);
                    if (idsFromSelector.length > 0) hasFile = true;
                }
                if (!hasFile) {
                    $.alert({
                        title: "Archivo requerido",
                        content: "Debes subir al menos un archivo o seleccionar al menos una imagen del módulo antes de guardar este componente.",
                        theme: 'modern',
                        icon: 'fa-solid fa-triangle-exclamation',
                        type: "orange"
                    });
                    return;
                }
            }

            formData.append('dataComp', dataComp);
            formData.append('tablecomp', table_comp);
            formData.append('hasfile', has_file);
            formData.append('cy', cy);
            formData.append('idpag', idpag);
            formData.append('idsec', idsec);
            formData.append('idcol', idcol);
            formData.append('orden', ordenVisible);
            formData.append('slideId', slideId);

            $.ajax({
                url: '/CreateFirstSlide',
                method: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                beforeSend(){
                    $('#lockscreen').fadeIn();
                },
                success: function (res){
                    if(res.success){
                        $('#lockscreen').fadeOut();

                        function firstId(v) {
                            if (v == null) return '';
                            if (Array.isArray(v)) return v.length ? String(v[0]) : '';
                            return String(v);
                        }
                        var idCompPrincipal = firstId(res.data.componente_principal);
                        var idSlideInicial = firstId(res.data.slide_inicial);

                        $('#pag_component').val(res.data.id_pag_componente);
                        $('#CompSlidesId').val(idCompPrincipal);
                        $('#SlideId').val(idSlideInicial);
                        $('#tablecomp_slide').val(res.data.table_slides);
                        $('#idpag_slide').val(res.data.idpag);
                        $('#required').val(required);
                        $('#btnIdEliminarSlide_1').attr('data-slideid', idSlideInicial || '0');

                        $(`#index_slide`).val(1);

                        let index = 1;
                        renderSlidesForm(index);
                    } else {
                        alert(res.message || "Ocurrió un error al crear el componente");
                    }
                },
                error: function (xhr, status, err){
                    $('#lockscreen').fadeOut();
                    console.error("Error:", status, err);
                    $.alert({
                        title: "Error al editar",
                        content: xhr.responseJSON?.message || 'Ocurrió un error inesperado.',
                        theme: 'modern',
                        type: "red"
                    });
                }
            });
        }
    }

    function addSlide(pag_component, CompSlidesId, SlideId, tablecomp_slide, idpag_slide, required, form){

        let indexSlide = $(`#index_slide`).val();

        let compType = pag_component;
        let comp_slide = CompSlidesId;
        let idSlide = SlideId;

        $(`#pag_component_${indexSlide}`).val(compType);
        $(`#CompSlidesId_${indexSlide}`).val(comp_slide);
        
        $(`#tablecomp_slide_${indexSlide}`).val(tablecomp_slide);
        $(`#idpag_slide_${indexSlide}`).val(idpag_slide);

        let requiredFields = required || [];
        let dataFormComp = form;
        let $form = $('#CompSlides_Form_' + indexSlide);
        formData = new FormData($form[0]);

        const { isValid } = validateForm($form, requiredFields);
        if (!isValid) {
            $.alert({
                title: "Campos requeridos",
                content: "Por favor completa todos los campos obligatorios antes de agregar un nuevo slide",
                theme: 'modern',
                icon: 'fa-solid fa-triangle-exclamation',
                type: "red"
            });
            return;
        }

        var imgErr = validateImageSelectionForForm($form, { isSlideForm: true, tablecomp_slide: tablecomp_slide });
        if (imgErr) {
            $.alert({
                title: "Imágenes del slide",
                content: imgErr,
                theme: 'modern',
                icon: 'fa-solid fa-triangle-exclamation',
                type: "orange"
            });
            return;
        }
        
        var hasSlideImages = $form.find('input[name="fk_id_file[]"]').filter(function() { return $(this).val(); }).length > 0;
        if (!hasSlideImages) {
            formData.append('skipFile', 'true');
        }
        
        // Agregar datos adicionales
        formData.append('indexSlide', indexSlide);
        formData.append('compType', compType);
        formData.append('comp_slide', comp_slide);
        formData.append('slideId', idSlide);
        formData.append('tablecomp', tablecomp_slide);
        formData.append('idpag', idpag_slide);
        formData.append('cy', $('.cyphval').val());
        
        $.ajax({
            url: '/AddSlides',
            method: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            beforeSend(){
                $('#lockscreen').fadeIn();
            },
            success: function (res){
                $('#lockscreen').fadeOut();
                console.log('[addSlide] AddSlides response:', res);
                if(res.success){
                    var $slideIdEl = $(`#SlideId_${indexSlide}`);
                    if ($slideIdEl.length) $slideIdEl.val(res.data.slideId);
                    $(`#btnIdEliminarSlide_${indexSlide}`).attr('data-slideid', res.data.slideId);

                    renderSlidesForm(indexSlide);
                    $(this).hide();
                } else {
                    $.alert({
                        title: "Error al editar",
                        content: res.message,
                        theme: 'modern',
                        type: "red"
                    });
                }
            },
            error: function (xhr, status, err){
                $('#lockscreen').fadeOut();
                console.error("[addSlide] Error AddSlides:", status, err, xhr.responseJSON);
                $.alert({
                    title: "Error al editar",
                    content: xhr.responseJSON?.message || 'Ocurrió un error inesperado.',
                    theme: 'modern',
                    type: "red"
                });
            }
        });
    };
</script>
