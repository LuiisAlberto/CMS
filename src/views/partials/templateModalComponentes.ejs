                    return `
                        <div class="acordeon-doc-item" data-doc-id="${acordeonEscapeHtml(doc.id)}">
                            <span class="btn-delete-subcategoria" 
                                  data-sub-id="${acordeonEscapeHtml(doc.id)}"
                                  onclick="eliminarElementoAcordeon('subcategoria', ${acordeonEscapeHtml(doc.id)}, event)">
                                <i class="fa-solid fa-times"></i>
                            </span>
                            <div class="acordeon-doc-header">
                                <h6 class="acordeon-doc-title mb-0">
                                    ${acordeonEscapeHtml(doc.titulo || 'Sin título')}
                                </h6>
                                <button type="button" class="acordeon-doc-toggle">
                                    <i class="fa-solid fa-chevron-down"></i>
                                </button>
                            </div>
                            <div class="acordeon-doc-body">
                                <div class="acordeon-inner-wrapper">
                                    <div class="acordeon-inner-list">
                                        ${acordeonesHtml}
                                    </div>
                                    <div class="mt-2">
                                        <button type="button" class="btn btn-sm btn-outline-primary acordeon-btn-seleccionar-docs"
                                            data-sub-id="${acordeonEscapeHtml(doc.id)}"
                                            data-cat-tag="${acordeonEscapeHtml(cat.fk_id_cat_tag || '')}">
                                            <i class="fa-solid fa-folder-open"></i> Seleccionar documentos
                                        </button>
                                        <div class="acordeon-inline-doc-selector mt-2 d-none" data-sub-id="${acordeonEscapeHtml(doc.id)}"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;
                }).join('')
                : `<div class="text-center text-muted py-4" style="background: #f9f9f9; border-radius: 8px; border: 1px dashed #ddd;">
                    <i class="fa-solid fa-folder-open mb-2" style="font-size: 32px; opacity: 0.4;"></i>
                    <p class="mb-1 fw-bold">No hay ítems en esta pestaña</p>
                    <small>Usa el formulario de arriba para agregar un ítem (ej. Convocatorias jurídico).</small>
                </div>`;

            // Panel de categoría (con formulario inline para agregar ítem)
            $content.append(`
                <div 
                    class="acordeon-tab-panel ${isActive ? 'is-active' : ''}"
                    data-cat-panel="${cat.id}"
                    data-cat-tag="${acordeonEscapeHtml(cat.fk_id_cat_tag || '')}">
                    
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h6 class="mb-0 name_slide">${safeTitle}</h6>
