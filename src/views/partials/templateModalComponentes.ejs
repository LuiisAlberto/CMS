    var acordeonDocSelectorState = { page: 1, search: '', totalPages: 1, selectedDoc: null };
    var acordeonInlineDocSelectorSubId = null;

    $(document).on('click', '.acordeon-btn-seleccionar-docs', function () {
        var subId = $(this).data('sub-id');
        var catTag = $(this).data('cat-tag');
        var $container = $(this).siblings('.acordeon-inline-doc-selector');
        if ($container.hasClass('d-none')) {
            acordeonInlineDocSelectorSubId = subId;
            $container.removeClass('d-none').empty().html('<p class="small text-muted">Cargando...</p>');
            loadInlineDocSelector($container, catTag, subId);
        } else {
            $container.addClass('d-none').empty();
            acordeonInlineDocSelectorSubId = null;
        }
    });

    function loadInlineDocSelector($container, catTag, subId) {
        var token = $('.cyphval').val() || '';
        $.ajax({
            url: '/GetDocs',
            method: 'GET',
            data: { i: token, page: 1, limit: 50, search: '', tag: catTag || '' }
        }).done(function (data) {
            if (!data || !data.success || !data.documents) {
                $container.html('<p class="small text-danger">No se pudieron cargar documentos.</p>');
                return;
            }
            var docs = data.documents;
            var selectedIds = [];
            var html = '<div class="border rounded p-2 bg-white"><p class="small mb-2">Selecciona los documentos para este ítem:</p><div class="acordeon-inline-doc-list mb-2" style="max-height:200px;overflow-y:auto;">';
            docs.forEach(function (d) {
                var id = d.id_wb_doc;
                var name = (d.nombre || '').replace(/</g, '&lt;');
                html += '<label class="d-block small"><input type="checkbox" class="acordeon-inline-doc-cb me-2" value="' + id + '"> ' + name + '</label>';
            });
            html += '</div><button type="button" class="btn btn-sm btn-primary acordeon-inline-doc-apply" data-sub-id="' + subId + '">Aplicar</button></div>';
            $container.html(html);
        }).fail(function () {
            $container.html('<p class="small text-danger">Error al cargar.</p>');
        });
    }

    $(document).on('click', '.acordeon-inline-doc-apply', function () {
        var subId = $(this).data('sub-id');
        var $container = $(this).closest('.acordeon-inline-doc-selector');
        var ids = [];
        $container.find('.acordeon-inline-doc-cb:checked').each(function () { ids.push(Number($(this).val())); });
        var cypherval = $('.cyphval').val();
        fetch('/acordeon-subcategoria-documentos', {
            method: 'POST',
            body: JSON.stringify({ subcategoriaId: subId, documentoIds: ids, i: cypherval }),
            headers: { 'Content-Type': 'application/json' }
        }).then(function (r) { return r.json(); }).then(function (data) {
            if (data.success) {
                $container.addClass('d-none').empty();
                acordeonRefetchAndRender();
            } else {
                showJConfirm(data.message || 'Error al guardar.');
            }
        }).catch(function () { showJConfirm('Error al guardar documentos.'); });
    });

    function buildAcordeonDocumentSelector() {
        var token = $('.cyphval').val() || '';
        var page = acordeonDocSelectorState.page || 1;
        var search = (acordeonDocSelectorState.search || '').trim();
        var $grid = $('#acordeonDocSelectorGrid').empty();
        var $pagination = $('#acordeonDocSelectorPagination').empty();
        $grid.html('<p class="text-muted small">Cargando documentos...</p>');

        $.ajax({
            url: '/GetDocs',
            method: 'GET',
            data: { i: token, page: page, limit: 10, search: search }
        }).done(function (data) {
            if (!data || !data.success || !data.documents) {
                $grid.html('<p class="text-muted small">No se pudieron cargar los documentos.</p>');
                return;
            }
            var docs = data.documents;
            acordeonDocSelectorState.totalPages = data.totalPages || 1;
            if (!docs.length) {
                $grid.html('<p class="text-muted small">No hay documentos en el repositorio. Sube documentos en el módulo de Documentos.</p>');
                return;
            }
            docs.forEach(function (doc) {
                var arch = doc.archivodoc || {};
                var storage = arch.storage || {};
                var url = (storage.storage_path || '') + (arch.file_path || '');
                if (url && !/^https?:\/\//i.test(url)) url = 'https://cdn.morena.app/' + url.replace(/^\//, '');
                var nombre = (doc.nombre || '').replace(/</g, '&lt;');
                var isPdf = (arch.file_path || '').toLowerCase().indexOf('.pdf') !== -1;
                var $col = $('<div class="col-12 col-sm-6"></div>');
                var $card = $('<div class="acordeon-doc-card"></div>')
                    .data('doc', { id_wb_doc: doc.id_wb_doc, nombre: doc.nombre, contenido_alt: doc.contenido_alt || '', url: url });
                $card.append(
                    $('<div class="acordeon-doc-card-icon"></div>').html('<i class="fa-solid fa-file-' + (isPdf ? 'pdf' : 'word') + '"></i>'),
                    $('<div class="acordeon-doc-card-name flex-grow-1"></div>').text(doc.nombre || 'Sin nombre')
                );
                $col.append($card);
                $grid.append($col);
                $card.on('click', function () {
                    var d = $(this).data('doc');
                    acordeonDocSelectorState.selectedDoc = d;
                    $('#acordeonAcordeonTitulo').val(d.nombre || '');
                    $('#acordeonAcordeonContenido').val(d.contenido_alt || '');
                    $('#acordeonAcordeonUrlLink').val(d.url || '');
                    $('#acordeonSelectedDocName').text(d.nombre || '');
                    $('#acordeonDocSelectorBlock').addClass('d-none');
                    $('#acordeonAcordeonFormBlock').removeClass('d-none');
                    $('#acordeonAcordeonTitulo').focus();
                });
            });
            if (acordeonDocSelectorState.totalPages > 1) {
                var cur = data.currentPage || page;
                var total = acordeonDocSelectorState.totalPages;
                var $ul = $('<ul class="pagination pagination-sm mb-0"></ul>');
                $ul.append('<li class="page-item' + (cur === 1 ? ' disabled' : '') + '"><a class="page-link" href="#" data-page="' + (cur - 1) + '">«</a></li>');
                for (var i = 1; i <= total; i++) {
                    $ul.append('<li class="page-item' + (i === cur ? ' active' : '') + '"><a class="page-link" href="#" data-page="' + i + '">' + i + '</a></li>');
                }
                $ul.append('<li class="page-item' + (cur === total ? ' disabled' : '') + '"><a class="page-link" href="#" data-page="' + (cur + 1) + '">»</a></li>');
                $pagination.append($ul);
            }
        }).fail(function () {
            $grid.html('<p class="text-danger small">Error al cargar documentos.</p>');
        });
    }

    $(document).on('click', '#acordeonDocSelectorPagination .page-link', function (e) {
        e.preventDefault();
        if ($(this).closest('.page-item').hasClass('disabled')) return;
        var p = parseInt($(this).data('page'), 10);
        if (p >= 1 && p <= acordeonDocSelectorState.totalPages) {
            acordeonDocSelectorState.page = p;
            buildAcordeonDocumentSelector();
        }
    });

    $(document).on('input', '#acordeonDocSelectorSearch', function () {
        var val = $(this).val();
        acordeonDocSelectorState.search = val;
        acordeonDocSelectorState.page = 1;
        clearTimeout(window.acordeonDocSearchTimeout);
        window.acordeonDocSearchTimeout = setTimeout(function () { buildAcordeonDocumentSelector(); }, 350);
    });

    $(document).on('click', '#acordeonCambiarDocumento', function () {
        acordeonDocSelectorState.selectedDoc = null;
        $('#acordeonDocSelectorBlock').removeClass('d-none');
        $('#acordeonAcordeonFormBlock').addClass('d-none');
        $('#acordeonAcordeonTitulo').val('');
        $('#acordeonAcordeonContenido').val('');
        $('#acordeonAcordeonUrlLink').val('');
        acordeonDocSelectorState.page = 1;
        buildAcordeonDocumentSelector();
    });

    function agregarNuevoAcordeon(btn) {
        var catId = Number($(btn).data('cat-id'));
        var docId = $(btn).data('doc-id');

        acordeonCurrentSubForAcc = { catId: catId, docId: docId };
        acordeonDocSelectorState.page = 1;
        acordeonDocSelectorState.search = '';
        acordeonDocSelectorState.selectedDoc = null;
        $('#acordeonDocSelectorSearch').val('');
        $('#acordeonDocSelectorBlock').removeClass('d-none');
        $('#acordeonAcordeonFormBlock').addClass('d-none');
        $('#acordeonAcordeonTitulo').val('');
        $('#acordeonAcordeonContenido').val('');
        $('#acordeonAcordeonUrlLink').val('');

        $('#acordeonAcordeonDialog').removeClass('d-none');
        buildAcordeonDocumentSelector();
    }

    // Cerrar modal acordeón interno
    $(document).on('click', '.acordeon-acordeon-cancel', function () {
        $('#acordeonAcordeonDialog').addClass('d-none');
        acordeonCurrentSubForAcc = null;
    });

    // Registrar acordeón interno
    $(document).on('click', '#btnRegistrarAcordeonModal', function (e) {
        e.preventDefault();

        const titulo    = ($('#acordeonAcordeonTitulo').val() || '').trim();
        const contenido = ($('#acordeonAcordeonContenido').val() || '').trim();
        const url_link  = ($('#acordeonAcordeonUrlLink').val() || '').trim();
        const componenteId = $('#acordeonComponentId').val();
        const cypherval = $('.cyphval').val();

        if (!titulo) {
            showJConfirm('El título del acordeón es obligatorio.');
            return;
        }
        if (!url_link) {
            showJConfirm('La URL del archivo es obligatoria.');
            return;
        }
        if (!acordeonCurrentSubForAcc) {
            showJConfirm('No se pudo identificar la subcategoría actual.');
            return;
        }
        if (!componenteId || componenteId === '0') {
            showJConfirm('Error: No se encontró el ID del componente');
            return;
        }

        const formData = {
            titulo: titulo,
            contenido: contenido,
            url_link: url_link,
            componenteId: componenteId,
            subcategoriaId: acordeonCurrentSubForAcc.docId,
            i: cypherval
        };

        fetch('/agregar-acordeon', {
            method: 'POST',
            body: JSON.stringify(formData),
            headers: { 'Content-Type': 'application/json' }
        })
        .then(res => res.json())
        .then(data => {
            if (!data.success) {
                showJConfirm(data.message || 'No se pudo agregar el acordeón.');
                return;
            }

            // Agregar acordeón al estado local con el ID retornado
            acordeonAgregarAcordeon(
                acordeonCurrentSubForAcc.catId,
                acordeonCurrentSubForAcc.docId,
                { 
                    titulo, 
                    contenido,
                    url_link,
                    id: data.data.acordeonId 
                }
            );

            $('#acordeonAcordeonDialog').addClass('d-none');
            acordeonCurrentSubForAcc = null;

            $.alert({
                title: 'Éxito',
                content: 'Acordeón agregado correctamente',
                type: 'green',
                buttons: {
                    ok: { text: 'Aceptar', btnClass: 'btn-success' }
                }
            });
        })
        .catch(err => {
            console.error('Error al agregar acordeón:', err);
            showJConfirm('Ocurrió un error inesperado al agregar el acordeón.');
        });
    });

    // Función para eliminar elementos (categoría, subcategoría o acordeón)
    function eliminarElementoAcordeon(tipo, elementoId, event) {
        if (event) {
            event.stopPropagation();
            event.preventDefault();
        }

        const tipoTexto = tipo === 'categoria' ? 'categoría' : 
                         tipo === 'subcategoria' ? 'subcategoría' : 'acordeón';

        $.confirm({
            title: 'Confirmar eliminación',
            content: `¿Estás seguro de que deseas eliminar esta ${tipoTexto}?`,
            type: 'red',
            buttons: {
                confirmar: {
                    text: 'Eliminar',
                    btnClass: 'btn-danger',
                    action: function() {
                        const cypherval = $('.cyphval').val();
                        
                        fetch('/eliminar-elemento-acordeon', {
                            method: 'POST',
                            body: JSON.stringify({
                                tipo: tipo,
                                elementoId: elementoId,
                                i: cypherval
                            }),
                            headers: { 'Content-Type': 'application/json' }
                        })
                        .then(res => res.json())
                        .then(data => {
                            if (!data.success) {
                                showJConfirm(data.message || 'No se pudo eliminar el elemento.');
                                return;
                            }

                            // Eliminar del estado local
                            if (tipo === 'categoria') {
                                const index = acordeonCategorias.findIndex(c => 
                                    c.id_wb_categoria_acordeon === elementoId || c.id === elementoId
                                );
                                if (index !== -1) {
                                    acordeonCategorias.splice(index, 1);
                                }
                            } else if (tipo === 'subcategoria') {
                                for (let cat of acordeonCategorias) {
                                    const index = cat.documentos.findIndex(d => d.id === elementoId);
                                    if (index !== -1) {
                                        cat.documentos.splice(index, 1);
                                        break;
                                    }
                                }
                            } else if (tipo === 'acordeon') {
                                for (let cat of acordeonCategorias) {
                                    for (let doc of cat.documentos) {
                                        const index = doc.acordeones.findIndex(a => a.id === elementoId);
                                        if (index !== -1) {
                                            doc.acordeones.splice(index, 1);
                                            break;
                                        }
                                    }
                                }
                            }

                            acordeonRenderTabs();

                            $.alert({
                                title: 'Éxito',
                                content: `${tipoTexto.charAt(0).toUpperCase() + tipoTexto.slice(1)} eliminada correctamente`,
                                type: 'green',
                                buttons: {
                                    ok: { text: 'Aceptar', btnClass: 'btn-success' }
                                }
                            });
                        })
                        .catch(err => {
                            console.error('Error al eliminar elemento:', err);
                            showJConfirm('Ocurrió un error inesperado al eliminar el elemento.');
                        });
                    }
                },
                cancelar: {
                    text: 'Cancelar',
                    btnClass: 'btn-secondary'
                }
            }
        });
    }

    // Expandir / colapsar subcategoría (documento)
    $(document).on('click', '.acordeon-doc-header', function () {
        $(this).closest('.acordeon-doc-item').toggleClass('open');
    });

    // Scroll vertical de lista de documentos
    $(document).on('click', '.btn-docs-prev, .btn-docs-next', function () {
        const $pane = $(this).closest('.acordeon-tab-panel');
        const $list = $pane.find('.acordeon-docs-list');
        if (!$list.length) return;

        const delta   = $(this).hasClass('btn-docs-prev') ? -120 : 120;
        const current = $list.scrollTop();
        $list.animate({ scrollTop: current + delta }, 200);
    });

    async function validarFinalizarAcordeon() {
        const cypherval = $('.cyphval').val();

        // 0. Guardar título y descripción (por si el usuario los editó)
        try {
            await guardarAcordeonPrincipal({ silent: true });
        } catch (e) {
            return;
        }

        const acordeonId = $('#acordeonComponentId').val();

        // 1. Validar que el acordeón principal esté guardado
        if (!acordeonId || acordeonId === '0') {
            $.alert({
                title: 'Atención',
                content: 'Debes guardar el título del acordeón primero (Paso 1).',
                type: 'orange'
            });
            return;
        }

        // Si por algún motivo no se cargó el estado en memoria, rehidratar antes de validar.
        if (acordeonCategorias.length === 0) {
            try {
                await acordeonHydrateFromServer(acordeonId);
            } catch (e) {
                // si falla, continúa con la validación normal (mostrará el mensaje)
            }
        }

        // 2. Validar que haya al menos una categoría
        if (acordeonCategorias.length === 0) {
            $.alert({
                title: 'Atención',
                content: 'Debes agregar al menos una categoría.',
                type: 'orange'
            });
            return;
        }

        // 3. Validar que al menos una categoría tenga subcategorías
        const tieneSubcategorias = acordeonCategorias.some(cat => cat.documentos && cat.documentos.length > 0);
        if (!tieneSubcategorias) {
            $.alert({
                title: 'Atención',
                content: 'Debes agregar al menos una subcategoría en alguna de las categorías.',
                type: 'orange'
            });
            return;
        }

        try {
            await publicarAcordeon(acordeonId, cypherval);
            $.alert({
                title: 'Éxito',
                content: 'Acordeón guardado correctamente.',
                type: 'green',
                buttons: {
                    ok: {
                        text: 'Aceptar',
                        btnClass: 'btn-success',
                        action: function() {
                            window.location.reload();
                        }
                    }
                }
            });
        } catch (e) {
            console.error(e);
            $.alert({
                title: 'Error',
                content: 'Ocurrió un error al finalizar el guardado.',
                type: 'red'
            });
        }
    }

    async function publicarAcordeon(acordeonId, cypherval) {
        try {
            const response = await fetch('/publicar-acordeon', {
                method: 'POST',
                body: JSON.stringify({ acordeonId: acordeonId, i: cypherval }),
                headers: { 'Content-Type': 'application/json' }
            });
            const result = await response.json();
            if (!result.success) {
                console.warn('No se pudo publicar el acordeón automáticamente:', result.message);
            }
        } catch (e) {
            console.error('Error al intentar publicar el acordeón:', e);
        }
    }
</script>
