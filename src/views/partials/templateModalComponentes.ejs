    function applySlideImageMax($scope, max) {
        const $root = $scope ? $($scope) : $(document);
        const m = parseInt(max, 10);
        if (!m || m <= 0) return;
        $root.find('.image-selector-container[data-role="slide-images"]').each(function () {
            const $c = $(this);
            $c.attr('data-max', m);
