    // === BLOQUE ESPECIAL PARA TIPO 9 (ACORDEÓN) - EJECUTAR DESPUÉS DE MOSTRAR EL MODAL ===
    if (tipo === 9) {
        // Esperar a que el modal esté completamente visible y el DOM actualizado
        setTimeout(() => {
            refreshAcordeonCategoriasDocumentosSelect();
