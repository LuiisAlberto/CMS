    function abrirModalFormularioComp(dataComp, result, id_sec, id_col, colWidth, hasfile, tablecomp) {
        limpieza_modalGral();
        var tableStrModal = (tablecomp != null && tablecomp !== undefined) ? String(tablecomp) : '';
        var dcForRules = (tableStrModal && Object.prototype.hasOwnProperty.call(TABLE_TO_CANONICAL_DATACOMP, tableStrModal))
            ? TABLE_TO_CANONICAL_DATACOMP[tableStrModal]
            : dataComp;
        modalGral_addTit('NUEVO CONTENIDO');
        modalGral_addSubtit('A continuación registra el contenido solicitado');
        modalGral_bodyAppend(getHtmlTemplate(result.body));
        if (dataComp === 9 || tableStrModal === 'wb_comp_acordeon') $('#modalGral').addClass('modal-acordeon');
        // Configuración especial para componentes slide (5, 10, 14): definir tabla y límite de imágenes antes de inicializar selector
        var slideTableFromParent = {
            'wb_comp_carrousel': { dc: 5, slide: 'wb_comp_slides_carrousel' },
            'wb_comp_galeria': { dc: 10, slide: 'wb_comp_slides_galeria' },
            'wb_comp_linea': { dc: 14, slide: 'wb_comp_slides_linea' },
        };
        var slideMeta = slideTableFromParent[tableStrModal];
        var slideDc = slideMeta ? slideMeta.dc : dataComp;
        if ([5, 10, 14].includes(dataComp) || slideMeta) {
            const slideTableMap = {
                5: 'wb_comp_slides_carrousel',
                10: 'wb_comp_slides_galeria',
                14: 'wb_comp_slides_linea'
            };
            const tablecomp_slide = slideMeta ? slideMeta.slide : slideTableMap[slideDc];
            $('#tablecomp_slide').val(tablecomp_slide);
            const slideImgMax = (tablecomp_slide === 'wb_comp_slides_carrousel') ? 4 : 1;
            applySlideImageMax($('#modalGral'), slideImgMax);
        }
        // Inicializar selectores de imágenes dentro del modal recién generado
        initImageSelectorContainers('#modalGral');
        // Cargar tags actualizados (imágenes, entradas) para que categorías nuevas aparezcan
        refreshComponentModalTags();

        const compConfig = ComponentConfig[dcForRules] || ComponentConfig[dataComp] || { requiredFields: [] };
        result.requiredFields = compConfig.requiredFields;

        // Tus reglas de UI (usar id lógico para no mostrar campo texto en noticias si el id en BD ≠ 8)
        reglasFormDinamicos(dcForRules, result, tablecomp);

        // Si es acordeón (dataComp === 9 o tabla acordeón), guardar los datos de página/sección/columna
        if (dataComp === 9 || tableStrModal === 'wb_comp_acordeon') {
            setTimeout(() => {
                $('.btn_save_comp').hide();

                const idpag = <%- datapagina.id_wb_pagina %>;
                const ordenVisible = $(`.pub_columna[data-idcol="${id_col}"] .pub_componente`).length + 1;
                
                $('#acordeonIdPag').val(idpag);
                $('#acordeonIdSec').val(id_sec);
                $('#acordeonIdCol').val(id_col);
                $('#acordeonDataComp').val(dataComp);
                $('#acordeonOrden').val(ordenVisible);
                

                const footerAcordeon = `
                    <button
                        class="btnGral verde_t"
                        type="button"
                        data-comp="${dataComp}"
                        data-form="${result.form}"
                        data-idsec="${id_sec}"
                        data-idcol="${id_col}"
                        data-colwidth="${colWidth}"
                        data-hasfile="${hasfile}"
                        data-tablecomp="${tablecomp}"
                        data-required='${JSON.stringify(result.requiredFields)}' onclick="validarFinalizarAcordeon()">
                        <p>GUARDAR</p>
                        <div class="btnIcon">
                            <div class="boxIcon verde"><img src="assets/img/GUARDAR.svg"></div>
                            <span class="s-verde"></span>
                        </div>
                    </button>`;

                $('#modalGral .modal-footer').append(footerAcordeon);
            }, 100);
        }

        const footer = `
            <button class="btnGral guinda_t btn-cerrar-modal" type="button" data-bs-dismiss="modal" aria-label="Cancelar">
                <p>CANCELAR</p>
                <div class="btnIcon">
                    <div class="boxIcon guinda"><img src="assets/img/TIMES.svg"></div>
                    <span class="s-guinda"></span>
                </div>
            </button>
            <button
                class="btnGral btn_save_comp verde_t"
                type="button"
                data-comp="${dataComp}"
                data-form="${result.form}"
                data-idsec="${id_sec}"
                data-idcol="${id_col}"
                data-colwidth="${colWidth}"
                data-hasfile="${hasfile}"
                data-tablecomp="${tablecomp}"
                data-required='${JSON.stringify(result.requiredFields)}'>
                <p>GUARDAR</p>
                <div class="btnIcon">
                    <div class="boxIcon verde"><img src="assets/img/GUARDAR.svg"></div>
                    <span class="s-verde"></span>
                </div>
            </button>`;
        modalGral_addFooter(footer);

        if ([5, 10, 14].includes(dataComp)){ // solo slides
            setTimeout(() => {
                $('.btn_save_comp').hide();

                const footerSlides = `
                    <button type="button" class="btn_add_slides btnGral oro_t"
                            data-index="1"
                            data-comp="${dataComp}"
                            data-form="${result.form}"
                            data-idsec="${id_sec}"
                            data-idcol="${id_col}"
                            data-colwidth="${colWidth}"
                            data-hasfile="${hasfile}"
                            data-tablecomp="${tablecomp}"
                            data-required='${JSON.stringify(result.requiredFields)}'>
                        <p>AGREGAR SLIDE</p>
                        <div class="btnIcon">
                            <div class="boxIcon oro"><img src="assets/img/AGREGAR.svg"></div>
                            <span class="s-oro"></span>
                        </div>
                    </button>

                    <button class="btnGral btn_save_all_slides_status verde_t" type="button"
                        data-comp="${dataComp}"
                        data-form="${result.form}"
                        data-idsec="${id_sec}"
                        data-idcol="${id_col}"
                        data-idpag="<%- datapagina.id_wb_pagina %>"
                        data-colwidth="${colWidth}"
                        data-hasfile="${hasfile}"
                        data-tablecomp="${tablecomp}"
                        data-required='${JSON.stringify(result.requiredFields)}'
                        data-editmode="false">
                        <p>GUARDAR TODO</p>
                        <div class="btnIcon">
                            <div class="boxIcon verde"><img src="assets/img/GUARDAR.svg"></div>
                            <span class="s-verde"></span>
                        </div>
                    </button>
                `;

                $('#modalGral .modal-footer').append(footerSlides);
            }, 200); 
        }

        // ⬇️ Obtener o crear instancia del modal (editpag abre con getOrCreateInstance sin asignar modalGralInstance)
        var modalEl = document.getElementById('modalGral');
        if (!modalGralInstance && modalEl && typeof bootstrap !== 'undefined' && bootstrap.Modal) {
            var existingInst = bootstrap.Modal.getInstance(modalEl);
            modalGralInstance = existingInst || new bootstrap.Modal(modalEl, { backdrop: true, keyboard: true });
        }
        if (!modalGralInstance) {
            modalGralInstance = new bootstrap.Modal($('#modalGral')[0], { backdrop: true, keyboard: true });
        }
        modalGralInstance.show();
        if (result.idCompTemplate) {
            $('#'+result.idCompTemplate).val(result.comp);
        }
    }

    function getColWidth(colElement) {
        if (!colElement || colElement.length === 0) {
            return 12;
        }

        const colClass = colElement.attr('class').split(' ').find(cls => cls.startsWith('col-md-'));
        if (colClass) {
            return parseInt(colClass.replace('col-md-', ''), 10);
        }
        return 12;
    }

