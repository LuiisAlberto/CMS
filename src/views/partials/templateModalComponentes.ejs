function formatDateYMD(value){
  const d = value ? new Date(value) : null;
  if(!d || Number.isNaN(d.getTime())) return '';
  const y = d.getFullYear();
  const m = String(d.getMonth()+1).padStart(2,'0');
  const day = String(d.getDate()).padStart(2,'0');
  return `${y}-${m}-${day}`;
}

function syncAcentoPickerFromHidden(hiddenId) {
  var $h = $('#' + hiddenId);
  var pickerId = hiddenId === 'color_acento_redes' ? 'color_acento_redes_picker' : 'color_acento_picker';
  var $p = $('#' + pickerId);
  if (!$h.length || !$p.length) return;
  var raw = ($h.val() || '').trim();
  if (raw && /^#?[0-9A-Fa-f]{6}$/.test(raw.replace(/^#/, ''))) {
    $h.removeAttr('data-theme-default');
    var hex = raw.indexOf('#') === 0 ? raw.toLowerCase() : ('#' + raw.toLowerCase());
    $p.val(hex);
  } else {
    $h.attr('data-theme-default', '1');
    $h.val('');
    $p.val('#8e2c2d');
  }
}

function finalizeAcentoColorsForSubmit() {
  [['color_acento', 'color_acento_picker'], ['color_acento_redes', 'color_acento_redes_picker']].forEach(function (pair) {
    var h = document.getElementById(pair[0]);
    var p = document.getElementById(pair[1]);
    if (!h || !p) return;
    if (h.getAttribute('data-theme-default') === '1') {
      h.value = '';
    } else {
      h.value = p.value || '';
    }
  });
}

function setFieldValue($field, value){
  if(!$field || !$field.length) return;
  const type = ($field.attr('type')||'').toLowerCase();
  const v = type === 'date' ? formatDateYMD(value) : value;
  $field.val(v);
  const fid = $field.attr('id');
  if (fid === 'color_acento' || fid === 'color_acento_redes') {
    syncAcentoPickerFromHidden(fid);
  }
}

function ocultar(selectores) {
  if (!Array.isArray(selectores) || !selectores.length) return;

  const $contenedores = $(selectores.join(','));

  $contenedores.each(function () {
    const $c = $(this);

    $c.hide();

    $c.find('input, select, textarea')
      .each(function () {
        const $field = $(this);

        $field.prop('disabled', true).removeClass('required');

        // Limpia el valor
        if ($field.is(':checkbox, :radio')) {
          $field.prop('checked', false);
        } else if ($field.is('select')) {
          $field.prop('selectedIndex', 0);
        } else {
          $field.val('');
        }
      });
  });
}


function expandir(selectores){
  if (!Array.isArray(selectores) || !selectores.length) return;

  const $contenedores = $(selectores.join(','));

  $contenedores.each(function () {
    const $c = $(this);
    $c.show();
    $c.addClass('col-lg-12').removeClass('col-lg-3');
    $c.find('input, select, textarea').each(function () {
      $(this).prop('disabled', false);
    });
  });
}


function validarAnioRegeneracion($anioInput){
  const anioActual = new Date().getFullYear();
  const check = () => {
    const val = parseInt($anioInput.val(), 10);
    if(Number.isFinite(val) && val > anioActual) $anioInput.val(anioActual);
  };
  check();
  $anioInput.on('input change', check);
}

