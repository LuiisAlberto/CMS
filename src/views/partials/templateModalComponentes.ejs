<script>
    const tagsEntradas = <%- JSON.stringify(tags_entradas_content) %>;
    const tagsImgs     = <%- JSON.stringify(tags_images_content) %>;
    const tagsDocs     = <%- JSON.stringify(tags_docs) %>;

    /** Categorías de documentos para acordeón: siempre desde API (misma lista que editpag). */
    function refreshAcordeonCategoriasDocumentosSelect(opts) {
        opts = opts || {};
        var attempt = opts.attempt != null ? opts.attempt : 1;
        var maxAttempts = opts.maxAttempts != null ? opts.maxAttempts : 10;
        var retryMs = opts.retryMs != null ? opts.retryMs : 150;

        var $sel = $('#acordeonSelectCategoriaDoc');
        if (!$sel.length) {
            if (attempt < maxAttempts) {
                return setTimeout(function () {
                    refreshAcordeonCategoriasDocumentosSelect({
                        attempt: attempt + 1,
                        maxAttempts: maxAttempts,
                        retryMs: retryMs
                    });
                }, retryMs);
            }
            return;
        }

        fetch('/api/tags?tipo=documentos&incluir_todas=1', { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (!data || !data.success || !Array.isArray(data.tags)) return;
                if (data.tags.length === 0) {
                    // Si el SSR ya traía opciones, no las borremos por un posible fallo/latencia.
                    var hasAnyRealOption = $sel.find('option').filter(function () { return String($(this).val() || '') !== ''; }).length > 0;
                    if (!hasAnyRealOption && attempt < maxAttempts) {
                        return setTimeout(function () {
                            refreshAcordeonCategoriasDocumentosSelect({
                                attempt: attempt + 1,
                                maxAttempts: maxAttempts,
                                retryMs: retryMs
                            });
                        }, retryMs);
                    }
                    return;
                }

                var ph = 'Seleccionar categoría...';
                $sel.empty().append($('<option value="">').text(ph));
                data.tags.forEach(function (t) {
                    $sel.append($('<option>').val(t.id_cat_tag).text(t.tag || ''));
                });
            })
            .catch(function () {
                if (attempt < maxAttempts) {
                    setTimeout(function () {
                        refreshAcordeonCategoriasDocumentosSelect({
                            attempt: attempt + 1,
                            maxAttempts: maxAttempts,
                            retryMs: retryMs
                        });
                    }, retryMs);
                }
            });
    }

    // Actualiza los selects de tags (imágenes, entradas) con la lista actual del servidor
    // para que las categorías recién creadas aparezcan al abrir el modal de componente.
    function refreshComponentModalTags() {
        refreshAcordeonCategoriasDocumentosSelect();
        var app = (typeof window !== 'undefined' && window.dataapp) ? window.dataapp : ((typeof dataapp !== 'undefined') ? dataapp : null);
        var pg = (typeof window !== 'undefined' && window.pagedata) ? window.pagedata : ((typeof pagedata !== 'undefined') ? pagedata : null);
        var fk = (app && app.fk_id_sysapp_type != null) ? app.fk_id_sysapp_type : null;
        var idSysapp = (app && app.id_sysapp != null) ? app.id_sysapp : null;
        if (idSysapp == null && pg && pg.fk_id_sysapp != null) idSysapp = pg.fk_id_sysapp;
        var params = [];
        if (fk != null) params.push('fk_id_sysapp_type=' + encodeURIComponent(fk));
        if (idSysapp != null) params.push('id_sysapp=' + encodeURIComponent(idSysapp));
        function fillSelect($sel, tags, firstLabel) {
            if (!$sel.length || !tags || !tags.length) return;
            $sel.empty();
            if (firstLabel) $sel.append($('<option value="0" disabled selected>').text(firstLabel));
            tags.forEach(function(t) { $sel.append($('<option>').val(t.id_cat_tag).text(t.tag)); });
        }
        function urlTipo(tipo, todas) {
            var q = 'tipo=' + tipo;
            if (todas) q += '&incluir_todas=1';
            if (params.length) q = params.join('&') + '&' + q;
            return '/api/tags?' + q;
        }
        var urlImg = urlTipo('imagenes', params.length === 0);
        var urlEnt = urlTipo('entradas', params.length === 0);
        Promise.all([
            fetch(urlImg, { credentials: 'same-origin' }).then(function(r) { return r.json(); }),
            fetch(urlEnt, { credentials: 'same-origin' }).then(function(r) { return r.json(); })
        ]).then(function(results) {
            var rImg = results[0], rEnt = results[1];
            var $modal = $('#modalGral');
            if (rImg.success && rImg.tags) {
                fillSelect($modal.find('#tipo_tag_img'), rImg.tags, 'Seleccione un tipo de tag');
                $modal.find('.container_tag_imagenes select[name="fk_id_cat_tag"]').each(function() {
                    fillSelect($(this), rImg.tags, 'Seleccione un tipo de tag');
                });
            }
            if (rEnt.success && rEnt.tags) {
                fillSelect($modal.find('#selector_tipo_tag_entrada'), rEnt.tags, 'Seleccione un tipo de entrada');
            }
        }).catch(function() {});
    }

    // ============================================================
    // Selector de imágenes basado en módulo de imágenes (/GetImages)
    // ============================================================
    const IMAGE_SELECTOR_CONFIG = {
        token: '<%- idcypher %>',
        pageSize: 8
    };

    function buildImageSelectorBase($container) {
        if ($container.data('image-selector-initialized')) return;

        const role = $container.data('role');
        const max  = parseInt($container.data('max'), 10) || 1;
        const isTitulopag = role === 'titulopag-imagenes';

        const $header = $('<div class="image-selector-header d-flex justify-content-between align-items-center mb-2"></div>');
        const labelText = isTitulopag ? 'Selecciona imagen derecha' : (max > 1 ? 'Puedes seleccionar hasta ' + max + ' imágenes.' : 'Selecciona una imagen.');
        const $info   = $('<small class="text-muted image-selector-label"></small>').text(labelText);
        const $search = $('<input type="text" class="form-control form-control-sm" placeholder="Buscar imagen...">')
            .css('max-width', '220px');
        $header.append($info, $search);

        const $grid       = $('<div class="image-selector-grid row mt-2"></div>');
        const $pagination = $('<div class="image-selector-pagination mt-2"></div>');
        const $selected   = $('<div class="image-selector-selected mt-2"></div>');

        $container.empty().append($header, $grid, $pagination, $selected);

        const state = {
            role: role,
            max: max,
            page: 1,
            search: '',
            selected: []
        };
        if (isTitulopag) state.titulopagLabels = ['Selecciona imagen derecha', 'Selecciona imagen izquierda'];
        $container.data('image-selector-state', state);

        $search.on('input', function () {
            const val = $(this).val() || '';
            state.search = val;
            state.page = 1;
            loadImagesForSelector($container);
        });

        loadImagesForSelector($container);

        $container.data('image-selector-initialized', true);
    }

    function loadImagesForSelector($container) {
        const state = $container.data('image-selector-state');
        if (!state) return;

        const { token, pageSize } = IMAGE_SELECTOR_CONFIG;
        const page   = state.page || 1;
        const search = state.search || '';

        const $grid       = $container.find('.image-selector-grid').empty();
        const $pagination = $container.find('.image-selector-pagination').empty();

        $grid.append('<p class="text-muted">Cargando imágenes...</p>');

        var params = { i: token, page: page, limit: pageSize, search: search };
        if (typeof dataapp !== 'undefined' && dataapp && dataapp.id_sysapp != null) {
            params.idapp = dataapp.id_sysapp;
        }

        $.ajax({
            url: '/GetImages',
            method: 'GET',
            data: params
        }).done(function (data) {
            if (!data || !data.success) {
                $grid.html('<p class="text-danger">No se pudieron cargar las imágenes.</p>');
                return;
            }

            const images = data.images || [];
            const totalPages = data.totalPages || 1;
            const currentPage = data.currentPage || page;

            renderImagesGrid($container, images);
            renderImagesPagination($container, currentPage, totalPages);
        }).fail(function () {
            $grid.html('<p class="text-danger">Error al cargar las imágenes.</p>');
        });
    }

    function isImageSelectorAtMax(state) {
        if (!state) return false;
        var max = state.max != null ? state.max : 1;
        return state.selected.length >= max;
    }

    function updateImageGridCheckboxesDisabled($container) {
        const state = $container.data('image-selector-state');
        if (!state) return;
        var atMax = isImageSelectorAtMax(state);
        $container.find('.image-selector-grid .image-card').each(function () {
            var $card = $(this);
            var $check = $card.find('.form-check-input');
            var id_file = $card.data('id-file');
            var isSelected = state.selected.some(function (it) { return it.id_file === id_file; });
            if (atMax && !isSelected) {
                $check.prop('disabled', true);
                $card.addClass('image-card--disabled');
            } else {
                $check.prop('disabled', false);
                $card.removeClass('image-card--disabled');
            }
        });
    }

    function resolveImageSelectorSrc(file) {
        function normalizeMediaUrl(url) {
            var out = String(url || '');
            while (out.indexOf('/cdn/cdn/') !== -1) {
                out = out.replace(/\/cdn\/cdn\//g, '/cdn/');
            }
            return out;
        }

        const filePathRaw = file && file.file_path ? String(file.file_path) : '';
        const storagePathRaw = file && file.storageM && file.storageM.storage_path
            ? String(file.storageM.storage_path)
            : '';

        if (!filePathRaw) return '/assets/img/default_morena.png';
        if (/^https?:\/\//i.test(filePathRaw)) return normalizeMediaUrl(filePathRaw);

        const normalizedFilePath = filePathRaw.replace(/^\/+/, '');
        if (storagePathRaw) {
            return normalizeMediaUrl(storagePathRaw.replace(/\/+$/, '') + '/' + normalizedFilePath);
        }
        return normalizeMediaUrl('https://cdn.morena.app/' + normalizedFilePath);
    }

    function renderImagesGrid($container, images) {
        const state = $container.data('image-selector-state');
        const $grid = $container.find('.image-selector-grid').empty();

        if (!images.length) {
            $grid.html('<p class="text-muted">No se encontraron imágenes.</p>');
            return;
        }

        var atMax = isImageSelectorAtMax(state);

        images.forEach(function (file) {
            const id_file = file.id_file;
            const url = resolveImageSelectorSrc(file);
            const nombre = file.file_name || '';

            const alreadySelected = state.selected.some(function (it) { return it.id_file === id_file; });
            const shouldDisable = atMax && !alreadySelected;

            const $col = $('<div class="col-6 col-md-3 mb-2"></div>');
            const $card = $('<div class="image-card border rounded p-1 h-100 d-flex flex-column"></div>').data('id-file', id_file);
            const $imgWrap = $('<div class="ratio ratio-4x3 mb-1"></div>');
            const $img = $('<img class="w-100 h-100" style="object-fit: cover;">')
                .attr('src', url)
                .attr('alt', nombre);
            const $label = $('<div class="small text-truncate"></div>').text(nombre);
            const $check = $('<input type="checkbox" class="form-check-input mt-1">')
                .prop('checked', alreadySelected)
                .prop('disabled', shouldDisable);

            if (shouldDisable) $card.addClass('image-card--disabled');

            $imgWrap.append($img);
            $card.append($imgWrap, $label, $check);
            $col.append($card);
            $grid.append($col);

            $card.on('click', function (e) {
                if (e.target.tagName === 'INPUT') return;
                if ($check.prop('disabled')) return;
                $check.prop('checked', !$check.prop('checked')).trigger('change');
            });

            $check.on('change', function () {
                if ($(this).prop('disabled')) return;
                toggleImageSelection($container, { id_file: id_file, url: url, nombre: nombre }, $(this).is(':checked'));
            });
        });
    }

    function renderImagesPagination($container, currentPage, totalPages) {
        const state = $container.data('image-selector-state');
        const $pagination = $container.find('.image-selector-pagination').empty();

        if (totalPages <= 1) return;

        const $ul = $('<ul class="pagination pagination-sm mb-0"></ul>');
        const WINDOW_SIZE = 3;

        function addPage(p, label, disabled, active) {
            const $li = $('<li class="page-item"></li>');
            if (disabled) $li.addClass('disabled');
            if (active) $li.addClass('active');
            const $a = $('<a class="page-link" href="#"></a>').html(label).data('page', p);
            $li.append($a);
            $ul.append($li);
        }

        addPage(currentPage - 1, '&laquo;', currentPage === 1, false);
        var pageStart = Math.max(1, currentPage - 1);
        var pageEnd = Math.min(totalPages, pageStart + WINDOW_SIZE - 1);
        if (pageEnd - pageStart + 1 < WINDOW_SIZE) {
            pageStart = Math.max(1, pageEnd - WINDOW_SIZE + 1);
        }
        for (var p = pageStart; p <= pageEnd; p++) {
            addPage(p, p, false, p === currentPage);
        }
        addPage(currentPage + 1, '&raquo;', currentPage === totalPages, false);

        $pagination.append($ul);

        $ul.on('click', '.page-link', function (e) {
            e.preventDefault();
            const p = parseInt($(this).data('page'), 10);
            if (!p || p < 1 || p > totalPages || p === currentPage) return;
            state.page = p;
            loadImagesForSelector($container);
        });
    }

    function toggleImageSelection($container, imgData, isChecked) {
        const state = $container.data('image-selector-state');
        if (!state) return;

        const { max, role } = state;
        const multiple = role === 'slide-images';
        const titulopag = role === 'titulopag-imagenes';

        if (isChecked) {
            if (titulopag) {
                var exists = state.selected.some(function(it) { return it.id_file === imgData.id_file; });
                if (!exists) {
                    if (state.selected.length >= max) {
                        $.alert({
                            title: "Límite de imágenes",
                            content: "Solo puedes seleccionar imagen derecha e imagen izquierda.",
                            theme: 'modern',
                            type: "orange"
                        });
                        return;
                    }
                    state.selected.push(imgData);
                }
            } else if (!multiple && state.selected.length >= 1) {
                state.selected = [imgData];
            } else {
                var exists = state.selected.some(function(it) { return it.id_file === imgData.id_file; });
                if (!exists) {
                    if (state.selected.length >= max) {
                        $.alert({
                            title: "Límite de imágenes",
                            content: "Solo puedes seleccionar hasta " + max + " imagen(es).",
                            theme: 'modern',
                            type: "orange"
                        });
                        return;
                    }
                    state.selected.push(imgData);
                }
            }
        } else {
            state.selected = state.selected.filter(function(it) { return it.id_file !== imgData.id_file; });
        }

        renderSelectedImages($container);
        syncHiddenInputsForSelector($container);
        if (titulopag) updateTitulopagLabel($container);
        updateImageGridCheckboxesDisabled($container);
    }

    function renderSelectedImages($container) {
        const state = $container.data('image-selector-state');
        const $selected = $container.find('.image-selector-selected').empty();
        if (!state || !state.selected.length) {
            $selected.html('<small class="text-muted">Sin imágenes seleccionadas.</small>');
            return;
        }
        state.selected.forEach(function (it) {
            const $wrap = $('<div class="d-inline-block me-1 mb-1 border rounded position-relative" style="width:60px;height:45px;overflow:hidden;"></div>');
            const $img = $('<img class="w-100 h-100" style="object-fit:cover;">')
                .attr('src', it.url)
                .attr('alt', it.nombre || '');
            const $remove = $('<button type="button" class="btn btn-sm btn-light position-absolute" style="top:0;right:0;padding:0 4px;line-height:1;font-size:10px;">×</button>');

            $remove.on('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                const st = $container.data('image-selector-state');
                if (!st) return;
                st.selected = st.selected.filter(function(sel) { return sel.id_file !== it.id_file; });
                renderSelectedImages($container);
                syncHiddenInputsForSelector($container);
                updateImageGridCheckboxesDisabled($container);
            });

            $wrap.append($img, $remove);
            $selected.append($wrap);
        });
    }

    function syncHiddenInputsForSelector($container) {
        const state = $container.data('image-selector-state');
        if (!state) return;
        const role = state.role;
        const selected = state.selected;

        const $form = $container.closest('form');
        if (!$form.length) return;

        if (role === 'slide-images') {
            var $scope = $container.closest('.slide-item');
            if (!$scope.length) $scope = $form;
            $scope.find('input.image-id-hidden[data-role="slide-images"]').remove();
            if (!selected.length) return;
            selected.forEach(function (it) {
                $('<input type="hidden" class="image-id-hidden">')
                    .attr('data-role', role)
                    .attr('name', 'fk_id_file[]')
                    .val(it.id_file)
                    .appendTo($scope);
            });
            return;
        }

        $form.find('input.image-id-hidden[data-role="' + role + '"]').remove();
        if (!selected.length) return;

        if (role === 'titulopag-imagenes') {
            if (selected[0]) {
                $('<input type="hidden" class="image-id-hidden">')
                    .attr('data-role', role).attr('name', 'fk_id_file').val(selected[0].id_file).appendTo($form);
            }
            if (selected[1]) {
                $('<input type="hidden" class="image-id-hidden">')
                    .attr('data-role', role).attr('name', 'fk_id_file_izq').val(selected[1].id_file).appendTo($form);
            }
        } else if (role === 'comp-image-left') {
            $('<input type="hidden" class="image-id-hidden">')
                .attr('data-role', role)
                .attr('name', 'fk_id_file_izq')
                .val(selected[0].id_file)
                .appendTo($form);
        } else {
            $('<input type="hidden" class="image-id-hidden">')
                .attr('data-role', role)
                .attr('name', 'fk_id_file')
                .val(selected[0].id_file)
                .appendTo($form);
        }
    }

    function updateTitulopagLabel($container) {
