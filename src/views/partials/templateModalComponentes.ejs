                            <label class="titForm verde_t form-coleccion-fotografica__label">Tipo de tag</label>
                            <select type="text" id="tipo_tag_img" name="fk_id_cat_tag" value="" class="form-control form-basic-lleno required form-coleccion-fotografica__select">
                                <option value="0" disabled selected>Seleccione un tipo de tag</option>
                                <%
                                for (const tag of tags_imgs) {
                                %>
                                <option value="<%-tag.id_cat_tag%>"><%-tag.tag%></option>
                                <%
                                }
                                %> 
                            </select>
                        </div>
                    </div>
                </div>
                <div class="row container_tag_imagenes align-items-start form-coleccion-fotografica__row-actions">
                    <div class="coleccion_list form-coleccion-fotografica__list"></div>
                    <div class="col-lg-8 form-coleccion-fotografica__add-wrap">
                        <button type="button" class="btn btn-primary btnAddColeccion form-coleccion-fotografica__btn-add">Agregar Colección</button>
                    </div>
                </div>
            </div>
            <!-- Regeneración -->
            <div class="container_tag_regeneracion" style="display: none;">
                <div class="row">
                    <div class="col-lg-12">
                        <label class="titForm verde_t">A continuación seleccionará el año para mostrar las regeneraciones correspondientes.</label>
                    </div>
                </div>
