                    </div>
                </div>
            `);
        });

        acordeonActiveCategoryId = activeId;
        
    }

    // Refrescar datos del acordeón desde el servidor y volver a renderizar (p. ej. tras aplicar documentos)
    function acordeonRefetchAndRender() {
        var componenteId = $('#acordeonComponentId').val();
        var cy = $('.cyphval').val();
        if (!componenteId || componenteId === '0') {
            acordeonRenderTabs();
            return;
        }
        $.ajax({
            url: '/obtener-acordeon-datos',
            method: 'POST',
            data: { componenteId: componenteId, cy: cy }
        }).done(function (res) {
            if (!res.success || !res.data) {
                acordeonRenderTabs();
                return;
            }
            var acordeonData = res.data;
            var nuevasCats = [];
            if (Array.isArray(acordeonData.categorias) && acordeonData.categorias.length > 0) {
                acordeonData.categorias.forEach(function (cat) {
                    var catId = cat.id_wb_categoria_acordeon;
                    var catTitulo = (cat.cat_tag && cat.cat_tag.tag) ? cat.cat_tag.tag : (cat.descripcion || '');
                    var nuevaCat = {
                        id: catId,
                        id_wb_categoria_acordeon: catId,
                        titulo: catTitulo,
                        descripcion: cat.descripcion || '',
                        fk_id_cat_tag: cat.fk_id_cat_tag || null,
                        documentos: []
                    };
                    if (Array.isArray(cat.subcategorias) && cat.subcategorias.length > 0) {
                        cat.subcategorias.forEach(function (sub) {
                            var nuevaSub = { id: sub.id_rel_wb_subcategoria, titulo: sub.titulo || '', acordeones: [] };
                            if (Array.isArray(sub.acordeones) && sub.acordeones.length > 0) {
                                sub.acordeones.forEach(function (acc) {
                                    nuevaSub.acordeones.push({
                                        id: acc.id,
                                        titulo: acc.titulo || '',
                                        contenido: acc.texto || acc.contenido || '',
                                        url_link: acc.url_link || acc.link || null,
                                        documento: acc.documento || null
                                    });
                                });
                            }
                            nuevaCat.documentos.push(nuevaSub);
                        });
                    }
                    nuevasCats.push(nuevaCat);
                });
            }
            acordeonCategorias = nuevasCats;
            if (acordeonCategorias.length > 0 && !acordeonActiveCategoryId) {
                acordeonActiveCategoryId = acordeonCategorias[0].id;
            }
            acordeonRenderTabs();
        }).fail(function () {
            acordeonRenderTabs();
        });
    }

    // ================== Alta de elementos (categoría / subcategoría / acordeón) ==================
    function acordeonAgregarCategoria(data) {
    // data puede venir como:
    // { id, titulo }  ó  { id_wb_categoria_acordeon, descripcion }  etc.

    let rawId = null;

    if (data && typeof data === 'object') {
        if (data.id_wb_categoria_acordeon != null) {
            rawId = data.id_wb_categoria_acordeon;
        } else if (data.id != null) {
            rawId = data.id;
        }
    }

    let id = rawId != null ? parseInt(rawId, 10) : NaN;

    // Fallback por si algún día no viene el ID del servidor
    if (!id || isNaN(id) || id <= 0) {
        acordeonCategoriaCounter++;
        id = acordeonCategoriaCounter;
    }

    const titulo =
        (data && (data.titulo || data.descripcion))
            ? (data.titulo || data.descripcion)
            : `Categoría ${id}`;

    const nuevaCat = {
        id: id,                         // <- ESTE es el que usarán tus data-* en el DOM
        id_wb_categoria_acordeon: id,      // <- ID de BD para futuras peticiones (subcategorías, etc.)
        titulo: titulo,
        documentos: []                  // inicia sin subcategorías
    };

    acordeonCategorias.push(nuevaCat);
    acordeonActiveCategoryId = id;
    acordeonRenderTabs();
}


    function acordeonAgregarSubcategoria(catId, data) {
        const idNum = Number(catId);
        // Buscar por id_wb_categoria_acordeon o por id
        const cat = acordeonCategorias.find(c => 
            c.id_wb_categoria_acordeon === idNum || c.id === idNum
        );
        
        if (!cat) {
            console.error('No se encontró la categoría con ID:', idNum);
            showJConfirm('No se encontró la categoría seleccionada.');
            return;
        }

        if (!Array.isArray(cat.documentos)) cat.documentos = [];

        const index = cat.documentos.length + 1;
        cat.documentos.push({
            id: data.id,  // Usar el subcategoriaId que retorna el backend
            titulo: data.titulo || `Subcategoría ${index}`,
            acordeones: []
        });

        acordeonActiveCategoryId = cat.id;
        acordeonRenderTabs();
    }

    function acordeonAgregarAcordeon(catId, docId, data) {
        const idNum = Number(catId);
        const cat = acordeonCategorias.find(c => c.id === idNum);
        if (!cat) {
            showJConfirm('No se encontró la categoría.');
            return;
        }

        const doc = cat.documentos.find(d => String(d.id) === String(docId));
        if (!doc) {
            showJConfirm('No se encontró la subcategoría.');
            return;
        }

        if (!Array.isArray(doc.acordeones)) doc.acordeones = [];

        const index = doc.acordeones.length + 1;
        const nuevoAcc = {
            id: data.id,  // Usar el acordeonId que retorna el backend
            titulo: data.titulo || `Acordeón ${index}`,
            contenido: data.contenido || ''
        };

        doc.acordeones.push(nuevoAcc);
        acordeonActiveCategoryId = cat.id;
        acordeonRenderTabs();

        // Dejar abierta la subcategoría donde se agregó
        setTimeout(() => {
            const $panel   = $(`.acordeon-tab-panel[data-cat-panel="${cat.id}"]`);
            const $docItem = $panel.find(`.acordeon-doc-item[data-doc-id="${doc.id}"]`);
            $docItem.addClass('open');
        }, 0);
    }

    function acordeonInitForm() {
        const $form = $('#AcordeonModel_Form');
        if (!$form.length || $form.data('acordeon-init')) return;

        $form.data('acordeon-init', true);

        acordeonCategorias       = [];
        acordeonCategoriaCounter = 0;
        acordeonActiveCategoryId = null;
        acordeonCurrentCatForSub = null;
        acordeonCurrentSubForAcc = null;

        acordeonRenderTabs();
    }

    // ================== Eventos ==================
    // Cuando se abre modal general, si es el formulario del acordeón, inicializamos
    $(document).on('shown.bs.modal', '#modalGral', function () {
        if ($('#AcordeonModel_Form').length) {
