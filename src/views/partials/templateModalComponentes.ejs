        }
        
        // Ajustar z-index de backdrops
        $('.modal-backdrop').each(function() {
          const zIndex = parseInt($(this).css('z-index')) || 0;
          if (zIndex >= 1055) {
            $(this).css('z-index', '1050');
          }
        });
        
        // Asegurar que el modal y su contenido sean interactivos
        $('#modalGral').css({
          'z-index': '1055',
          'pointer-events': 'auto'
        });
        $('#modalGral .modal-dialog').css('pointer-events', 'auto');
        $('#modalGral .modal-content').css('pointer-events', 'auto');
        
        // Asegurar que el lockscreen esté completamente oculto y no interactivo
        $('#lockscreen').hide();
        $('#lockscreen').css({
          'display': 'none',
          'z-index': '1030',
          'pointer-events': 'none',
          'visibility': 'hidden'
        });
        
        // Verificar si hay algún elemento bloqueando (z-index muy alto)
        $('*').each(function() {
          const $el = $(this);
          const zIndex = parseInt($el.css('z-index')) || 0;
          // Si hay un elemento con z-index entre 1050 y 1055 que no sea el modal, ajustarlo
          if (zIndex > 1050 && zIndex < 1055 && !$el.is('#modalGral') && !$el.closest('#modalGral').length && !$el.is('.modal-backdrop')) {
            console.warn('Elemento con z-index problemático encontrado:', $el, 'z-index:', zIndex);
            $el.css('z-index', '1049');
