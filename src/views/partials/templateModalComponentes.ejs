    function NuevoContenidoCompModal(){
        let dataComp = $(this).data('tipcomp');
        let hasfile = $(this).data('hasfile');
        let tablecomp = $(this).data('tablecomp');
        let tableStr = (tablecomp != null && tablecomp !== undefined) ? String(tablecomp) : '';
        let fromTable = tableStr && NEW_COMP_TEMPLATE_BY_TABLE[tableStr];
        let result = fromTable ? { body: fromTable.body, form: fromTable.form } : {};

        let id_sec = $('#ulcomp').data('idsec');
        let id_col = $('#ulcomp').data('idcol');

        const $col = $(`.pub_columna[data-idcol="${id_col}"]`);
        const numComponentes = $col.find('.pub_componente').length;
        
        let colWidth = $('#ulcomp').data('colwidth') || 12;
        var dcCanon = (tableStr && Object.prototype.hasOwnProperty.call(TABLE_TO_CANONICAL_DATACOMP, tableStr))
            ? TABLE_TO_CANONICAL_DATACOMP[tableStr]
            : dataComp;
        let minSize = minComponentSizes[dataComp] || minComponentSizes[dcCanon] || 12;

        if (numComponentes > 0) {
            $.alert({
                title: "Columna ocupada",
                content: "Ya existe un componente en esta columna. Solo se permite uno.",
                theme: 'modern',
                icon: 'fa-solid fa-triangle-exclamation',
                type: "red"
            });
            return;
        }

        if (minSize > colWidth) {
            $.alert({
                title: "No compatible",
                content: `Este componente necesita al menos ${minSize} columnas, pero la columna seleccionada tiene ${colWidth}.`,
                theme: 'modern',
                icon: 'fa-solid fa-triangle-exclamation',
                type: "red"
            });
            return;
        }

        if (!result.body) {
        switch(dataComp){
            case 1:  { result = { body: 'CompTextImgModelTemplate', form: 'CompTextImgModel_Form' }; break; }
            case 2:  { result = { body: 'CompTextoModelTemplate',   form: 'CompTextoModel_Form'   }; break; }
            case 3:  { result = { body: 'CompTextoModelTemplate',   form: 'CompTextoModel_Form'   }; break; }
            case 4:  { result = { body: 'CompTextoModelTemplate',   form: 'CompTextoModel_Form'   }; break; }
            case 5:  { result = { body: 'CompSlidesModelTemplate',  form: 'CompSlidesModel_Form'  }; break; }
            case 7:  { result = { body: 'CompTextImgModelTemplate', form: 'CompTextImgModel_Form' }; break; }
            case 8:  { result = { body: 'CompTagModalTemplate',     form: 'CompTagModal_Form'     }; break; }
            case 9:  { result = { body: 'AcordeonModelTemplate',     form: 'AcordeonModel_Form'     }; break; }
            case 10: { result = { body: 'CompSlidesModelTemplate',  form: 'CompSlidesModel_Form'  }; break; }
            case 13: { result = { body: 'CompTextImgModelTemplate', form: 'CompTextImgModel_Form' }; break; }
            case 14: { result = { body: 'CompSlidesModelTemplate',  form: 'CompSlidesModel_Form'  }; break; }
            case 16: { result = { body: 'RedesModelTemplate',       form: 'RedesModel_Form'       }; break; }
            case 17: { result = { body: 'CompTagModalTemplate',     form: 'CompTagModal_Form'     }; break; }
            case 20: { result = { body: 'ImagenModelTemplate',      form: 'ImagenModel_Form'      }; break; }
            case 21: { result = { body: 'CompTextImgModelTemplate', form: 'CompTextImgModel_Form' }; break; }
            case 23: { result = { body: 'CompTextImgModelTemplate', form: 'CompTextImgModel_Form' }; break; }
            case 24: { result = { body: 'CompTagModalTemplate',     form: 'CompTagModal_Form'     }; break; }
        }
        }

        if (!result.body || !result.form) {
            $.alert({
                title: 'Componente no configurado',
                content: 'El tipo de componente seleccionado no tiene formulario asociado.',
                theme: 'modern',
                icon: 'fa-solid fa-triangle-exclamation',
                type: 'red'
            });
