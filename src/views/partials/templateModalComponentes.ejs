    function validateImageSelectionForForm($form, opts) {
        opts = opts || {};
        var tableComp = opts.tableComp;
        var isSlideForm = opts.isSlideForm;
        var tablecompSlide = opts.tablecomp_slide;
        // Solo el carrusel puede tener hasta 4 imágenes; galería, línea del tiempo y demás solo 1
        var isCarouselSlide = tablecompSlide === 'wb_comp_slides_carrousel';
        if (isSlideForm) {
            var ids = $form.find('input[name="fk_id_file[]"]').map(function() { return $(this).val(); }).get().filter(Boolean);
            if (ids.length < 1) return isCarouselSlide ? 'Cada slide debe tener entre 1 y 4 imágenes seleccionadas.' : 'Debes seleccionar una imagen para este slide.';
            if (isCarouselSlide) {
                if (ids.length > 4) return 'Cada slide puede tener como máximo 4 imágenes.';
            } else {
                if (ids.length > 1) return 'Este componente solo permite una imagen por slide.';
            }
            return null;
        }
        if (tableComp === 'wb_comp_titulopag') {
            var derecha = $form.find('input[name="fk_id_file"]').val();
            if (!derecha || !derecha.trim()) return 'Selecciona al menos la imagen derecha.';
            return null;
        }
        if (opts.requiresImage) {
            var id = $form.find('input[name="fk_id_file"]').val();
            if (!id || !String(id).trim()) return 'Debes seleccionar al menos una imagen.';
            return null;
        }
        return null;
    }

