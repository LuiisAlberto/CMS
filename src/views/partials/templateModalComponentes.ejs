    function agregarSubcategoria(){
        const titulo = ($('.acordeon-tab-panel.is-active .acordeon-input-titulo-item').val() || '').trim();
        const acordeonId = $('#acordeonComponentId').val();
        const cypherval = $('.cyphval').val();
