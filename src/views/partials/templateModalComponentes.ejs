// ===================== Editor de texto enriquecido (Summernote) para componente Texto ===================== //
function initEditorTexto($form){
  var $ta = $form.find('textarea[name="texto"]');
  if (!$ta.length || !$.fn.summernote) return;
  if ($ta.data('summernote')) return; // ya inicializado
  $ta.summernote({
    height: 180,
    toolbar: [
      ['style', ['bold', 'italic', 'underline', 'clear']],
      ['color', ['color']],
      ['para', ['ul', 'ol', 'paragraph']],
      ['insert', ['link']]
    ]
  });
}
function destroyEditorTexto($form){
  var $ta = $form.find('textarea[name="texto"]');
  if ($ta.length && $ta.data('summernote')) {
    $ta.summernote('destroy');
  }
}
function getEditorTextoValue($form){
  var $ta = $form.find('textarea[name="texto"]');
  if ($ta.length && $ta.data('summernote')) {
    return $ta.summernote('code');
  }
  return $ta.val() || '';
}

// ===================== Reglas dinámicas (UI por tipo) — sin slides ===================== //
function reglasFormDinamicos(dataComp, result, tablecomp){
  setTimeout(()=>{
    const $form = $('#' + result.form);
    const table = (tablecomp || '').toString();

    // Forzar comportamiento correcto del modal de noticias aunque el ID interno cambie por ambiente.
    if (table === 'wb_comp_noticias') {
      ocultar(['.container_tag_imagenes', '.container_tag_regeneracion', '.general_textimg', '.col-url-text', '.secButton', '.inputVideoDate', '.inputCoo']);
      expandir(['.container_tag_entradas']);
      return;
    }
    // Mismo criterio: id_cat_wb_componente puede no ser 17 en BD; las reglas por número fallan y se expande .general_textimg por error.
    if (table === 'wb_comp_cards_regeneracion') {
      ocultar(['.container_tag_entradas', '.container_tag_imagenes', '.general_textimg', '.container_regeneracion', '.col-url-text', '.secButton', '.inputVideoDate', '.inputCoo']);
      expandir(['.container_tag_regeneracion']);
      return;
    }
    if (table === 'wb_comp_coleccion_fotografica') {
      ocultar(['.container_tag_entradas', '#selector_tipo_tag_entrada', '#selector_type_tag', '.container_tag_regeneracion', '.general_textimg', '.container_regeneracion', '.col-url-text', '.secButton', '.inputVideoDate', '.inputCoo']);
      expandir(['.container_tag_imagenes']);
      return;
    }

    const reglas = {
      1:  () => { 
        ocultar(['.inputUrl','.title_comp', '.imgs_slides--not-titulopag', '.campos_color_acento']); 
        expandir(['.col_text_comptextimg', '.campos_titulo_principal']); 
      },
      2:  () => { destroyEditorTexto($form); },
      3:  () => {
        ocultar(['.col-url-text']);
        $form.find('textarea[name="texto"]').removeAttr('rows').removeClass('textarea-boton');
        initEditorTexto($form);
      },
      4:  () => {
        destroyEditorTexto($form);
        $form.find('textarea[name="texto"]').attr('rows',2).addClass('textarea-boton');
      },
      5:  () => {
        ocultar(['.anio_comp_linea']);
        expandir(['.text_btn_slides', '.url_link_slides']);
        if (table === 'wb_comp_carrousel') {
          expandir(['.campos_color_carrusel_estatal']);
        } else {
          ocultar(['.campos_color_carrusel_estatal']);
        }
      },
      7:  () => { ocultar(['.campos_titulo_principal']); expandir(['.title_comp','.col_text_comptextimg','.inputUrl', '.campos_color_acento']); },
      8:  () => {
        ocultar(['.container_tag_imagenes','#selector_tipo_tag_img','#selector_type_tag', '.container_tag_regeneracion', '.general_textimg']);
        expandir(['.container_tag_entradas']);
      },
      10: () => { ocultar(['.anio_comp_linea', '.text_btn_slides', '.url_link_slides', '.campos_color_carrusel_estatal']); },
      13: () => { expandir(['.title_comp','.inputUrl']); ocultar(['.col_text_comptextimg', '.campos_color_acento']); },
      14: () => { ocultar(['.text_btn_slides', '.url_link_slides', '.campos_color_carrusel_estatal']); expandir(['.anio_comp_linea']); },
      17: () => {  expandir(['.container_tag_regeneracion']); ocultar(['.general_textimg', '.container_tag_entradas', '.container_tag_imagenes', '.campos_color_acento']); validarAnioRegeneracion($form.find('input[name="year_regeneracion"]')); },
      21: () => {
        ocultar(['.inputUrl', '.campos_titulo_principal']);
        expandir(['.col_text_comptextimg','.title_comp', '.campos_color_acento']);
        $('#labeltitle').replaceWith('<p>Nombre completo</p>');
        $('#labeltext').replaceWith('<p>Puesto</p>');
      },
      23: () => { expandir(['.title_comp','.inputUrl']); ocultar(['.col_text_comptextimg', '.campos_color_acento']); },
      24: () => {
        ocultar(['.container_tag_entradas','#selector_tipo_tag_entrada','#selector_type_tag', '.container_tag_regeneracion', '.general_textimg']);
        expandir(['.container_tag_imagenes']);
      }
    };

    const dcNum = parseInt(dataComp, 10);
    const reglaFn = (reglas[dataComp] != null) ? reglas[dataComp] : (!Number.isNaN(dcNum) ? reglas[dcNum] : null);
    if (reglaFn) reglaFn();

    // Reglas globales
    const esNoticias = (table === 'wb_comp_noticias') || (dcNum === 8);
    if (dcNum !== 4)  ocultar(['.col-url-text','.secButton']);
    if (dcNum !== 12) ocultar(['.inputCoo']);
    const esModalSoloTag = [8, 17, 24].includes(dcNum)
      || table === 'wb_comp_noticias'
      || table === 'wb_comp_cards_regeneracion'
      || table === 'wb_comp_coleccion_fotografica';
    if (!esNoticias && !esModalSoloTag) {
      expandir(['.general_textimg']);
      ocultar(['.container_regeneracion']);
    } else {
      ocultar(['.general_textimg', '.container_regeneracion']);
    }
    if (dcNum !== 23) ocultar(['.inputVideoDate']);
  }, 200);
}

// ===================== Bind de envío solo-cambios ===================== //
function bindDynamicFormSubmit($form, comp, tipo, tablecomp, initialData){
  $form.off('submit').on('submit', async function(e){
    e.preventDefault();

    finalizeAcentoColorsForSubmit();

    if (tipo === 3) {
      var $ta = $form.find('textarea[name="texto"]');
      if ($ta.data('summernote')) $ta.val(getEditorTextoValue($form));
    }

    const formData   = new FormData();
    const datosForm  = [];
    const datosExtras = {
      id_comp: comp.id,
      tipo,
      cy: $('.cyphval').val(),
      idpag: "<%- datapagina.id_wb_pagina %>",
      tablecomp,
      idapp: '<%=dataapp.id_sysapp%>'
    };

    const alwaysSubmitNames = ['color_acento', 'color_filtro'];
    $form.find('input, select, textarea').each(function(){
      const $el = $(this);
      const name = $el.attr('name');
      if (!name || $el.is(':disabled')) return;
      // No procesar aquí los array fk_id_file[] (se tratan en bloque después)
      if (name === 'fk_id_file[]') return;
      // Incluir siempre inputs hidden (ej. fk_id_file del selector de imágenes); en jQuery :visible es false para hidden
      // color_acento / color_filtro pueden estar en filas aún ocultas por reglas CSS; deben enviarse al editar igual
      if (alwaysSubmitNames.indexOf(name) === -1 && !$el.is(':visible') && $el.attr('type') !== 'hidden') return;

      const currentVal = $el.val();
      const prevVal = Object.prototype.hasOwnProperty.call(initialData, name)
        ? (initialData[name] == null ? '' : String(initialData[name]))
        : undefined;

      if (prevVal === undefined || String(currentVal) !== prevVal){
        datosForm.push({ [name]: currentVal });
        formData.append(name, currentVal);
      }
    });
    // fk_id_file[]: comparar todos los IDs como conjunto
    const $arrFiles = $form.find('input[name="fk_id_file[]"]');
    if ($arrFiles.length) {
      const currentIds = $arrFiles.map(function() { return $(this).val(); }).get().filter(Boolean);
      const prevStr = initialData['fk_id_file[]'] != null ? String(initialData['fk_id_file[]']) : '';
      const prevIds = prevStr ? prevStr.split(',').map(function(s){ return s.trim(); }).filter(Boolean) : [];
      const same = currentIds.length === prevIds.length && currentIds.every(function(id, i) { return id === prevIds[i]; });
      if (!same) {
        datosForm.push({ 'fk_id_file[]': currentIds });
        currentIds.forEach(function(id) { formData.append('fk_id_file[]', id); });
      }
    }

    if (tipo === 3) {
      var txtVal = getEditorTextoValue($form);
      formData.append('texto', txtVal);
      var prevTxt = initialData && initialData.texto != null ? String(initialData.texto) : undefined;
      if (prevTxt === undefined || String(txtVal) !== prevTxt) {
        datosForm.push({ texto: txtVal });
      }
    }

    // --- NUEVO: payload específico para tipo 24 (colecciones) ---
    let coleccionesPayload = [];
    if (tipo === 24) {
      coleccionesPayload = buildColeccionesPayload24($form);
    }

    if (datosForm.length === 0 && coleccionesPayload.length === 0){
      $.alert({
        title:'Sin cambios',
        content:'No detecté modificaciones para guardar.',
        type:'blue'
      });
      return;
    }

    formData.append('datosExtras', JSON.stringify(datosExtras));
    formData.append('datosForm',   JSON.stringify(datosForm));

    // Solo en tipo 24 mandamos el detalle extra justo debajo de datosForm
    if (tipo === 24 && coleccionesPayload.length > 0) {
      formData.append('datosColecciones', JSON.stringify(coleccionesPayload));
    }

    try{
      await enviarFormDataDinamico('/updateComponentData', formData);
    }catch(err){
      console.error('❌ Error al enviar FormData dinámico:', err);
      $.alert({ title:'Error', content:'No se pudo actualizar el componente.', type:'red' });
    }
  });
}

async function enviarFormDataDinamico(url, formData) {
    try {
        $('#lockscreen').show();

        const response = await $.ajax({
            url,
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            xhr: function () {
                const xhr = $.ajaxSettings.xhr();
                if (xhr.upload) {
                    xhr.upload.addEventListener('progress', e => {
                        if (e.lengthComputable) {
                        const percent = (e.loaded / e.total) * 100;
                        }
                    });
                }
                return xhr;
            }
        });

        $('#lockscreen').hide();
        $.alert({
            title: 'Éxito',
            content: 'Los datos se han actualizado correctamente.',
            type: 'green',
            onClose: function () {
                window.location.reload();
            }
        });
    } catch (error) {
        $('#lockscreen').hide();
        $.alert({
            title: 'Error',
            content: 'No se pudo enviar la información al servidor.',
            type: 'red'
        });
    }
}

