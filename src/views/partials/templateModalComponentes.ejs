// Convierte un File a base64 (solo la parte base64, sin "data:...")
function fileToBase64(file) {
    return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = e => {
            const full = e.target.result || '';
            const idx = full.indexOf(',');
            resolve(idx >= 0 ? full.substring(idx + 1) : full);
        };
        reader.onerror = reject;
        reader.readAsDataURL(file);
    });
}

function buildColeccionesPayload24($form) {
  if (!Array.isArray(colecciones24Initial)) return [];

  const cambios   = [];
  const presentes = new Set();

  // Recorremos todas las colecciones que actualmente existen en el formulario
  $form.find('.tagimg-form').each(function () {
      const $coleccion = $(this);
      const rawId = $coleccion.data('coleccion-id');
      const coleccionId = rawId != null ? Number(rawId) : null;
      if (coleccionId == null || Number.isNaN(coleccionId)) return;

      presentes.add(coleccionId);

      const $select = $coleccion.find('select[name="fk_id_cat_tag"]');
      if (!$select.length) return;

      const currentVal = String($select.val() || '');
      const inicial = colecciones24Initial.find(c => c.coleccionId === coleccionId);

      // Colección nueva (no estaba al inicio)
      if (!inicial) {
          if (currentVal) {
              cambios.push({
                  accion: 'guardado',          // NUEVO registro
                  coleccionId,
                  fk_id_cat_tag: currentVal
              });
          }
          return;
      }

      // Colección que ya existía: vemos si cambió el tag
      const oldVal = String(inicial.fk_id_cat_tag || '');
      if (oldVal !== currentVal) {
          cambios.push({
              accion: 'modificacion',
              coleccionId,
              fk_id_cat_tag: currentVal,
              cambio: {
                  antes: oldVal,
                  nuevo: currentVal
              }
          });
      }
  });

  // Cualquier colección inicial que ya no esté presente se considera eliminada
  colecciones24Initial.forEach(inicial => {
      if (!presentes.has(inicial.coleccionId)) {
          const oldVal = String(inicial.fk_id_cat_tag || '');
          cambios.push({
              accion: 'eliminacion',
              coleccionId: inicial.coleccionId,
              fk_id_cat_tag: oldVal,
              cambio: {
                  antes: oldVal,
                  nuevo: null
              }
          });
      }
  });

  return cambios;
}

</script>
<script>
    // ================== Estado local del acordeón (sin JSONs de prueba) ==================
    let acordeonCategorias = [];
    let acordeonCategoriaCounter = 0;
    let acordeonActiveCategoryId = null;
    let acordeonCurrentCatForSub = null;   // categoría para crear subcategoría
    let acordeonCurrentSubForAcc = null;   // { catId, docId } para crear acordeón interno

    // ================== Utilidades ==================
    function acordeonEscapeHtml(str) {
        if (str == null) return '';
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    // Hidratar estado desde el servidor (edición)
    async function acordeonHydrateFromServer(componenteId) {
        const cypherval = $('.cyphval').val();
        if (!componenteId || componenteId === '0' || !cypherval) return false;

        const res = await $.ajax({
            url: '/obtener-acordeon-datos',
            method: 'POST',
            data: { componenteId: componenteId, cy: cypherval }
        });

        if (!res || !res.success || !res.data) return false;

        const acordeonData = res.data;

        // Llenar campos principales del contenedor
        $('#acordeonId').val(acordeonData.id_wb_contenedor_acordeon || 0);
        $('#acordeonComponentId').val(componenteId);
        $('#acordeonContenedorId').val(acordeonData.id_wb_contenedor_acordeon || 0);
        $('#acordeonTitulo').val(acordeonData.titulo || '');
        $('#acordeonDescripcion').val(acordeonData.descripcion || '');

        // Reconstruir el estado global de categorías
        acordeonCategorias = [];
        acordeonCategoriaCounter = 0;
        acordeonActiveCategoryId = null;

        if (Array.isArray(acordeonData.categorias) && acordeonData.categorias.length > 0) {
            acordeonData.categorias.forEach(cat => {
                const catId = cat.id_wb_categoria_acordeon || cat.id || 0;
                if (catId > acordeonCategoriaCounter) acordeonCategoriaCounter = catId;

                const catTitulo = (cat.cat_tag && cat.cat_tag.tag)
                    ? cat.cat_tag.tag
                    : (cat.descripcion || '');

                const nuevaCat = {
                    id: catId,
                    id_wb_categoria_acordeon: catId,
                    titulo: catTitulo,
                    descripcion: cat.descripcion || '',
                    fk_id_cat_tag: cat.fk_id_cat_tag || null,
                    documentos: []
                };

                if (Array.isArray(cat.subcategorias) && cat.subcategorias.length > 0) {
                    cat.subcategorias.forEach(sub => {
                        const nuevaSub = {
                            id: sub.id_rel_wb_subcategoria,
                            titulo: sub.titulo || '',
                            acordeones: []
                        };
                        if (Array.isArray(sub.acordeones) && sub.acordeones.length > 0) {
                            sub.acordeones.forEach(acc => {
                                nuevaSub.acordeones.push({
                                    id: acc.id,
                                    titulo: acc.titulo || '',
                                    contenido: acc.texto || acc.contenido || '',
                                    url_link: acc.url_link || acc.link || null,
                                    documento: acc.documento || null
                                });
                            });
                        }
                        nuevaCat.documentos.push(nuevaSub);
                    });
                }

                acordeonCategorias.push(nuevaCat);
            });

            acordeonActiveCategoryId = acordeonCategorias[0]?.id || null;
        }

        acordeonRenderTabs();
        return true;
    }

    // Render de tabs y contenido de categorías/subcategorías/acordeones
    function acordeonRenderTabs() {
        const $tabs    = $('#acordeonTabs');
        const $content = $('#acordeonTabsContent');

        if (!$tabs.length || !$content.length) {
            console.error('❌ No se encontraron los contenedores necesarios');
            return;
        }

        $tabs.empty();
        $content.empty();

        // Sin categorías
        if (acordeonCategorias.length === 0) {
            acordeonActiveCategoryId = null;
            $content.html(`
                <div class="p-5 text-center" style="background: #faf8f5; border-radius: 12px; border: 2px dashed #e0d5c4;">
                    <i class="fa-solid fa-layer-group mb-3" style="font-size: 48px; opacity: 0.35; color: #9F1F41;"></i>
                    <h5 class="mb-2" style="color: #9F1F41;">No hay categorías registradas</h5>
                    <h5 class="mb-0" style="color: #5d4e37;">En este apartado se van a visualizar las Categorías con las Subcategorías y acordeones correspondientes.</h5>
                    <p class="mb-0" style="color: #5d4e37;">Para generar nuevos registros ingresa un nombre en el campo "Nueva Categoría" y presiona [+] para <strong>"Guardar categoría"</strong>.</p>
                </div>
            `);
            return;
        }

        // Categoría activa
        let activeId = acordeonActiveCategoryId;
        if (!activeId || !acordeonCategorias.some(c => c.id === activeId)) {
            activeId = acordeonCategorias[0].id;
        }

        acordeonCategorias.forEach(cat => {
            const isActive  = cat.id === activeId;
            const safeTitle = acordeonEscapeHtml(cat.titulo || 'Sin título');
            const docs      = Array.isArray(cat.documentos) ? cat.documentos : [];

            docs.forEach(doc => {
                console.log(`   📄 Subcategoría ${doc.id}: ${doc.titulo} - ${doc.acordeones?.length || 0} acordeones`);
            });

            // Botón de tab (categoría)
            $tabs.append(`
                <button 
                    type="button"
                    class="acordeon-tab-btn ${isActive ? 'is-active' : ''}"
                    data-cat-id="${cat.id_wb_categoria_acordeon || cat.id}">
                    <span>${safeTitle}</span>
                    <span class="btn-delete-categoria" 
                          data-cat-id="${cat.id_wb_categoria_acordeon || cat.id}"
                          onclick="eliminarElementoAcordeon('categoria', ${cat.id_wb_categoria_acordeon || cat.id}, event)">
                        <i class="fa-solid fa-times"></i>
                    </span>
                </button>
            `);

            // Subcategorías / documentos
            const docsHtml = docs.length
                ? docs.map((doc, docIdx) => {
                    
                    const acordeones = Array.isArray(doc.acordeones) ? doc.acordeones : [];
                    const acordeonesHtml = acordeones.length
                        ? acordeones.map(acc => {
                            const isDocLink = acc.url_link && (acc.documento && acc.documento.nombre || acc.titulo);
                            const linkText = (acc.documento && acc.documento.nombre) ? acc.documento.nombre : (acc.titulo || 'Documento');
                            const linkHref = (acc.url_link || '').replace(/"/g, '&quot;');
                            return `
                            <div class="acordeon-inner-item" data-acc-id="${acordeonEscapeHtml(acc.id)}">
                                <span class="btn-delete-acordeon" 
                                      data-acc-id="${acordeonEscapeHtml(acc.id)}"
                                      onclick="eliminarElementoAcordeon('acordeon', ${acordeonEscapeHtml(acc.id)}, event)">
                                    <i class="fa-solid fa-times"></i>
                                </span>
                                ${isDocLink
                                    ? `<div class="acordeon-inner-doc-link"><a href="${linkHref}" target="_blank" rel="noopener noreferrer" class="acordeon-doc-link-tag">${acordeonEscapeHtml(linkText)}</a></div>`
                                    : `<div class="acordeon-inner-title">${acordeonEscapeHtml(acc.titulo)}</div><div class="acordeon-inner-body">${acordeonEscapeHtml(acc.contenido || '')}</div>`
                                }
