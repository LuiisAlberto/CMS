            return;
        }
        if (!catId) {
            showJConfirm('No se pudo identificar la categoría.');
            return;
        }

        fetch('/agregar-subcategoria-acordeon', {
            method: 'POST',
            body: JSON.stringify({
                titulo: titulo,
                acordeonId: acordeonId,
                categoriaId: catId,
                i: cypherval,
                pagina: <%= typeof datapagina !== 'undefined' ? datapagina.id_wb_pagina : '""' %>,
                contenedorId: $('#acordeonContenedorId').val()
            }),
            headers: { 'Content-Type': 'application/json' }
        })
        .then(res => res.json())
        .then(data => {
            if (!data.success) {
                showJConfirm(data.message || 'No se pudo agregar el ítem.');
