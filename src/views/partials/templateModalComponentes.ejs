    // Limpia marcas previas de validación
    function clearValidation($form, invalidClass = 'is-invalid') {
        $form.find('.' + invalidClass).removeClass(invalidClass).removeAttr('aria-invalid');
    }

    // Valida campos requeridos por name (strings del array requiredFields)
    function validateForm($form, requiredFields = [], opts = {}) {
        const invalidClass = opts.invalidClass || 'is-invalid';
        const focusFirst   = opts.focusFirst   !== false; // por default sí enfoca
        const treatZeroAsEmpty = opts.treatZeroAsEmpty !== false; // '0' cuenta como vacío

        let isValid = true;
        const camposFaltantes = [];
        let $firstInvalid = null;

        clearValidation($form, invalidClass);

        const markInvalid = ($el, labelText) => {
            if (!$el || !$el.length) return;
            $el.addClass(invalidClass).attr('aria-invalid', 'true');
            $el.one('input change', function () {
                $(this).removeClass(invalidClass).removeAttr('aria-invalid');
            });
            if (!$firstInvalid) $firstInvalid = $el;
            if (labelText && !camposFaltantes.includes(labelText)) {
                camposFaltantes.push(labelText);
            }
        };

        const getLabelFor = ($field) => {
            const id = $field.attr('id');
            if (id) {
                const $byFor = $form.find(`label[for="${id}"]`).first();
                if ($byFor.length) return $.trim($byFor.text());
            }
            const $near = $field.closest('.ma-g, .form-group, .form-item, .row').find('label').first();
            if ($near.length) return $.trim($near.text());
            return $field.attr('name') || 'campo';
        };

        for (const name of requiredFields) {
            let $inputs = $form.find(`[name="${name}"]`);
            if (!$inputs.length) {
                continue;
            }

            $inputs = $inputs.filter(':enabled').filter(function () {
                const $el = $(this);
                return $el.is(':visible') && $el.parents().filter(function(){ return $(this).css('display')==='none'; }).length === 0;
            });

            if (!$inputs.length) continue;

            const type = ($inputs.first().attr('type') || '').toLowerCase();
            const tag  = ($inputs.first()[0]?.tagName || '').toLowerCase();

            if (type === 'radio') {
                if ($inputs.filter(':checked').length === 0) {
                    markInvalid($inputs.first(), getLabelFor($inputs.first()));
                    isValid = false;
                }
                continue;
            }

            if (type === 'checkbox') {
                if ($inputs.filter(':checked').length === 0) {
                    markInvalid($inputs.first(), getLabelFor($inputs.first()));
                    isValid = false;
                }
                continue;
            }

            if (type === 'file') {
                const anyFile = Array.from($inputs).some(inp => inp.files && inp.files.length > 0);
                if (!anyFile) {
                    markInvalid($inputs.first(), getLabelFor($inputs.first()));
                    isValid = false;
                }
                continue;
            }

            const $field = $inputs.first();
            const valRaw = (tag === 'select') ? $field.val() : ($field.val() || '');
            const val = typeof valRaw === 'string' ? valRaw.trim() : valRaw;

            const isEmpty = val === '' || val === null || (treatZeroAsEmpty && (val === '0' || val === 0));

            if (isEmpty) {
                markInvalid($field, getLabelFor($field));
                isValid = false;
            }
        }

        if (focusFirst && $firstInvalid && $firstInvalid.length) {
            try { $firstInvalid[0].scrollIntoView({ behavior: 'smooth', block: 'center' }); } catch {}
            $firstInvalid.focus();
        }
        return { isValid, camposFaltantes };
    }

