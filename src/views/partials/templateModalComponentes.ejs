            $(this).text(m > 1 ? ('Puedes seleccionar hasta ' + m + ' imágenes desde el módulo de imágenes.') : 'Selecciona una imagen desde el módulo de imágenes.');
        });
    }

    function setImageSelectorSelected($container, selectedItems) {
        if (!$container || !$container.length) return;
        var state = $container.data('image-selector-state');
        if (!state) return;
        state.selected = Array.isArray(selectedItems) ? selectedItems : [];
        renderSelectedImages($container);
        syncHiddenInputsForSelector($container);
        if (state.role === 'titulopag-imagenes') updateTitulopagLabel($container);
        updateImageGridCheckboxesDisabled($container);
