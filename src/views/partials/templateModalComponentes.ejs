<!-- tag -->
<template id="CompTagModalTemplate">
    <form id="CompTagModal_Form" class="limit-form row">
        <input type="hidden" class="cyphval" value="<%-idcypher%>">
        <input type="hidden" class="comp" id="CompTagId" value="0">

        <div class="tagform-item">
            <!-- Entradas -->
            <div class="container_tag_entradas">
                <div class="row">
                    <div class="col-lg-12">
                        <label class="titForm verde_t">A continuación registrará el tipo de entrada que traerá toda la información que le corresponda.</label>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-lg-12 mt-1">
                        <!-- Tag entrada -->
                        <div id="tagentrada">
                            <label class="titForm verde_t">Tipo de tag</label>
                            <select type="text" id="selector_tipo_tag_entrada" name="fk_id_cat_tag" value="" class="form-control form-basic-lleno required">
                                <option value="0" disabled selected>Seleccione un tipo de entrada</option>
                                <%
                                for (const tag of tags ) {
                                %>
                                <option value="<%-tag.id_cat_tag%>"><%-tag.tag%></option>
                                <%
                                }
                                %> 
                            </select>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Imágenes (Colección fotográfica) -->
