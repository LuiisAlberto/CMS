        <footer class="footerMorena" id="footer-container">
                <div class="contFooter row">
                    <!-- El footer se cargará dinámicamente aquí -->
                    <div class="col-12 text-center">
                        <p>Cargando pie de página...</p>
                    </div>
                </div>
        </footer>
        </main>
            <script>
                <!--let tipo_p='<% //datapagina.fk_id_cat_type_pagina%>';-->
                let tipo_p='1';
                if(tipo_p==='1') {
                    $('#lockscreen').show();
                    setTimeout(() => {
                        $('#lockscreen').css('opacity',0);
                        setTimeout(() => {
                            $('#lockscreen').hide();
                        }, 1000);
                    }, 1000);
                }
                $(document).ready(function () {
                    obtenerFooter();
                });

                async function obtenerFooter(){
                    const pathname = (new URL(window.location.href)).pathname;
                    const host = window.location.host;
                    
                    // Intentar obtener el id_sysapp desde una variable global o meta tag
                    let appId = null;
                    try {
                        const metaAppId = document.querySelector('meta[name="app-id"]');
                        if (metaAppId) {
                            appId = metaAppId.getAttribute('content');
                        }
                        if (!appId && typeof window.appId !== 'undefined') {
                            appId = window.appId;
                        }
                    } catch(e) {
                        // console.log('No se pudo obtener appId desde meta/variable global');
                    }
                    
                    fetch('/footer-data', {
                        method: 'POST',
                        body: JSON.stringify({
                            pathname: pathname,
                            host: host,
                            appId: appId,
                            i: new URLSearchParams(window.location.search).get('i') || null,
                            detalle: new URLSearchParams(window.location.search).get('d') || null,
                            tags: new URLSearchParams(window.location.search).get('v')|| null
                        }),
                        headers: { 'Content-Type': 'application/json' }
                    })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error(`Error HTTP: ${response.status}`);
                        }
                        return response.json();
                    })
                    .then(data => {
                        if(data.success && data.data){
                            renderizarFooter(data.data);
                        } else {
                            // Si no hay footer configurado, mostrar footer vacío
                            renderizarFooterVacio();
                        }
                    })
                    .catch((error) => {
                        console.error('Error al obtener footer:', error);
                        renderizarFooterVacio();
                    });
                }

                // Función para escapar HTML y prevenir XSS
                function escapeHtml(text) {
                    if (!text) return '';
                    const map = {
                        '&': '&amp;',
                        '<': '&lt;',
                        '>': '&gt;',
                        '"': '&quot;',
                        "'": '&#039;'
                    };
                    return text.toString().replace(/[&<>"']/g, m => map[m]);
                }

                // Función para escapar URL
                function escapeUrl(url) {
                    if (!url) return '#';
                    try {
                        // Validar que sea una URL válida o ruta relativa
                        if (url.startsWith('http://') || url.startsWith('https://') || url.startsWith('/') || url.startsWith('#')) {
                            return escapeHtml(url);
                        }
                        return '#';
                    } catch(e) {
                        return '#';
                    }
                }

                function renderizarFooter(footerData) {
                    const footerContainer = document.querySelector('.contFooter');
                    if (!footerContainer) return;

                    let html = '';

                    // Verificar qué secciones tienen contenido
                    const tieneLogo = footerData.url_logo && footerData.url_logo.trim() !== '';
                    const tieneSuscripcion = footerData.texto_suscripcion && footerData.texto_suscripcion.trim() !== '';
                    const tieneEnlaces = footerData.enlaces_por_categoria && Object.keys(footerData.enlaces_por_categoria).length > 0;
                    const tieneContacto = (footerData.direccion_contacto && footerData.direccion_contacto.trim() !== '') ||
                                         (footerData.telefono_contacto && footerData.telefono_contacto.trim() !== '') ||
                                         (footerData.email_contacto && footerData.email_contacto.trim() !== '');

                    // Calcular número de columnas para ajustar el tamaño
                    let numColumnas = 0;
                    if (tieneLogo || tieneSuscripcion) numColumnas++;
                    if (tieneEnlaces) numColumnas++;
                    if (tieneContacto) numColumnas++;

                    // Determinar tamaño de columna según número de secciones
                    let colSize = 'col-lg-4 col-md-4';
                    if (numColumnas === 1) {
                        colSize = 'col-lg-12 col-md-12';
                    } else if (numColumnas === 2) {
                        colSize = 'col-lg-6 col-md-6';
                    }

                    // Columna 1: Logo y Suscripción (solo si hay contenido)
                    if (tieneLogo || tieneSuscripcion) {
                        html += `<div class="${colSize} col-sm-12">`;
                        
                        if (tieneLogo) {
                            html += `<img src="${escapeUrl(footerData.url_logo)}" alt="Logo MORENA">`;
                        }
                        
                        if (tieneSuscripcion) {
                            html += '<h1 class="titFooter mt-2">Suscríbete</h1>';
                            html += `<p class="mt-2">${escapeHtml(footerData.texto_suscripcion).replace(/\n/g, '<br>')}</p>`;
                            // Formulario de suscripción comentado
                            // html += `
                            //     <form class="subscription-form mt-3">
                            //         <input type="email" placeholder="Tu correo electrónico" required="">
                            //         <button type="submit">Suscribirse</button>
                            //     </form>
                            // `;
                        }
                        
                        html += '</div>';
                    }

                    // Columna 2: Enlaces de Interés (solo si hay enlaces)
                    if (tieneEnlaces) {
                        html += `<div class="${colSize} col-sm-12">`;
                        
                        Object.keys(footerData.enlaces_por_categoria).forEach(categoria => {
                            const enlacesCategoria = footerData.enlaces_por_categoria[categoria];
                            if (enlacesCategoria && enlacesCategoria.length > 0) {
                                if (categoria && categoria.trim() !== '') {
                                    html += `<h1 class="titFooter mt-2">${escapeHtml(categoria)}</h1>`;
                                }
                                enlacesCategoria.forEach(enlace => {
                                    if (enlace.nombre && enlace.nombre.trim() !== '') {
                                        const url = escapeUrl(enlace.url_link);
                                        html += `<li><a href="${url}">${escapeHtml(enlace.nombre)}</a></li>`;
                                    }
                                });
                            }
                        });
                        
                        html += '</div>';
                    }

                    // Columna 3: Contacto (solo si hay datos de contacto)
                    if (tieneContacto) {
                        html += `<div class="${colSize} col-sm-12 footerContact">`;
                        html += '<h1 class="titFooter mt-2">Contacto</h1>';
                        
                        if (footerData.direccion_contacto && footerData.direccion_contacto.trim() !== '') {
                            html += `
                                <li class="d-flex">
                                    <div class="contIcon">
                                        <i class="fa-solid fa-location-dot"></i>
                                    </div>
                                    <p>${escapeHtml(footerData.direccion_contacto).replace(/\n/g, '<br>')}</p>
                                </li>
                            `;
                        }
                        
                        if (footerData.telefono_contacto && footerData.telefono_contacto.trim() !== '') {
                            html += `
                                <li class="d-flex">
                                    <div class="contIcon">
                                        <i class="fa-solid fa-phone"></i>
                                    </div>
                                    <p>${escapeHtml(footerData.telefono_contacto)}</p>
                                </li>
                            `;
                        }
                        
                        if (footerData.email_contacto && footerData.email_contacto.trim() !== '') {
                            html += `
                                <li class="d-flex">
                                    <div class="contIcon">
                                        <i class="fa-solid fa-envelope"></i> 
                                    </div>
                                    <div class="conttexto">
                                        <p>Email: ${escapeHtml(footerData.email_contacto)}</p>
                                    </div>
                                </li>
                            `;
                        }
                        
                        html += '</div>';
                    }

                    // Copyright (solo si hay texto)
                    if (footerData.texto_copyright && footerData.texto_copyright.trim() !== '') {
                        html += '<hr class="mt-3">';
                        html += `<p class="text-center">${escapeHtml(footerData.texto_copyright)}</p>`;
                    }

                    footerContainer.innerHTML = html;
                }

                function renderizarFooterVacio() {
                    const footerContainer = document.querySelector('.contFooter');
                    if (!footerContainer) return;

                    // Si no hay datos, mostrar footer vacío
                    footerContainer.innerHTML = '';
                }
            </script>
    </body>
</html>