<div class="container-fluid mt-5 mb-5">
    <!-- Navegación de Tabs -->
    <ul class="nav nav-pills nav-justified nav-tabs">
        <% if (slidecontent && slidecontent.length > 0) { %>
            <% slidecontent.forEach((tab, index) => { %>
                <li class="nav-item">
                    <a 
                        class="nav-link <%= index === 0 ? 'active' : '' %>" 
                        id="tab-<%= tab.id_wb_comp_tab_tabs %>" 
                        data-bs-toggle="tab" 
                        href="#content-<%= tab.id_wb_comp_tab_tabs %>" 
                        role="tab" 
                        aria-controls="content-<%= tab.id_wb_comp_tab_tabs %>" 
                        aria-selected="<%= index === 0 ? 'true' : 'false' %>">
                        <%= tab.titulo %>
                    </a>
                </li>
            <% }) %>
        <% } else { %>
            <p>No hay tabs disponibles.</p>
        <% } %>
    </ul>

    <!-- Contenido de Tabs -->
    <div class="tab-content tabsContainer" id="myTabContent">
        <% if (slidecontent && slidecontent.length > 0) { %>
            <% slidecontent.forEach((tab, index) => { %>
                <div 
                    class="tab-pane fade <%= index === 0 ? 'show active' : '' %>" 
                    id="content-<%= tab.id_wb_comp_tab_tabs %>" 
                    role="tabpanel" 
                    aria-labelledby="tab-<%= tab.id_wb_comp_tab_tabs %>">
                    <h5><%= tab.titulo %></h5>
                    <p><%= tab.texto %></p>
                </div>
            <% }) %>
        <% } else { %>
            <p>No hay contenido disponible para las tabs.</p>
        <% } %>
    </div>
</div>
