                                        data-index_s1="<%= imgIndex + 1 %>">
                                        <img class="img-<%= imgIndex === 0 ? 'uno' : (imgIndex === 1 ? 'dos' : (imgIndex === 2 ? 'tres' : 'cuatro')) %>"
