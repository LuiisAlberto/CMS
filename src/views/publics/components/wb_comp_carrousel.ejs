            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselAguila_w_<%= idComp %>"
            data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>
<% } else if (type_carrousel===4) { %>
    <div id="carouselAguila_red_<%= idComp %>" class="carousel carousel-dark slide" data-bs-ride="carousel"
        data-bs-interval="false">
        <div class="carousel-indicators">
            <% slidecontent.forEach((_, index)=> { %>
                <button type="button" data-bs-target="#carouselAguila_red_<%= idComp %>" data-bs-slide-to="<%= index %>"
                    class="<%= index === 0 ? 'active' : '' %>"
