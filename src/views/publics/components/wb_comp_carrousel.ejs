<% if (type_carrousel===1) { %>
    <div id="carouselNacional_<%= idComp %>" class="carousel carousel-dark slide" data-bs-ride="carousel" data-bs-interval="false">
        <div class="carousel-indicators">
            <% slidecontent.forEach((_, index)=> { %>
                <button type="button" data-bs-target="#carouselNacional_<%= idComp %>" data-bs-slide-to="<%= index %>"
                    class="<%= index === 0 ? 'active' : '' %>" aria-current="<%= index === 0 ? 'true' : 'false' %>"
                    aria-label="Slide <%= index + 1 %>">
                </button>
            <% }) %>
        </div>
        <!-- Contenedor de Slides -->
        <div class="carousel-inner cs-inner">
            <% slidecontent.forEach((slide, index)=> { %>
                <% const slideVariant = index % 3; %>
                <div class="carousel-item carrusel-nacional <%= index === 0 ? 'active' : '' %>">
                    <!-- Slide 1 -->
                    <% if (slideVariant===0) { %>
                        <div class="containerLeftSlide">
                            <div class="container-logo-slide">
                                <img class="logo-morena" src="/assets/img/recursos_componentes/LOGO-MORENA.png"
                                    alt="logo-morena">
                            </div>
                            <div class="container-titulo-slide">
                                <p class="titulo-slide">
                                    <%= slide.titulo %>
                                </p>
                            </div>
                            <div class="container-text-slide">
                                <p class="text-slide">
                                    <%= slide.texto %>
                                </p>
                            </div>
                            <div class="container-btn-slide">
                                <button class="btnPrincBlack">
                                    <div class="corner"></div>
                                    <span>
                                        <%= slide.btn_text%>
                                    </span>
                                    <div class="s-block">
                                        <i class="fa-solid fa-arrow-right"></i>
                                    </div>
                                </button>
                            </div>
                        </div>
                        <div class="containerRightSlide containerdiv <%= slide.fk_id_file && slide.fk_id_file.length === 1 ? 'single-image-container' : '' %>">
                            <% if (slide.fk_id_file && slide.fk_id_file.length> 0) { %>
                                <% slide.fk_id_file.forEach((file, imgIndex)=> { %>
                                    <div class="container-img-<%= imgIndex + 1 %> containerdiv"
                                        data-index_s1="<%= imgIndex + 1 %>">
                                        <img class="img-<%= imgIndex + 1 %>"
                                            src="<%= file.storage_path + file.file_path %>"
                                            alt="img-<%= imgIndex + 1 %>">
                                    </div>
                                <% }) %>
                                <% } else { %>
                                    <div class="container-img-1 containerdiv" data-index_s1="1">
                                        <img class="img-1" src="/assets/img/default_morena.png" alt="img-default">
                                    </div>
                            <% } %>
                        </div>
                    <% } %>
                    <!-- Slide 2 -->
                    <% if (slideVariant===1) { %>
                        <div class="containerLeftSlide">
                            <div class="container-imgleft-slide2 <%= slide.fk_id_file && slide.fk_id_file.length === 1 ? 'single-image-container' : '' %>">
                                <% if (slide.fk_id_file && slide.fk_id_file.length> 0) { %>
                                    <img class="imgleft-slide2"
                                        src="<%= slide.fk_id_file[0].storage_path + slide.fk_id_file[0].file_path %>" alt="imgleft-slide2">
                                <% } else { %>
                                    <img class="imgleft-slide2" src="/assets/img/default_morena.png" alt="img-default">
                                <% } %>
                            </div>
                        </div>
                        <div class="containerRightSlide responsive p-top">
                            <div class="container-tituloslide2">
                                <p class="titulo-slide2">
                                    <%= slide.titulo %>
                                </p>
                            </div>
                            <div class="container-text-slide2">
                                <p class="text-slide2">
                                    <%= slide.texto %>
                                </p>
                            </div>
                            <div class="container-btn-slide2">
                                <button class="btnPrincBlack">
                                    <div class="corner"></div>
                                    <span>
                                        <%= slide.btn_text%>
                                    </span>
                                    <div class="s-block">
                                        <i class="fa-solid fa-arrow-right"></i>
                                    </div>
                                </button>
                            </div>
                        </div>
                    <% } %>
                    <!-- Slide 3 -->
                    <% if (slideVariant===2) { %>
                        <div class="containerLeftSlide <%= slide.fk_id_file && slide.fk_id_file.length === 1 ? 'single-image-container' : '' %>">
                            <% if (slide.fk_id_file && slide.fk_id_file.length> 0) { %>
                                <% slide.fk_id_file.forEach((file, imgIndex)=> { %>
                                    <div id="container<%= imgIndex + 1 %>-s3"
                                        class="container-img-<%= imgIndex + 1 %>-s3 containerdiv"
                                        data-index_s3="<%= imgIndex + 1 %>">
                                        <img class="img-<%= imgIndex + 1 %>-s3"
                                            src="<%= file.storage_path + file.file_path %>"
                                            alt="img-<%= imgIndex + 1 %>-s3">
                                    </div>
                                <% }) %>
                                <% } else { %>
                                    <div id="container1-s3" class="container-img-1-s3 containerdiv" data-index_s3="1">
                                        <img class="img-1-s3" src="/assets/img/default_morena.png" alt="img-default">
                                    </div>
                            <% } %>
                        </div>
                        <div class="containerRightSlide responsive p-top">
                            <div class="container-tituloslide2">
                                <p class="titulo-slide2">
                                    <%= slide.titulo %>
                                </p>
                            </div>
                            <div class="container-text-slide2">
                                <p class="text-slide2">
                                    <%= slide.texto %>
                                </p>
                            </div>
                            <div class="container-btn-slide2">
                                <div class="btn btn-slide2">
                                    <button class="btnPrincBlack">
                                        <div class="corner"></div>
                                        <span>
                                            <%= slide.btn_text%>
                                        </span>
                                        <div class="s-block">
                                            <i class="fa-solid fa-arrow-right"></i>
                                        </div>
                                    </button>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            <% }) %>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#carouselNacional_<%= idComp %>" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselNacional_<%= idComp %>" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>
<% } else if (type_carrousel===2) { %>
    <div id="carouselEstatal_<%= idComp %>" class="carousel carousel-dark slide" data-bs-ride="carousel" data-bs-interval="false"<% if (typeof carouselEstatalBgUri !== 'undefined' && carouselEstatalBgUri) { %> style="background-image: url('<%= carouselEstatalBgUri %>'); background-size: cover; background-position: center;"<% } %>>
        <% if (typeof carouselEstatalOverlayRgba !== 'undefined' && carouselEstatalOverlayRgba) { %>
        <div class="carousel-estatal-accent-overlay" style="background-color: <%= carouselEstatalOverlayRgba %>;" aria-hidden="true"></div>
        <% } %>
        <div class="carousel-indicators">
            <% slidecontent.forEach((_, index)=> { %>
                <button 
                    type="button" 
                    data-bs-target="#carouselEstatal_<%= idComp %>" 
                    data-bs-slide-to="<%= index %>"
                    class="<%= index === 0 ? 'active' : '' %>" 
                    aria-current="<%= index === 0 ? 'true' : 'false' %>"
                    aria-label="Slide <%= index + 1 %>">
                </button>
            <% }) %>
        </div>

        <div class="carousel-inner cs-inner">
            <% slidecontent.forEach((slideEst, index)=> { %>
                <!-- SOLUCIÓN TEMPORAL MEJORADA -->
                <% // Determinar type_slide: primero del backend, si no por índice let
                    currentTypeSlide=slideEst.type_slide; let typeSource='backend' ; if (!currentTypeSlide ||
                    currentTypeSlide==='-' || currentTypeSlide==='NO DEFINIDO' ) { currentTypeSlide=(index % 3) + 1;
                    typeSource='calculado por índice' ; } %>

                <div class="carousel-item carrusel-estatal <%= index === 0 ? 'active' : '' %>">
                    <!-- LADO IZQUIERDO - USANDO currentTypeSlide -->
                    <div class="containerLeftSlide">
                        <% if (currentTypeSlide===1) { %>
                            <!-- TIPO 1: TEXTO a la izquierda -->
                            <div class="container-titulo-slide">
                                <p class="titulo-slide-estatal">
                                    <%= slideEst.titulo %>
                                </p>
                            </div>
                            <div class="container-text-slide">
                                <p class="text-slide-estatal">
                                    <%= slideEst.texto %>
                                </p>
                            </div>
                            <div class="container-btn-slide">
                                <div class="btn btn-slide">
                                    <% if (slideEst.url_link && slideEst.url_link !=='#' ) { %>
                                        <a class="text-color-a" href="<%= slideEst.url_link %>">
                                    <% } %>
                                            <button class="btnPrincBlack">
                                                <div class="corner"></div>
                                                <span>
                                                    <%= slideEst.btn_text || 'Siguiente' %>
                                                </span>
                                                <div class="s-block">
                                                    <i class="fa-solid fa-arrow-right"></i>
                                                </div>
                                            </button>
                                            <% if (slideEst.url_link && slideEst.url_link !=='#' ) { %>
                                        </a>
                                    <% } %>
                                </div>
                            </div>
                        <% } else if (currentTypeSlide===2) { %>
                            <!-- TIPO 2: IMAGEN a la izquierda -->
                            <div class="container-imgleft-slide2 <%= slideEst.fk_id_file && slideEst.fk_id_file.length === 1 ? 'single-image-container' : '' %>">
                                <% if (slideEst.fk_id_file && slideEst.fk_id_file.length> 0) { %>
                                    <img class="imgleft-slide2"
                                        src="<%= slideEst.fk_id_file[0].storage_path + slideEst.fk_id_file[0].file_path %>"
                                        alt="<%= slideEst.titulo || 'Imagen' %>">
                                <% } else { %>
                                    <img class="imgleft-slide2" src="/assets/img/default_morena.png" alt="default-img">
                                <% } %>
                            </div>
                        <% } else if (currentTypeSlide===3) { %>
                            <!-- TIPO 3: IMÁGENES a la izquierda -->
                            <div class="containerLeftSlide <%= slideEst.fk_id_file && slideEst.fk_id_file.length === 1 ? 'single-image-container' : '' %>">
                                <% if (slideEst.fk_id_file && slideEst.fk_id_file.length> 0) { %>
                                    <% slideEst.fk_id_file.forEach((file, imgIndex)=> { %>
                                        <div class="container-img-<%= imgIndex + 1 %>-s3 containerdiv">
                                            <img class="img-<%= imgIndex + 1 %>-s3" src="<%= file.storage_path + file.file_path %>" alt="<%= slideEst.titulo || 'Imagen' %>">
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <div class="container-img-1-s3 containerdiv">
                                        <img class="img-1-s3" src="/assets/img/default_morena.png" alt="default-img">
                                    </div>
                                <% } %>
                            </div>
                        <% } %>
                    </div>

                    <!-- LADO DERECHO - USANDO currentTypeSlide -->
                    <div class="containerRightSlide <%= currentTypeSlide !== 1 ? 'responsive p-top' : '' %> <%= currentTypeSlide === 1 && slideEst.fk_id_file && slideEst.fk_id_file.length === 1 ? 'single-image-container' : '' %>">
                        <% if (currentTypeSlide===1) { %>
                            <!-- TIPO 1: IMÁGENES a la derecha -->
                            <% if (slideEst.fk_id_file && slideEst.fk_id_file.length> 0) { %>
                                <% slideEst.fk_id_file.forEach((file, imgIndex)=> { %>
                                    <div class="container-img-<%= imgIndex + 1 %> containerdiv">
                                        <img class="img-<%= imgIndex + 1 %>"
                                            src="<%= file.storage_path + file.file_path %>"
                                            alt="<%= slideEst.titulo || 'Imagen' %>">
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <div class="container-img-1 containerdiv">
                                    <img class="img-1" src="/assets/img/default_morena.png" alt="default-img">
                                </div>
                            <% } %>
                        <% } else if (currentTypeSlide===2 || currentTypeSlide===3) { %>
                            <!-- TIPO 2 y 3: TEXTO a la derecha -->
                            <div class="container-tituloslide2">
                                <p class="titulo-slide2-estatal">
                                    <%= slideEst.titulo %>
                                </p>
                            </div>
                            <div class="container-text-slide2">
                                <p class="text-slide2-estatal">
                                    <%= slideEst.texto %>
                                </p>
                            </div>
                            <div class="container-btn-slide2">
                                <div class="btn btn-slide2">
                                    <% if (slideEst.url_link && slideEst.url_link !=='#'
                                        ) { %>
                                        <a class="text-color-a"
                                            href="<%= slideEst.url_link %>">
                                            <% } %>
                                                <button class="btnPrincBlack">
                                                    <div class="corner"></div>
                                                    <span>
                                                        <%= slideEst.btn_text
                                                            || 'Continuar' %>
                                                    </span>
                                                    <div class="s-block">
                                                        <i
                                                            class="fa-solid fa-arrow-right"></i>
                                                    </div>
                                                </button>
                                                <% if (slideEst.url_link &&
                                                    slideEst.url_link !=='#' ) { %>
                                        </a>
                                        <% } %>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>

        <!-- Controles -->
        <button class="carousel-control-prev" type="button" data-bs-target="#carouselEstatal_<%= idComp %>" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselEstatal_<%= idComp %>" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>
<% } else if (type_carrousel===3) { %>
    <div id="carouselAguila_w_<%= idComp %>" class="carousel carousel-dark slide" data-bs-ride="carousel" data-bs-interval="false">
        <div class="carousel-indicators">
            <% slidecontent.forEach((_, index)=> { %>
                <button type="button" data-bs-target="#carouselAguila_w_<%= idComp %>" data-bs-slide-to="<%= index %>"
                    class="<%= index === 0 ? 'active' : '' %>"
                    aria-current="<%= index === 0 ? 'true' : 'false' %>" aria-label="Slide <%= index + 1 %>">
                </button>
            <% }) %>
        </div>
        <!-- Contenedor de Slides -->
        <div class="carousel-inner cs-inner">
            <% slidecontent.forEach((slide, index)=> { %>
                <% const slideVariant = index % 3; %>
                <div class="carousel-item  <%= index === 0 ? 'active' : '' %>">
                    <!-- Slide 1 -->
                    <% if (slideVariant===0) { %>
                        <div class="containerLeftSlide">
                            <div class="container-logo-slide">
                                <% if (slide.fk_id_file && slide.fk_id_file.length> 0) { %>
                                    <img class="logo-morena" src="<%= slide.fk_id_file[0].storage_path + slide.fk_id_file[0].file_path %>" alt="logo-morena">
                                    <% } else { %>
                                    <img class="logo-morena" src="/assets/img/recursos_componentes/LOGO-MORENA.png" alt="logo-morena">
                                <% } %>
                            </div>
                            <div class="container-titulo-slide">
                                <p class="titulo-slide">
                                    <%= slide.titulo %>
                                </p>
                            </div>
                            <div class="container-text-slide">
                                <p class="text-slide">
                                    <%= slide.texto %>
                                </p>
                            </div>
                            <div class="container-btn-slide">
                                <button class="btnPrincBlack">
                                    <div class="corner"></div>
                                    <span>
                                        <%= slide.btn_text%>
                                    </span>
                                    <div class="s-block">
                                        <i class="fa-solid fa-arrow-right"></i>
                                    </div>
                                </button>
                            </div>
                        </div>
                        <div class="containerRightSlide containerdiv <%= slide.fk_id_file && slide.fk_id_file.length === 1 ? 'single-image-container' : '' %>">
                            <% if (slide.fk_id_file && slide.fk_id_file.length> 0) { %>
                                <% slide.fk_id_file.forEach((file, imgIndex)=> { %>
                                    <div class="container-img-<%= imgIndex + 1 %> containerdiv"
                                        data-index_s1="<%= imgIndex + 1 %>">
                                        <img class="img-<%= imgIndex + 1 %>"
                                            src="<%= file.storage_path + file.file_path %>"
                                            alt="img-<%= imgIndex + 1 %>">
                                    </div>
                                    <% }) %>
                                        <% } else { %>
                                            <div class="container-img-1 containerdiv" data-index_s1="1">
                                                <img class="img-1" src="/assets/img/default_morena.png"
                                                    alt="img-default">
                                            </div>
                                            <% } %>
                        </div>
                        <% } %>
                            <!-- Slide 2 -->
                            <% if (slideVariant===1) { %>
                                <div class="containerLeftSlid">
                                    <div class="container-imgleft-slide2">
                                        <% if (slide.fk_id_file && slide.fk_id_file.length> 0) { %>
                                            <img class="imgleft-slide2"
                                                src="<%= slide.fk_id_file[0].storage_path + slide.fk_id_file[0].file_path %>"
                                                alt="imgleft-slide2">
                                            <% } else { %>
                                                <img class="imgleft-slide2" src="/assets/img/default_morena.png"
                                                    alt="img-default">
                                                <% } %>
                                    </div>
                                </div>
                                <div class="containerRightSlide responsive p-top">
                                    <div class="container-tituloslide2">
                                        <p class="titulo-slide2">
                                            <%= slide.titulo %>
                                        </p>
                                    </div>
                                    <div class="container-text-slide2">
                                        <p class="text-slide2">
                                            <%= slide.texto %>
                                        </p>
                                    </div>
                                    <div class="container-btn-slide2">
                                        <div class="btn btn-slide2">
                                            <button class="btnPrincBlack">
                                                <div class="corner"></div>
                                                <span>
                                                    <%= slide.btn_text%>
                                                </span>
                                                <div class="s-block">
                                                    <i class="fa-solid fa-arrow-right"></i>
                                                </div>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <% } %>
                                    <!-- Slide 3 -->
                                    <% if (slideVariant===2) { %>
                                        <div class="containerLeftSlide">
                                            <% if (slide.fk_id_file && slide.fk_id_file.length> 0) { %>
                                                <% slide.fk_id_file.forEach((file, imgIndex)=> { %>
                                                    <div id="container<%= imgIndex + 1 %>-s3"
                                                        class="container-img-<%= imgIndex === 0 ? 'uno' : (imgIndex === 1 ? 'dos' : 'tres') %>-s3 containerdiv"
                                                        data-index_s3="<%= imgIndex + 1 %>">
                                                        <img class="img-<%= imgIndex === 0 ? 'uno' : (imgIndex === 1 ? 'dos' : 'tres') %>-s3"
                                                            src="<%= file.storage_path + file.file_path %>"
                                                            alt="img-<%= imgIndex + 1 %>">
                                                    </div>
                                                    <% }) %>
                                                        <% } else { %>
                                                            <div id="container1-s3"
                                                                class="container-img-uno-s3 containerdiv"
                                                                data-index_s3="1">
                                                                <img class="img-uno-s3"
                                                                    src="/assets/img/default_morena.png"
                                                                    alt="img-default">
                                                            </div>
                                                            <% } %>
                                        </div>
                                        <div class="containerRightSlide responsive p-top">
                                            <div class="container-tituloslide2">
                                                <p class="titulo-slide2">
                                                    <%= slide.titulo %>
                                                </p>
                                            </div>
                                            <div class="container-text-slide2">
                                                <p class="text-slide2">
                                                    <%= slide.texto %>
                                                </p>
                                            </div>
                                            <div class="container-btn-slide2">
                                                <div class="btn btn-slide2">
                                                    <button class="btnPrincBlack">
                                                        <div class="corner"></div>
                                                        <span>
                                                            <%= slide.btn_text%>
                                                        </span>
                                                        <div class="s-block">
                                                            <i class="fa-solid fa-arrow-right"></i>
                                                        </div>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                        <% } %>
                </div>
                <% }) %>
