<style>
    .card_cardtag {
        position: relative;
        cursor: pointer;
        transition: transform 0.3s ease;
    }

    .card_cardtag:hover {
        transform: translateY(-5px);
    }

    .cont_img_cardtag a {
        display: block;
        position: relative;
    }

    .circles_ptv {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 2;
        opacity: 0;
        transition: opacity 0.3s ease;
        background: rgba(0, 0, 0, 0.7);
        border-radius: 50%;
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card_cardtag:hover .circles_ptv {
        opacity: 1;
    }

    .img_cardtag {
        transition: filter 0.3s ease;
    }

    .card_cardtag:hover .img_cardtag {
        filter: brightness(0.7);
    }
</style>
<!-- Ya no es un componente de tipo tag, ahora es un componente de tipo textImg -->

<div class="card-tag-container">
    <% if (Array.isArray(objcomp.wb_comp_cards) && objcomp.wb_comp_cards.length> 0) { %>
        <% objcomp.wb_comp_cards.forEach((item, index)=> { %>
            <div class="card card_cardtag">
                <div class="t_cont_cardtag">
                    <p class="cardtag_text">
                        <%= item.titulo %>
                    </p>
                </div>
                <div class="cont_img_cardtag">
                    <a class='' href='<%= item.url_link %>' target="_blank">
                        <span class="circles_ptv">
                            <i class="fa-solid fa-arrow-right fa-2x" style="color: #ffffff;"></i>
                        </span>
                    </a>

                    <% if (item.fk_id_file && item.fk_id_file[0]) { %>
                        <img class="img_cardtag"
                            src="<%= item.fk_id_file[0].storage_path + '' +  item.fk_id_file[0].file_path %>"
                            alt="card_<%= item.titulo %>">
                        <% } else { %>
                            <img class="img_cardtag" src="/assets/img/default_morena.png" alt="card_<%= item.titulo %>">
                            <% } %>
                </div>
            </div>
            <% }) %>
                <% } else { %>
                    <p>No hay tarjetas disponibles.</p>
                    <% } %>
</div>