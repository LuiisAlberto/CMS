<script>
(function () {
    var _origGet = typeof getHtmlTemplate === 'function' ? getHtmlTemplate : null;
    window.getHtmlTemplate = function (id) {
        var el = document.getElementById(id);
        if (el && el.tagName === 'TEMPLATE' && el.content) {
            var wrap = document.createElement('div');
            wrap.appendChild(el.content.cloneNode(true));
            return wrap.innerHTML;
        }
        if (typeof $ !== 'undefined' && $('template#' + id).length) {
            return $('template#' + id).html();
        }
        if (window.parent && window.parent !== window && window.parent.document) {
            var pel = window.parent.document.getElementById(id);
            if (pel && pel.tagName === 'TEMPLATE' && pel.content) {
                var w2 = document.createElement('div');
                w2.appendChild(pel.content.cloneNode(true));
                return w2.innerHTML;
            }
            if (window.parent.jQuery && window.parent.jQuery('template#' + id).length) {
                return window.parent.jQuery('template#' + id).html();
            }
        }
        return _origGet ? _origGet(id) : '';
    };
})();
</script>
