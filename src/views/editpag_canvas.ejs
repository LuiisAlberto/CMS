    // -----------------------------------------------------------
    // Botón Publicar/Actualizar: habilitar al detectar cambios.
    // __setDraftDirty: marca cambios y habilita el botón.
    // __setDraftClean: limpia estado y deshabilita el botón (tras publicar).
    // -----------------------------------------------------------
    window.__setDraftDirty = function() {
        var $btn = $menu('#btnPubPag');
        if ($btn.length) {
            var updateOnly = $btn.attr('data-update-only') === '1';
            var title = updateOnly
                ? 'Haga clic para regenerar el HTML estático con los cambios guardados'
                : 'Publicar cambios y actualizar el HTML estático';
            $btn.prop('disabled', false).attr('title', title);
            $btn.addClass('verde_b').removeClass('gris');
        }
    };
    window.__setDraftClean = function() {
        var $btn = $menu('#btnPubPag');
        if ($btn.length) {
            var updateOnly = $btn.attr('data-update-only') === '1';
            var esPublicada = $btn.data('stat') === 1;
            // Página publicada o borrador: el botón solo se habilita tras cambios (__setDraftDirty).
            if (updateOnly && esPublicada) {
                $btn.prop('disabled', true).attr('title', 'Realice cambios en la página para habilitar la actualización del HTML estático');
            } else {
                $btn.prop('disabled', true).attr('title', 'Guarde cambios en la página para habilitar la publicación');
            }
            if (esPublicada) $btn.addClass('verde_b').removeClass('gris');
            else $btn.addClass('gris').removeClass('verde_b');
        }
    };

    // -----------------------------------------------------------
    // Dirty flag: detectar cambios en borradores sin afectar lo publicado.
    // Marcamos como "cambios sin publicar" cuando endpoints de edición responden OK.
    // Cubre tanto $.ajax como fetch (usado en modales/componentes).
    // -----------------------------------------------------------
    (function initDraftDirtyTracking(){
        try {
            const mutatingEndpoints = [
                '/CreatePag',
                '/agregarSeccion',
                '/eliminarSeccion',
                '/reordenarSeccion',
                '/agregarColumna',
                '/eliminarColumna',
                '/CreateComp',
                '/getCompToDelete',
                '/CreateFirstSlide',
                '/AddSlides',
                '/DeleteSlide',
                '/SaveAllSlidesStatus',
                '/SaveAllSlidesData',
                '/updateComponentData',
                '/CreateRegeneracion',
                '/EditRegeneracion',
                '/DeleteRegeneracion',
                '/crear-componente-acordeon',
                '/agregar-categoria-acordeon',
                '/agregar-subcategoria-acordeon',
                '/agregar-acordeon',
                '/eliminar-elemento-acordeon',
                '/publicar-acordeon',
                '/agent/create',
                '/agent/create-section'
            ];

            function isMutatingUrl(url){
                if (!url) return false;
                return mutatingEndpoints.some(ep => String(url).includes(ep));
            }

            // Hook jQuery ajaxSuccess
            $(document).ajaxSuccess(function(_evt, _xhr, settings, data){
                if (!settings || !isMutatingUrl(settings.url)) return;
                if (data && data.success === false) return;
                if (typeof window.__setDraftDirty === 'function') window.__setDraftDirty();
            });

            // Hook fetch (sin romperlo)
            if (window.fetch) {
                const originalFetch = window.fetch.bind(window);
                window.fetch = async function(input, init){
                    const url = (typeof input === 'string') ? input : (input && input.url);
                    const res = await originalFetch(input, init);
                    try {
                        if (isMutatingUrl(url) && res && res.ok) {
                            const cloned = res.clone();
                            let json = null;
                            try { json = await cloned.json(); } catch(e) {}
                            if (!json || json.success !== false) {
                                if (typeof window.__setDraftDirty === 'function') window.__setDraftDirty();
                            }
                        }
                    } catch(e) {}
                    return res;
                };
            }
        } catch (e) {
            // no-op
        }
    })();

</script>

