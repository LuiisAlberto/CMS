                        ['para', ['ul', 'ol', 'paragraph']],
                        ['height', ['height']],
                        ['view', ['codeview']],
                    ]
                });
            }

        }
        function handleColumnSelection($boton, sec, columnas_div) {
            $('.pub_columna').removeClass('selected');
            $menu('.btn-cols').removeClass('selected');
            $boton.addClass('selected');
            
            const columna = $boton.data('col');
            // Seleccionar solo la .pub_columna con este orden (no componentes que también tienen data-orden)
            const $selectedCol = $(`#seccion_${sec} .pub_columna`).filter(function() {
                return parseInt($(this).attr('data-orden'), 10) === parseInt(columna, 10);
            }).first();
            $selectedCol.addClass('selected');
            // Usar el ID real de la columna (id_wb_pag_columna) para que el modal y el registro funcionen
            const realIdCol = $selectedCol.attr('data-idcol') || $selectedCol.data('idcol') || columna;
            
            // 🔹 Evitar múltiples hr duplicados:
            const $editAll = $menu('#editall');
            const $existingSection = $editAll.find('.secmenu');

            if ($existingSection.length) {
                // Si ya existe, lo reemplazamos completamente (incluye el hr)
                $existingSection.prev('hr').remove();
                $existingSection.remove();
            }

            // 🔹 Agregar solo una vez el nuevo bloque (data-idcol = ID real de columna)
            $editAll.append(`
                <hr>
                <div class="secmenu" id="listVars">
                    <button type="button" class="btnAddComponent newCompMod"  
                        data-idsec="${sec}" 
                        data-numcols="${columnas_div.length}" 
                        data-idcol="${realIdCol}" 
                        data-cy="">
                        <span class="btn-text">NUEVO COMPONENTE</span>
                        <div class="circleButton">
                            <i class="fa-solid fa-plus"></i>
                        </div>
                    </button>
                </div>
            `);
        }
        
        function updateColumnStyles(sec, num_cols, idNuevaCol, orden) {
            $menu('#trash' + num_cols).remove();
            $menu(`#col${num_cols}`).addClass('active').after(`
                <button id="trash${num_cols}" 
                        data-col="${num_cols}" 
                        data-idcolu="${idNuevaCol}" 
                        class="btn-trash" 
                        type="button">
                    <i class="fa fa-trash"></i>
                </button>
            `);
        }
        $('.pub_componente').each(function(index) {
            let idc=$(this).attr('id');
            let idsec=$(this).data('sec');
            let idcol=$(this).data('col');
            fetch('/getComponenteObj',{
                method: 'POST',
                body:   JSON.stringify({
                    idp: '<%=dataapp.id_sysapp%>',
                    id_comp:idc ,
                    data_comp: $(this).data('comp')
                }),
                headers: {
                    "Content-Type": "application/json",
                },
            })
                .then(response=>response.json())
                .then(data=>{
                    if(data.success){
                        max_num_comp=data.id_comp > max_num_comp? data.id_comp:max_num_comp;
                        componentdata[data.id_comp]=data.objc;
                        componentdata[data.id_comp].saved=true;
                        componentdata[data.id_comp].modified=false;
                    }
                })
        });
    });

    function refreshSectionOrderButtons() {
        var idsec = parseInt($menu('#idsec').val(), 10);
        if (isNaN(idsec)) return;
        var $secs = $('.pub_seccion');
        var idx = -1;
        $secs.each(function (i) {
            if (parseInt($(this).data('sec'), 10) === idsec) {
                idx = i;
                return false;
            }
        });
        var $up = $menu('#orderUp');
        var $down = $menu('#orderDown');
        if (!$up.length || !$down.length) return;
        $up.prop('disabled', idx <= 0);
        $down.prop('disabled', idx < 0 || idx >= $secs.length - 1);
    }

    function _parseDataOrden(el) {
        if (!el || !el.getAttribute) return 0;
        var v = el.getAttribute('data-orden');
        if (v == null || v === '') return 0;
        var n = parseInt(v, 10);
        return isNaN(n) ? 0 : n;
    }

    function orderSecc(withControls = true) {
        var $parent = $('#contPub');
        if (!$parent.length) return;
        var rows = $parent.children('.pub_seccion').get();
        rows.sort(function (a, b) {
            return _parseDataOrden(a) - _parseDataOrden(b);
        });
        rows.forEach(function (row) {
            $parent.append(row);
        });

        var i = 1;
        $parent.children('.pub_seccion').each(function () {
            var $row = $(this);
            $row.removeData('orden');
            $row.attr('data-orden', i);

            if (withControls) {
                $row.next('.section-controls').remove();
                $row.after(`
                    <div class="addSec section-controls">
                        <button class="btnAco rojo_guinda newSec" data-orden="${i}">
                            <span class="disNo"></span><i class="fas fa-plus"></i>
                        </button>
                        <button class="btnAco rojo_guinda deletedSec" data-idsec="${$row.data('sec')}">
                            <span class="disNo"></span><i class="fa-solid fa-trash"></i>
                        </button>
                    </div>`);
            }
            i++;
        });
        if (withControls && typeof refreshSectionOrderButtons === 'function') {
            refreshSectionOrderButtons();
        }
    }

    function orderCols(idsec) {
        var $row = $('#seccion_' + idsec);
        if (!$row.length) return;
        var cols = $row.find('.pub_columna').get();
        cols.sort(function (a, b) {
            return _parseDataOrden(a) - _parseDataOrden(b);
        });
        cols.forEach(function (col) {
            $row.append(col);
        });
        var i = 1;
        $row.find('.pub_columna').each(function () {
            var $c = $(this);
            $c.removeData('orden');
            $c.attr('data-orden', i);
            i++;
        });
    }

    function CrearPag (){
        var tipopag = $('#tipopag').val();
        var cyphval = $('#cyphval').val();
        var namepag = $('#namepag').val();
        var tipo_tag = $('#tipo_tag').val();
        var cont_alt = $('#cont_alt').val();
        var cont_full = $('#cont_full').val();
        var f_pub = $('#f_pub').val();
        var idpag = $('#idpag').val();
        var url = $('#url').val();

        var formData = new FormData();
        formData.append('url', url);
        formData.append('tipo_tag', tipo_tag);
        formData.append('namepag', namepag);
        formData.append('cyphval', cyphval);
        formData.append('tipopag', tipopag);
        formData.append('cont_alt', cont_alt);
        formData.append('cont_full', cont_full);
        formData.append('f_pub', f_pub);
        formData.append('idpag', idpag);

        var archivo = window.getFileFromPondPagina ? window.getFileFromPondPagina() : null;
        if (archivo) {
            formData.append('cargar-imagpag', archivo);
        }
        fetch('/CreatePag', {
            method: 'POST',
            body: formData,
        })
            .then(response => response.json())
            .then(data => {
                //// console.log(data.success);
                if(data.success){
                    $.alert({
                        title: "Se guardó correctamente",
                        content: "Se ha guardado la página correctamente",
                        theme: 'modern',
                        icon: 'fa-solid fa-check',
                        type: "green",
                        buttons: {
                            Aceptar: {
                                text: 'Aceptar',
                                btnClass: 'btn-success',
                                action: function () {
                                    window.location.reload();
                                }
                            }
                        }
                    });
                } else {
                    $.alert({
                        title: "Advertencia",
                        content: data.message,
                        theme: 'modern',
                        icon: 'fa-solid fa-triangle-exclamation',
                        type: "red"
                    });
                }
            })
            .catch(error => {
                console.error('Error:', error);
            });

    }
    window.CrearPag = CrearPag;
