    #modalGral #newpage .filepond--drop-label {
        position: absolute !important; left: 0 !important; right: 0 !important; top: 0 !important; bottom: 0 !important;
        margin: 0 !important; padding: 0 !important; min-height: 0 !important; height: 100% !important;
        display: flex !important; align-items: center !important; justify-content: center !important;
        border: none !important; background: transparent !important; border-radius: 0 !important;
