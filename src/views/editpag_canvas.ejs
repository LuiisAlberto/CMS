            let blocked = $seccion.hasClass('blocked');
            if (blocked) return;

            /* Ya había sección activa pero se borraron todas las columnas: volver a crear la primera */
            if (active && $seccion.find('.pub_columna').length === 0) {
                let sec = $menu('#idsec').val() || $seccion.data('sec');
                if (sec == null || sec === '') return;
