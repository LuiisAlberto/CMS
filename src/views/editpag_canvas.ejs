    }
    #modalGral #newpage .filepond-row { margin-bottom: 1rem; }
    #modalGral #newpage .filepond--root {
        max-height: 200px; min-height: 96px; position: relative; pointer-events: auto !important;
        border: 1px solid #e0e0e0 !important; border-radius: 8px !important;
