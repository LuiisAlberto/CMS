<script>
    /** Elementos del menú lateral están en el documento padre (shell del editor). */
    var $menu = (function () {
        var pw = window.parent;
        if (!pw || pw === window || !pw.jQuery) {
            return function (sel, ctx) { return typeof ctx !== 'undefined' ? jQuery(sel, ctx) : jQuery(sel); };
        }
        var $p = pw.jQuery;
        var d = pw.document;
        return function (sel, ctx) { return ctx ? $p(sel, ctx) : $p(sel, d); };
    })();
    var $docCanvas = $(document);
    var $docParent = (window.parent && window.parent.jQuery && window.parent !== window)
        ? window.parent.jQuery(window.parent.document)
        : $docCanvas;

    /** Instancia de modal (mismo documento que #modalGral; no mezclar con bootstrap del padre). */
    function getBootstrapModalCtor() {
        if (typeof bootstrap !== 'undefined' && bootstrap.Modal) return bootstrap.Modal;
        return null;
    }

    /* Alineado con app/src/util/componentMinSizes.js (servidor) */
    let minComponentSizes = {
        1: 12,
        2: 3, 
        3: 3,
        4: 3, 
        5: 12, 
        7: 3,
        8: 12, 
        9: 12,
        10: 12,
        13: 3, 
        14: 12, 
        16: 12, 
        17: 12,
        20: 3,
        21: 3,
        23: 3,
        24: 12 
    }

    function sectionBlocksAdditionalColumns(sec) {
        var $comps = $('#seccion_' + sec).find('.pub_componente');
        var blocked = false;
        $comps.each(function () {
            var tip = $(this).attr('data-tipcomp');
            if (tip === undefined || tip === null || tip === '') return;
            var t = parseInt(tip, 10);
            if (isNaN(t)) return;
            var min = minComponentSizes[t] !== undefined ? minComponentSizes[t] : 3;
            if (min >= 12) {
                blocked = true;
                return false;
            }
        });
        return blocked;
    }

    function refreshColumnSlotAvailability(sec) {
        if (sec == null || sec === '') return;
        var canAdd = !sectionBlocksAdditionalColumns(sec);
        $menu('#editall .btn-cols').each(function () {
            var $b = $(this);
            if ($b.hasClass('active')) {
                $b.prop('disabled', false);
                $b.removeAttr('title');
                return;
            }
            if (!canAdd) {
                $b.prop('disabled', true);
                $b.attr('title', 'No se pueden añadir columnas: hay un componente de ancho completo en esta sección.');
            } else {
                $b.prop('disabled', false);
                $b.removeAttr('title');
            }
        });
    }

    window.refreshEditorColumnSlots = function () {
        var s = $menu('#idsec').val();
        if (s != null && s !== '') refreshColumnSlotAvailability(String(s));
    };

    let max_num_sec=0;
    let max_num_col=0;
    let pagedata=<%- JSON.stringify(datapagina) %>;
    let dataapp = <%- JSON.stringify(dataapp) %>;
    window.dataapp = dataapp;
    window.pagedata = pagedata;

    for (let secc of pagedata.secciones) { 
        max_num_sec=secc.id_wb_pag_seccion > max_num_sec? secc.id_wb_pag_seccion:max_num_sec;
        for (let col of secc.columnas) {
            max_num_col=col.id_wb_pag_columna > max_num_col? col.id_wb_pag_columna:max_num_col;
        }
    }

    let componentdata={};
    let max_num_comp=0;

    $(function () {
        /* Delegados en el padre: cada recarga del iframe ejecutaba este script de nuevo y acumulaba
           listeners (mismo documento padre), duplicando p. ej. POST /agregarColumna al pulsar una columna. */
        $docParent.off('.editpagCanvasIframe');

        $menu('#idlastsec').val(max_num_sec);

        orderSecc();
        $docCanvas.on('change', "#namepag", function () {
            var tipopag = $('#tipopag').val();
            if(parseInt(tipopag)!==1){
                let name = $(this).val();
                name = name.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
                name = name.toLowerCase();
                name = name.replace(/\s+/g, '-');
                name = name.replace(/[^a-z0-9\-]/g, '');
                name = name.substring(0, 50);
                name = name.replace(/-+$/, '');
                name = encodeURIComponent(name);
                $('#url').val(name);
            }
        });
        $docCanvas.on('change', "#url", function () {
            let name = $(this).val();
            name = name.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
            name = name.toLowerCase();
            name = name.replace(/\s+/g, '-');
            name = name.replace(/[^a-z0-9\-]/g, '');
            name = name.substring(0, 50);
            name = name.replace(/-+$/, '');
            name = encodeURIComponent(name);
            $('#url').val(name);
        });
        $docParent.on('click.editpagCanvasIframe', ".pubpag", function () {
            var $btn = $(this);
            let cy = $btn.data('cy');
            let stat = $btn.data('stat');
            let type = $btn.data('type');
            // En el editor: página ya publicada → solo regenerar HTML (nunca confundir con "ocultar").
            // data-stat=1 se usa en PubPag junto con update=1; sin esto, stat=1 + updateOnly falso mostraba el texto de borrador.
            var pagePublicada = $btn.attr('data-page-publicada') === '1';
            let updateOnly = $btn.attr('data-update-only') === '1' || pagePublicada;
            let cambio;
            var avisoDominio = '<p style="margin-top:12px;font-size:0.92rem;color:#555;line-height:1.45;">Después de aplicar los cambios, por caché y propagación del dominio puede tardar <strong>al menos 2 minutos</strong> en verse en el sitio público.</p>';
            if (updateOnly) {
                cambio = "¿Actualizar la página publicada con los últimos cambios? El HTML estático se regenerará." + avisoDominio;
            } else if (stat) {
                cambio = "¿Está seguro de ocultar esta página y dejarla como borrador?";
            } else {
                cambio = "¿Está seguro de publicar esta página?" + avisoDominio;
            }
            let url = '/PubPag?p='+cy+'&stat='+stat+'&t='+type;
            if (updateOnly) url += '&update=1';
            $.alert({
                title: "Advertencia",
                content: cambio,
                theme: 'modern',
                icon: 'fa-solid fa-triangle-exclamation',
                type: "red",
                buttons: {
                    Aceptar: {
                        text: 'Si, continuar',
                        btnClass: 'btn-success',
                        action: function () {
                            /* #lockscreen en el documento padre (shell editpag), no en el iframe.
                               pubpag-active sube el z-index para quedar encima de jquery-confirm al cerrarse
                               y evitar el flash en blanco entre modales. */
                            var $lock = $menu('#lockscreen');
                            if (!$lock.length) {
                                $.alert({
                                    title: 'Error',
                                    content: 'No se encontró el bloqueo de pantalla del editor. Recargue la página e intente de nuevo.',
                                    theme: 'modern',
                                    type: 'red'
                                });
                                return;
                            }
                            var $lockText = $lock.find('.textBlockScreen');
                            var defaultLockHtml = '<i class="fas fa-spinner fa-spin"></i>&nbsp;Cargando ...';
                            function resetPubLock() {
                                $lock.removeClass('lockscreen-light pubpag-active');
                                $lockText.html(defaultLockHtml);
                                $lock.hide();
                            }
                            $lockText.html(
                                '<i class="fas fa-spinner fa-spin"></i>&nbsp;Aplicando cambios y generando HTML estático…' +
                                '<br><span style="display:block;margin-top:14px;font-size:15px;font-weight:500;max-width:440px;margin-left:auto;margin-right:auto;line-height:1.45;color:#444;">Puede tardar unos momentos. No cierre esta pestaña.</span>'
                            );
                            $lock.addClass('lockscreen-light pubpag-active').show();
                            $.ajax({
                                url: url,
                                method: 'GET',
                                dataType: 'json',
                                success: function(data) {
                                    var titulo = 'Listo';
                                    var contenido = (data && data.message) ? data.message : 'Operación completada.';
                                    if (updateOnly) {
                                        titulo = 'HTML estático actualizado';
                                        contenido = (data && data.message) ? data.message : 'El HTML estático se regeneró correctamente. Los cambios ya están publicados.';
                                    } else if (!stat) {
                                        titulo = 'Página publicada';
                                        contenido = (data && data.message) ? data.message : 'La página quedó publicada y el HTML estático se generó.';
                                    } else {
                                        titulo = 'Página actualizada';
                                        contenido = (data && data.message) ? data.message : 'Los cambios se guardaron correctamente.';
                                    }
                                    var delayNote = '<p style="margin-top:14px;font-size:0.95rem;color:#555;line-height:1.45;">Por caché y propagación del dominio, los cambios pueden tardar <strong>al menos 2 minutos</strong> en verse en el sitio público.</p>';
                                    if (updateOnly || !stat) {
                                        contenido += delayNote;
                                    }
                                    /* Sin segundo modal: el overlay evita pantalla en blanco y pasa a “recargar” con animación */
                                    $lockText.html(
                                        '<div style="text-align:center;">' +
                                        '<i class="fas fa-circle-check" style="font-size:2.5rem;color:#7E2D43;margin-bottom:12px;" aria-hidden="true"></i>' +
                                        '<div style="font-size:1.12rem;font-weight:700;margin-bottom:10px;color:#2d2d2d;">' + titulo + '</div>' +
                                        '<div style="font-size:0.95rem;color:#444;">' + contenido + '</div>' +
                                        '<div class="pubpag-reload-row">' +
                                        '<i class="fas fa-sync fa-spin pubpag-reload-icon" aria-hidden="true"></i>' +
                                        '<span>Recargando editor…</span>' +
                                        '</div></div>'
                                    );
                                    $lock.addClass('lockscreen-light pubpag-active').show();
                                    setTimeout(function () {
                                        if (typeof window.__setDraftClean === 'function') {
                                            window.__setDraftClean();
                                        }
                                        // #lockscreen vive en el shell (editpag.ejs); este script corre en el iframe.
                                        // Recargar solo el iframe deja el overlay del padre colgado en "Recargando editor…".
                                        var wReload = window;
                                        if (window.top && window.top !== window) {
                                            wReload = window.top;
                                        } else if (window.parent && window.parent !== window) {
                                            wReload = window.parent;
                                        }
                                        wReload.location.reload();
                                    }, 1900);
                                },
                                error: function (xhr) {
                                    resetPubLock();
                                    var errMsg = (xhr.responseJSON && xhr.responseJSON.message)
                                        ? xhr.responseJSON.message
                                        : 'No se pudo completar la acción. Intente de nuevo.';
                                    $.alert({
                                        title: 'Error',
                                        content: errMsg,
                                        theme: 'modern',
                                        type: 'red'
                                    });
                                }
                            });
                        }
                    },
                    Cancelar: {
                        text: 'Cancelar',
                        btnClass: 'btn-alert',
                        action: function () {
                        }
                    }
                }
            });
        });
        $docParent.on('click.editpagCanvasIframe', ".editpag", function () {
            let cy = $(this).data('cy');
            var formData = new FormData();
            formData.append('cy', cy);

            fetch('/GetPostContent', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ cy: cy })
            })
                .then(response => response.json())
                .then(data => {
                    let tag = data.entrada.cat_tags && data.entrada.cat_tags[0] ? data.entrada.cat_tags[0].id_cat_tag : 0;
                    NuevaPagPrincipalModal(<%=datapagina.fk_id_cat_type_pagina%>, true);
                    $('#idpag').val(data.entrada.id_wb_pagina);
                    $('#namepag').val(data.entrada.nombre_pagina);
                    $('#url').val(data.entrada.url_safe);
                    $('#tipo_tag').val(tag);
                    $('#cont_alt').val(data.entrada.contenido_alt);
                    $('#cont_full').summernote('code', data.entrada.contenido);
                    let fecha = new Date(data.entrada.f_publicacion).toISOString().split('T')[0];
                    $('#f_pub').val(fecha);
                    let filepath=data.entrada.archivo? 'https://cdn.morena.app/'+data.entrada.archivo.file_path:'';
                    let htmlimg='<img src="'+filepath+'" class="imgcargada">';
                    $('#imgcargada').html(htmlimg);

                })
                .catch(error => {
                    console.error('Error:', error);
                });
        });
        $docCanvas.on('click', ".newSec", function (){
            let siguienteSec = $(this).parent().prev();
            let idsecprev = siguienteSec.attr('id');
            let ordenprev = siguienteSec.data('orden');
            let lastsec= parseInt($menu('#idlastsec').val());
            let newsec=lastsec+1
            let idpag = pagedata.id_wb_pagina;

            $menu('#idlastsec').val(newsec);
            $('.addSec').remove();

            $.ajax({
                url: '/agregarSeccion',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({newsec, idpag, ordenprev}),
                beforeSend(){
                    $('#lockscreen').show();
                },
                success: function(resp){
                    $('#lockscreen').hide();
                    if(resp.success){      
                        const seccion_creada = resp.id_sec;
                        const numCol = resp.num_col;
                        const orden = resp.orden;
                        const col_inicial = resp.col_inicial;

                        $("#"+idsecprev).after(`
                            <div class="row pub_seccion" id="seccion_${seccion_creada}" 
                            data-origen="new" data-sec="${seccion_creada}" data-orden="${orden}">
                                <div class="col-md-12 pub_columna active" 
                                    id="columna_${col_inicial}" 
                                    data-idcol="${col_inicial}" 
                                    data-orden="1">
                                </div>
                            </div>
                        `);
                        orderSecc();
                        $('#seccion_'+seccion_creada).trigger('click');
                    } else {
                        $.alert({
                            title: "Error",
                            content: resp.message || 'No se pudo insertar la sección.',
                            theme: 'modern',
                            type: "red"
                        });
                    }
                },
                error: function (xhr, status, err){
                    $('#lockscreen').hide();
                    console.error("Error:", status, err);
                    $.alert({
                        title: "Error al editar",
                        content: xhr.responseJSON?.message || 'Ocurrió un error inesperado.',
                        theme: 'modern',
                        type: "red"
                    });
                }
            });
        });
        $docCanvas.on('click', ".deletedSec", function (e){
            e.preventDefault();

            let sec = $menu("#idsec").val(); 
            let idpag = pagedata.id_wb_pagina;
            //// console.log("sec: "+sec + " pagina: "+idpag);

            $.alert({
                title: "Confirmar eliminación",
                content: "¿Estás seguro de que deseas eliminar esta sección? Esta acción no se puede deshacer.",
                theme: 'modern',
                icon: 'fa-solid fa-triangle-exclamation',
                type: "orange",
                buttons: {
                    confirmar: {
                        text: 'Sí, eliminar',
                        btnClass: 'btn-danger',
                        action: function () {
                            $.ajax({
                                url: '/eliminarSeccion',
                                method: 'POST',
                                data: { sec, idpag },
                                beforeSend: function() {
                                    $('#lockscreen').fadeIn();
                                },
                                success: function(resp) {
                                    $('#lockscreen').fadeOut();
                                    if(resp.success) {
                                        $('#seccion_' + sec).next('.addSec').remove();
                                        $('#seccion_' + sec).remove();
                                        orderSecc();

                                        setTimeout(() => {
                                            window.location.reload();
                                        }, 500);
                                    }
                                },
                                error: function(xhr, status, error) {
                                    $('#lockscreen').fadeOut();
                                    console.error("Error al eliminar sección:", status, error);
                                    $.alert({
                                        title: "Error al eliminar",
                                        content: xhr.responseJSON?.message || 'Ocurrió un error al eliminar la sección.',
                                        theme: 'modern',
                                        type: "red"
                                    });
                                }
                            });
                            return true;
                        }
                    },
                    cancelar: {
                        text: 'Cancelar',
                        action: function () {
                        }
                    }
                }
            });
        });
