        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        border: none;
        border-radius: 999px;
        padding: 0 48px 0 0;
        font-family: inherit;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.07em;
