        }
        var fpImg2mb = {
            labelMaxFileSize: 'Tamaño máximo: {filesize}',
            labelMaxFileSizeExceeded: 'El archivo supera el tamaño máximo permitido ({filesize}).',
            labelFileTypeNotAllowed: 'Tipo de archivo no permitido',
        };
        window.pondLogo = FilePond.create(inputLogo, Object.assign({
            allowMultiple: false,
            allowDrop: true,
            dropOnElement: true,
            dropOnPage: false,
            acceptedFileTypes: ['image/jpeg', 'image/png'],
            maxFileSize: '2MB',
            beforeAddFile: fpRechazarSiGrande,
            labelIdle: 'Arrastre aquí o <span class="filepond--label-action">seleccione</span><br><small class="text-muted">JPG o PNG, máx. 2 MB</small>',
            labelFileProcessing: 'Subiendo',
            labelFileProcessingComplete: 'Listo',
            labelTapToCancel: 'cancelar',
            labelTapToRetry: 'reintentar',
        }, fpImg2mb));
        window.pondFavicon = FilePond.create(inputFavicon, Object.assign({
            allowMultiple: false,
            allowDrop: true,
            dropOnElement: true,
            dropOnPage: false,
            acceptedFileTypes: ['image/jpeg', 'image/png'],
            maxFileSize: '2MB',
            beforeAddFile: fpRechazarSiGrande,
            labelIdle: 'Arrastre aquí o <span class="filepond--label-action">seleccione</span><br><small class="text-muted">JPG o PNG, máx. 2 MB</small>',
            labelFileProcessing: 'Subiendo',
            labelFileProcessingComplete: 'Listo',
            labelTapToCancel: 'cancelar',
            labelTapToRetry: 'reintentar',
        }, fpImg2mb));
