    function allowDropInModal() {
        var body = document.querySelector('#modalGral .modal-body');
        if (!body) return;
        body.removeEventListener('dragover', preventDefaultFiles);
        body.removeEventListener('dragenter', preventDefaultFiles);
        body.removeEventListener('drop', preventDefaultFiles);
        body.addEventListener('dragover', preventDefaultFiles, false);
        body.addEventListener('dragenter', preventDefaultFiles, false);
        body.addEventListener('drop', preventDefaultFiles, false);
    }
    function preventDefaultFiles(e) {
        if (e.dataTransfer && e.dataTransfer.types && e.dataTransfer.types.indexOf('Files') !== -1) {
            e.preventDefault();
        }
    }

