        function pollSolicitarDominio(jobId, idSysapp, retries) {
            var intentos = Number(retries) || 0;
            var maxReintentos = 30; // ~60s con intervalo de 2s
            var statusUrl = '/solicitarDominio/status/' + encodeURIComponent(jobId);
            if (idSysapp) {
                statusUrl += '?id_sysapp=' + encodeURIComponent(idSysapp);
            }
            $.ajax({
                url: statusUrl,
                type: 'GET',
                timeout: 0
            })
                .done(function (data) {
                    if (!data.success) {
                        var msgData = String((data && data.message) || '');
                        var esNoEncontradoTemporal = /No se encontró el proceso/i.test(msgData);
                        if (esNoEncontradoTemporal && intentos < maxReintentos) {
                            setTimeout(function () { pollSolicitarDominio(jobId, idSysapp, intentos + 1); }, 2000);
                            return;
                        }
                        $('#lockscreen').hide();
                        $.alert({ title: 'Atención', content: data.message || 'Error', theme: 'modern', type: 'red' });
                        return;
                    }
                    if (data.pending) {
                        setTimeout(function () { pollSolicitarDominio(jobId, idSysapp, intentos); }, 2000);
                        return;
                    }
                    $('#lockscreen').hide();
                    const modalEl = document.getElementById('modalSolicitarDominio');
                    const mi = bootstrap.Modal.getInstance(modalEl);
                    if (mi) { mi.hide(); }
                    const r = data.result || {};
                    if (r.success) {
                        $.alert({
                            title: 'Solicitud enviada',
                            content: r.message || '',
                            theme: 'modern',
                            type: 'green',
                            buttons: { Aceptar: { text: 'Aceptar', action: function () { location.reload(); } } }
                        });
                    } else {
                        $.alert({ title: 'Atención', content: r.message || 'No se pudo completar la solicitud.', theme: 'modern', type: 'red' });
                    }
                })
                .fail(function (xhr) {
                    // Fallas intermitentes de red/balanceador no deben romper el flujo si el job sigue vivo.
                    if (intentos < maxReintentos) {
                        setTimeout(function () { pollSolicitarDominio(jobId, idSysapp, intentos + 1); }, 2000);
                        return;
                    }
                    $('#lockscreen').hide();
                    const msg = (xhr.responseJSON && xhr.responseJSON.message) ? xhr.responseJSON.message : 'Error al consultar el estado del proceso.';
                    $.alert({ title: 'Error', content: msg, theme: 'modern', type: 'red' });
                });
        }

        $('#btnEnviarSolicitud').on('click', function () {
            const id = $('#modalInstanciaId').val();
            if (!id) return;
            $('#lockscreen').show();
            $.ajax({
                url: '/solicitarDominio',
                type: 'POST',
                data: { id_sysapp: id, acepta_terminos: true },
                timeout: 0
            })
                .done(function (data) {
                    if (!data.success) {
                        $('#lockscreen').hide();
                        $.alert({ title: 'Atención', content: data.message, theme: 'modern', type: 'red' });
                        return;
                    }
                    if (data.async && data.jobId) {
                        pollSolicitarDominio(data.jobId, id);
                        return;
                    }
                    $('#lockscreen').hide();
                    bootstrap.Modal.getInstance(document.getElementById('modalSolicitarDominio')).hide();
                    $.alert({
                        title: 'Solicitud enviada',
                        content: data.message,
                        theme: 'modern',
                        type: 'green',
                        buttons: { Aceptar: { text: 'Aceptar', action: function () { location.reload(); } } }
                    });
                })
                .fail(function (xhr) {
                    $('#lockscreen').hide();
                    const msg = (xhr.responseJSON && xhr.responseJSON.message) ? xhr.responseJSON.message : 'Error al enviar solicitud';
                    $.alert({ title: 'Error', content: msg, theme: 'modern', type: 'red' });
                });
        });

        $(document).on('click', '.solicitar-baja', function () {
