        $('#cont_alt').val($(this).data('app_desc'));
        $('#cargadolg').html('<a href="'+$(this).data('logo')+'" target="_blank" class="aimg">'+$(this).data('logo')+'</a>');
        $('#cargadofv').html('<a href="'+$(this).data('favicon')+'" target="_blank" class="aimg">'+$(this).data('favicon')+'</a>');

        aplicarCamposInstanciaSoloLecturaResponsable();
        setTimeout(function() {
            initFilePondInstancia();
            allowDropInModal();
            initResponsableIdSelect2();
            $('#responsable_id').off('change.instResp').on('change.instResp', aplicarEstadoResponsableInstancia);
            $('#responsable_crear_nuevo').off('change.instResp').on('change.instResp', aplicarEstadoResponsableInstancia);
            aplicarEstadoResponsableInstancia();
        }, 50);
        const urlInput = document.getElementById('url');
        if (urlInput) {
            urlInput.addEventListener('keyup', updatePreviewUrl);
            updatePreviewUrl();
        }
    }

    /** Misma regla que el módulo de usuarios (18 a 20 caracteres, formato CURP). */
    function isValidCurpInstancia(val) {
        var s = String(val || '').trim().toUpperCase();
        if (s.length < 18 || s.length > 20 || s.indexOf('@') !== -1) return false;
        return /^[A-Z]{4}\d{6}[A-Z]{6}[A-Z0-9]\d[A-Z0-9]{0,2}$/.test(s);
    }

    function CrearPag (){
        const form = document.getElementById('newpage');
        const isCreate = (parseInt($('#id_edit').val(), 10) || 0) === 0;

        if (!form.checkValidity()) {
            form.classList.add('was-validated');
            return;
        }

        var namepag = $('#namepag').val();
        var id_edit = $('#id_edit').val();
        var url = normalizeSubdomain($('#url').val() || '');
        var titlepag = $('#titlepag').val();
        var cont_alt = $('#cont_alt').val();

        if (!url) {
            $.alert({
                title: 'Atención',
                content: 'Escribe un subdominio válido.',
                theme: 'modern',
                icon: 'fa-solid fa-triangle-exclamation',
                type: 'red'
            });
            return;
        }

        var formData = new FormData();
        formData.append('id_edit', id_edit);
        formData.append('namepag', namepag);
        formData.append('url', url);
        formData.append('cont_alt', cont_alt);
        formData.append('titlepag', titlepag);
        formData.append('fk_id_sysapp_type', $('#fk_id_sysapp_type').val());
        formData.append('responsable_id', $('#responsable_id').val() || '');
        formData.append('responsable_crear_nuevo', $('#responsable_crear_nuevo').is(':checked') ? 'true' : 'false');
        formData.append('responsable_nombre', $('#responsable_nombre').val() || '');
        formData.append('responsable_primer_apellido', $('#responsable_primer_apellido').val() || '');
        formData.append('responsable_segundo_apellido', $('#responsable_segundo_apellido').val() || '');
        formData.append('responsable_email', $('#responsable_email').val() || '');
        formData.append('responsable_curp', $('#responsable_curp').val() || '');
        formData.append('responsable_fk_id_estado', $('#responsable_fk_id_estado').val() || '');

        var archivo1 = null, archivo2 = null;
        if (window.pondFavicon) {
            var f = window.pondFavicon.getFile();
            if (f && f.file) archivo1 = f.file;
        }
        if (window.pondLogo) {
            var f = window.pondLogo.getFile();
            if (f && f.file) archivo2 = f.file;
        }
        if (archivo1) formData.append('cargar-favicon', archivo1);
        if (archivo2) formData.append('cargar-logo', archivo2);

        if (isCreate) {
            const crearNuevo = $('#responsable_crear_nuevo').is(':checked');
            if (!crearNuevo && !$('#responsable_id').val()) {
                $.alert({
                    title: 'Atención',
                    content: 'Selecciona un usuario responsable.',
                    theme: 'modern',
                    icon: 'fa-solid fa-triangle-exclamation',
                    type: 'red'
                });
                return;
            }
            var curpNorm = sanitizeCurpValueInstancia($('#responsable_curp').val());
            if (crearNuevo && (!window._instanciaResponsableCurpValidada || curpNorm !== window._instanciaResponsableCurpValidada)) {
                $.alert({
                    title: 'Atención',
                    content: 'Debes validar la CURP con el botón «VALIDAR CURP» antes de crear la instancia.',
                    theme: 'modern',
                    icon: 'fa-solid fa-triangle-exclamation',
                    type: 'red'
                });
                return;
            }
            if (crearNuevo && (!$('#responsable_nombre').val() || !$('#responsable_email').val() || !$('#responsable_curp').val() || !$('#responsable_fk_id_estado').val())) {
                $.alert({
                    title: 'Atención',
                    content: 'Completa nombre, correo, CURP y entidad federativa del nuevo responsable.',
                    theme: 'modern',
                    icon: 'fa-solid fa-triangle-exclamation',
                    type: 'red'
                });
                return;
            }
            if (crearNuevo && !isValidCurpInstancia($('#responsable_curp').val())) {
                $.alert({
                    title: 'Atención',
                    content: 'La CURP no es válida: debe tener entre 18 y 20 caracteres con formato oficial (no uses el correo ni otros textos en este campo).',
                    theme: 'modern',
                    icon: 'fa-solid fa-triangle-exclamation',
                    type: 'red'
                });
                return;
            }
        } else {
            if (!$('#responsable_id').val()) {
                $.alert({
                    title: 'Atención',
                    content: 'Selecciona un usuario responsable.',
                    theme: 'modern',
                    icon: 'fa-solid fa-triangle-exclamation',
                    type: 'red'
                });
                return;
            }
        }

        $('#lockscreen').show()
        fetch('/CreateInst', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { Accept: 'application/json' },
            body: formData,
        })
            .then(async (response) => {
                const ct = response.headers.get('content-type') || '';
                if (!ct.includes('application/json')) {
                    const txt = await response.text();
                    throw new Error(
                        'Respuesta inesperada del servidor (' +
                            response.status +
                            '). ¿Sesión vencida? Vuelve a iniciar sesión. ' +
                            (txt && txt.length < 200 ? txt : '')
                    );
                }
                const data = await response.json();
                if (!response.ok) {
                    throw new Error(
                        (data && data.message) ||
                            'Solicitud rechazada (' + response.status + '). Vuelve a intentar o inicia sesión de nuevo.'
                    );
                }
                return data;
            })
            .then(data => {

                $('#lockscreen').hide()
                if(data.success){
                    $.alert({
                        title: "Se guardó correctamente",
                        content: "Se ha guardado la instancia correctamente",
                        theme: 'modern',
                        icon: 'fa-solid fa-check',
                        type: "green",
                        buttons: {
                            Aceptar: {
                                text: 'Aceptar',
                                btnClass: 'btn-success',
                                action: function () {
                                        window.location.reload();
                                }
                            }
                        }
                    });
                } else {
                    $.alert({
                        title: "Advertencia",
                        content: data.message,
                        theme: 'modern',
                        icon: 'fa-solid fa-triangle-exclamation',
                        type: "red"
                    });
                }
            })
            .catch(error => {
                $('#lockscreen').hide();
                console.error('Error:', error);
                $.alert({
                    title: 'Error',
                    content: '<strong>' + (error && error.message ? error.message : 'No se pudo guardar la instancia.') + '</strong>',
                    theme: 'modern',
                    icon: 'fa-solid fa-triangle-exclamation',
                    type: 'red'
                });
            });

    }

    function normalizeSubdomain(value, options = {}) {
        const allowTrailingHyphen = options.allowTrailingHyphen === true;
        let normalized = String(value || '')
            .toLowerCase()
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '')
            .replace(/\s+/g, '-')
            .replace(/[^a-z0-9-]/g, '')
            .replace(/-+/g, '-');
        if (allowTrailingHyphen) {
            normalized = normalized.replace(/^-+/, '');
        } else {
            normalized = normalized.replace(/^-+|-+$/g, '');
        }
        return normalized;
    }

    function composeMorenaDomain(subdomain) {
        if (!subdomain) return '';
        return `${subdomain}.morena.org`;
    }

    function updatePreviewUrl() {
        const input = document.getElementById('url');
        const preview = document.getElementById('preview-url');
        let urlValue = normalizeSubdomain(input.value, { allowTrailingHyphen: true });
        input.value = urlValue;
        const fullUrl = composeMorenaDomain(urlValue);

        if (preview) {
            preview.textContent = fullUrl;
            preview.title = fullUrl;
        }
    }
</script>