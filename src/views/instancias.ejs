    function aplicarEstadoResponsableInstancia() {
        /** Evita recursión infinita: trigger('change') y Select2 vuelven a invocar esta función. */
        if (window._instanciaResponsableEvitarRecursion) return;

        var crearNuevo = $('#responsable_crear_nuevo').is(':checked');
        var idVal = $('#responsable_id').val();
        var tieneUsuarioLista = idVal !== undefined && idVal !== null && String(idVal).trim() !== '';

        /**
         * Importante: evaluar «crear nuevo» ANTES que «hay usuario en el listado».
         * Si no, al marcar el check con un usuario ya elegido en Select2, se tomaba
         * tieneUsuarioLista === true, se desmarcaba el check y nunca se mostraba el formulario.
         */
        if (crearNuevo) {
            $('#responsable_crear_nuevo').prop('disabled', false);
            var $rid = $('#responsable_id');
            $rid.prop('disabled', false);
            window._instanciaResponsableEvitarRecursion = true;
            try {
                if ($rid.data('select2')) {
                    $rid.val(null).trigger('change');
                } else {
                    $rid.val('').trigger('change');
                }
                $rid.prop('disabled', true);
            } finally {
                /* select2:clear puede dispararse tras este bloque; el flag sigue true un tick */
                setTimeout(function () {
                    window._instanciaResponsableEvitarRecursion = false;
                }, 0);
            }
            $('.responsable-nuevo').removeClass('d-none');
            if (!window._instanciaResponsableCurpValidada) {
                lockResponsableInstanciaNuevoDatos();
            } else {
                unlockResponsableInstanciaNuevoDatos(window._instanciaResponsableExistente);
            }
            syncResponsableSelect2Disabled();
            return;
        }

        if (tieneUsuarioLista) {
            $('#responsable_crear_nuevo').prop('checked', false).prop('disabled', true);
            $('.responsable-nuevo').addClass('d-none');
            limpiarCamposResponsableNuevoInstancia();
            $('#responsable_id').prop('disabled', false);
            syncResponsableSelect2Disabled();
            return;
        }

        $('#responsable_crear_nuevo').prop('disabled', false);
        $('#responsable_id').prop('disabled', false);
        $('.responsable-nuevo').addClass('d-none');
        limpiarCamposResponsableNuevoInstancia();
        syncResponsableSelect2Disabled();
    }

