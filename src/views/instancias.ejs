    (function initPaginacionInstancias() {
        const CARDS_PER_PAGE = 6;
        const cards = document.querySelectorAll('#instanciasCards .instancia-card');
        const nav = document.getElementById('paginationHosting');
        if (!nav || cards.length === 0) return;
        if (cards.length <= CARDS_PER_PAGE) return;

        let currentPage = 1;
        const totalPages = Math.ceil(cards.length / CARDS_PER_PAGE);

        function render() {
            const start = (currentPage - 1) * CARDS_PER_PAGE;
            const end = start + CARDS_PER_PAGE;
            cards.forEach((card, i) => {
                card.style.display = (i >= start && i < end) ? '' : 'none';
            });

            let numbersHtml = '';
            for (let p = 1; p <= totalPages; p++) {
                numbersHtml += `<button type="button" class="inst-page-btn ${p === currentPage ? 'is-active' : ''}" data-page="${p}">${p}</button>`;
            }

            nav.innerHTML = `
                <div class="inst-pagination-inner">
                    <button type="button" class="inst-page-btn inst-page-arrow" ${currentPage === 1 ? 'disabled' : ''} data-page="prev">
                        <i class="fa-solid fa-chevron-left"></i>
                    </button>
                    <div class="inst-page-numbers">
                        ${numbersHtml}
                    </div>
                    <button type="button" class="inst-page-btn inst-page-arrow" ${currentPage === totalPages ? 'disabled' : ''} data-page="next">
                        <i class="fa-solid fa-chevron-right"></i>
                    </button>
                </div>
                <p class="inst-pagination-meta">
                    Mostrando ${start + 1}–${Math.min(end, cards.length)} de ${cards.length} instancias
                </p>
            `;

            nav.querySelectorAll('.inst-page-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const p = this.dataset.page;
                    if (p === 'prev' && currentPage > 1) currentPage--;
                    else if (p === 'next' && currentPage < totalPages) currentPage++;
                    else if (!isNaN(parseInt(p, 10))) currentPage = parseInt(p, 10);
                    render();
                });
            });
        }
        render();
    })();

