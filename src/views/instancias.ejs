<%- include('partials/footerNoMx'); %>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<script>
    /** Perfil «Responsable de instancia»: no crea instancias; en edición solo ve (no edita) nombre, subdominio y tipo. */
    var ES_RESPONSABLE_INSTANCIA = <%= (typeof es_responsable_instancia !== 'undefined' && es_responsable_instancia) ? 'true' : 'false' %>;

    /** Tras «Validar CURP» en nueva instancia; si el usuario edita la CURP, se invalida. */
    window._instanciaResponsableCurpValidada = '';
    window._instanciaResponsableExistente = false;

    /** Misma máscara por posición que usuarios (LLLLDDDDDDLLLLLLAD). */
    function sanitizeCurpValueInstancia(raw) {
        var chars = String(raw || '').toUpperCase().replace(/[^A-Z0-9]/g, '').split('');
        var mask = ['L','L','L','L','D','D','D','D','D','D','L','L','L','L','L','L','A','D','A','A'];
        var out = [];
        var i = 0;
        while (i < chars.length && out.length < mask.length) {
            var ch = chars[i];
            var slot = mask[out.length];
            var ok =
                (slot === 'L' && /[A-Z]/.test(ch)) ||
                (slot === 'D' && /[0-9]/.test(ch)) ||
                (slot === 'A' && /[A-Z0-9]/.test(ch));
            if (ok) out.push(ch);
            i++;
        }
        return out.join('');
    }
    function sanitizeResponsableInstanciaCurpField(el) {
        if (!el) return;
        el.value = sanitizeCurpValueInstancia(el.value);
    }
    function lockResponsableInstanciaNuevoDatos() {
        $('#responsable_nombre, #responsable_primer_apellido, #responsable_segundo_apellido, #responsable_email, #responsable_fk_id_estado')
            .prop('disabled', true)
            .addClass('bg-light');
    }
    function unlockResponsableInstanciaNuevoDatos(existingUser) {
        var ex = existingUser === true;
        $('#responsable_fk_id_estado').prop('disabled', false).removeClass('bg-light');
        $('#responsable_nombre, #responsable_primer_apellido, #responsable_segundo_apellido, #responsable_email').prop('disabled', false);
        $('#responsable_nombre, #responsable_primer_apellido, #responsable_segundo_apellido').prop('readonly', ex);
        $('#responsable_email').prop('readonly', ex);
        if (ex) {
            $('#responsable_nombre, #responsable_primer_apellido, #responsable_segundo_apellido, #responsable_email').addClass('bg-light');
        } else {
            $('#responsable_nombre, #responsable_primer_apellido, #responsable_segundo_apellido, #responsable_email').removeClass('bg-light');
        }
    }
    function resetResponsableInstanciaCurpGate() {
        window._instanciaResponsableCurpValidada = '';
        window._instanciaResponsableExistente = false;
        $('#responsable_curp').val('').prop('readonly', false).removeClass('bg-light');
        $('#responsable_nombre, #responsable_primer_apellido, #responsable_segundo_apellido, #responsable_email').val('').prop('readonly', false);
        $('#responsable_fk_id_estado').val('').prop('disabled', false).removeClass('bg-light');
        lockResponsableInstanciaNuevoDatos();
    }
    function instanciaResponsableCurpInvalidateIfStale() {
        if (!$('#responsable_crear_nuevo').is(':checked')) return;
        var cur = sanitizeCurpValueInstancia($('#responsable_curp').val());
        $('#responsable_curp').val(cur);
        if (window._instanciaResponsableCurpValidada && cur !== window._instanciaResponsableCurpValidada) {
            window._instanciaResponsableCurpValidada = '';
            window._instanciaResponsableExistente = false;
            lockResponsableInstanciaNuevoDatos();
            $('#responsable_nombre, #responsable_primer_apellido, #responsable_segundo_apellido, #responsable_email').val('');
            $('#responsable_fk_id_estado').val('').prop('disabled', false).removeClass('bg-light');
        }
    }
    function applyInstanciaResponsableCurpResult(data) {
        var ex = data.existingUser === true;
        var d = data.data || {};
        var curpVal = d.curp || sanitizeCurpValueInstancia($('#responsable_curp').val());
        $('#responsable_curp').val(curpVal);
        window._instanciaResponsableCurpValidada = curpVal;
        window._instanciaResponsableExistente = ex;
        $('#responsable_nombre').val(d.nombre || '');
        $('#responsable_primer_apellido').val(d.primerA || '');
        $('#responsable_segundo_apellido').val(d.segundoA || '');
        $('#responsable_email').val(d.correo || '');
        var rawEst = d.fk_id_estado;
        var hasEstSel = rawEst != null && rawEst !== '' && !Number.isNaN(Number(rawEst));
        if (hasEstSel) {
            $('#responsable_fk_id_estado').val(String(Number(rawEst)));
        } else {
            $('#responsable_fk_id_estado').val('');
        }
        unlockResponsableInstanciaNuevoDatos(ex);
        if (ex && hasEstSel) {
            $('#responsable_fk_id_estado').prop('disabled', true).addClass('bg-light');
        } else {
            $('#responsable_fk_id_estado').prop('disabled', false).removeClass('bg-light');
        }
    }
    function clearInstanciaResponsableCurpRejected() {
        window._instanciaResponsableCurpValidada = '';
        window._instanciaResponsableExistente = false;
        lockResponsableInstanciaNuevoDatos();
        $('#responsable_nombre, #responsable_primer_apellido, #responsable_segundo_apellido, #responsable_email').val('').prop('readonly', false);
        $('#responsable_fk_id_estado').val('').prop('disabled', false).removeClass('bg-light');
    }
    function validarResponsableInstanciaCurp() {
        if (!$('#responsable_crear_nuevo').is(':checked')) return;
        var CURP = sanitizeCurpValueInstancia($('#responsable_curp').val());
        $('#responsable_curp').val(CURP);
        var curpRegex = /^[A-Z]{4}[0-9]{6}[A-Z]{6}[A-Z0-9][0-9][A-Z0-9]{0,2}$/;
        if (!CURP || !curpRegex.test(CURP)) {
            $.alert({
                title: 'Advertencia',
                content: 'Introduce una CURP válida (18 a 20 caracteres, formato oficial).',
                theme: 'modern',
                icon: 'fa-solid fa-triangle-exclamation',
                type: 'red'
            });
            return;
        }
        var param = 'curp=' + encodeURIComponent(CURP);
        fetch('/NuevoUsuarioValidarCurp', {
            method: 'POST',
            body: param,
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                if (data.success) {
                    var jc = $.alert({
                        title: 'Correcto',
                        content: '<strong>' + data.msg + '</strong>',
                        theme: 'modern',
                        icon: 'fa-solid fa-circle-check',
                        type: 'blue',
                        onOpen: function () { setTimeout(function () { jc.close(); }, 4000); }
                    });
                    applyInstanciaResponsableCurpResult(data);
                } else {
                    if (data.alreadyInCms === true) {
                        clearInstanciaResponsableCurpRejected();
                    }
                    $.alert({
                        title: 'Advertencia',
                        content: '<strong>' + data.msg + '</strong>',
                        theme: 'modern',
                        icon: 'fa-solid fa-triangle-exclamation',
                        type: 'blue'
                    });
                }
            })
            .catch(function () {
                $.alert({
                    title: 'Error',
                    content: '<strong>No se pudo validar la CURP.</strong>',
                    theme: 'modern',
                    icon: 'fa-solid fa-triangle-exclamation',
                    type: 'red'
                });
            });
    }

