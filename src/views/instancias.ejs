    function initFilePondInstancia() {
        var inputLogo = document.getElementById('cargar-logo');
        var inputFavicon = document.getElementById('cargar-favicon');
        if (!inputLogo || !inputFavicon) return;
        var fpMaxBytes = 2 * 1024 * 1024;
        function fpRechazarSiGrande(item) {
            var sz = item && (typeof item.fileSize === 'number' ? item.fileSize : (item.file && item.file.size));
            if (sz > fpMaxBytes) {
                $.alert({
                    title: 'Archivo demasiado grande',
                    content: 'El tamaño máximo permitido es 2 MB.',
                    theme: 'modern',
                    type: 'red',
                });
