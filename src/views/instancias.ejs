<div id="templateDer">

    <div class="limit-home">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8 col-sm-12 col-12  t-c">
                <h5 class="tit-seccion guinda_t">Administrador<b> de Instancias</b></h5>
                <div class="l-div">
                    <label class="borde-izq oroMorena"><span class="diagonal gris_t"></span></label>
                    <label class="borde-der solid_bg"><span></span></label>
                </div>
            </div>
            <div class="subenun ma-t2">
                <p class="subtit">
                    En esta sección se crean nuevas páginas web. Primero configure el dominio deseado, marque las páginas como completadas y solicite el dominio al área de Infraestructura Tecnológica para poder publicar.
                </p>
                <span></span>
            </div>
        </div>
    </div>

    <div class="container mt-4">
        <div class="row mb-3">
            <% if (typeof es_responsable_instancia === 'undefined' || !es_responsable_instancia) { %>
            <div class="col-auto mb-3">
                <button class="btnGral guinda_t cargapagina" type="button" id="crear_pagaPrincipal" data-id="0">
                    <p>NUEVA INSTANCIA</p>
                    <div class="btnIcon">
                        <div class="boxIcon guinda"><img src="assets/img/AGREGAR.svg"></div>
                        <span class="s-guinda"></span>
                    </div>
                </button>
            </div>
            <% } %>
        </div>

        <div class="instancias-cards" id="instanciasCards">
            <%
            const ESTATUS = { 0: 'Pendiente', 1: 'Solicitado', 2: 'Con dominio', 3: 'Rechazado', 4: 'Baja solicitada', 5: 'Baja procesada' };
            for (const doc of instanciaslist) {
                const DateFor = doc.f_reg ? doc.f_reg.toLocaleString('en-CA', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', hour12: false }) : '';
                const tipo = doc.fk_id_sysapp_type === 2 ? 'Nacional' : 'Secundaria';
                const tieneDominio = doc.fk_id_estatus_hosting === 2;
                const dominioMostrar = tieneDominio ? (doc.dominio_asignado || doc.urluri) : (doc.urluri || 'Sin dominio');
                const paginasCompletadas = !!doc.paginas_completadas;
                // Evitar mostrar "Solicitar dominio" cuando la instancia está en baja solicitada/procesada.
                const puedeSolicitar = paginasCompletadas
                    && ![1, 2, 4, 5].includes(Number(doc.fk_id_estatus_hosting));
                const yaSolicitado = doc.fk_id_estatus_hosting === 1;
                const bloquearCheckbox = yaSolicitado || tieneDominio;
                const publicada = doc.publicada === true || doc.publicada === 1;
                const bajaProcesada = doc.fk_id_estatus_hosting === 5;
                const puedeEliminar = !publicada || bajaProcesada;
            %>
            <div class="instancia-card" data-id="<%= doc.id_sysapp %>">
                <div class="instancia-card-inner">
                    <div class="instancia-card-inner-wrap">
                    <div class="instancia-card-header">
                        <img src="<%= doc.app_logo || '/assets/img/default_morena.png' %>" alt="Logo" class="instancia-card-logo">
                        <div>
                            <h3 class="instancia-card-title"><%- doc.sysapp_name %></h3>
                            <span class="instancia-card-type"><%= tipo %> · <%= DateFor %></span>
                        </div>
                    </div>
                    <p class="instancia-card-meta"><%- doc.app_legend %></p>
                    <% if (doc.responsable_nombre || doc.responsable_entidad) { %>
                    <p class="instancia-card-responsable">
                        <span class="text-muted">Responsable:</span>
                        <%= doc.responsable_nombre || '—' %>
                        <% if (doc.responsable_entidad) { %>
                            <span class="text-muted"> · </span><%= doc.responsable_entidad %>
                        <% } %>
                    </p>
                    <% } %>
                    <div class="instancia-card-domain <%= tieneDominio ? '' : 'placeholder' %>" title="<%- dominioMostrar %>"><%- dominioMostrar %></div>
                    <% if (doc.fk_id_estatus_hosting === 0) { %>
                      <div class="instancia-badge-pendiente"><%= ESTATUS[0] %> de solicitud de dominio</div>
                    <% } else if (doc.fk_id_estatus_hosting === 4) { %>
                      <div class="instancia-badge-pendiente">
                        <%= ESTATUS[4] %> (procesa la baja en <b>Hosting</b> para habilitar la eliminación)
                      </div>
                    <% } else if (doc.fk_id_estatus_hosting === 5) { %>
                      <div class="instancia-badge-pendiente"><%= ESTATUS[5] %> (ya puedes eliminar)</div>
                    <% } %>
                    </div>
                </div>
                <div class="instancia-card-body">
                    <div class="instancia-checkbox-wrap">
                        <input type="checkbox" class="form-check-input chk-completadas" id="chk-<%= doc.id_sysapp %>"
                               data-id="<%= doc.id_sysapp %>"
                               <%= paginasCompletadas ? 'checked' : '' %>
                               <%= bloquearCheckbox ? 'disabled' : '' %>>
                        <label for="chk-<%= doc.id_sysapp %>">Páginas completadas</label>
                    </div>
                    <div class="instancia-card-actions">
                        <% if (tieneDominio) { %>
                            <span class="badge bg-success">Con dominio</span>
                            <button class="btnAct oro btn-sm solicitar-baja" data-id="<%= doc.id_sysapp %>" data-hover="Solicitar baja">Baja</button>
                        <% } else if (yaSolicitado) { %>
                            <span class="instancia-badge-solicitada">Solicitud enviada a Infraestructura Tecnológica</span>
                        <% } else if (puedeSolicitar) { %>
                            <button class="btn-solicitar-dominio" data-id="<%= doc.id_sysapp %>" data-name="<%- doc.sysapp_name %>" data-hover="Solicitar dominio" title="Solicitar dominio">
                                <i class="fa-solid fa-globe"></i> Solicitar dominio
                            </button>
                        <% } %>
                        <button class="btnAct oro editentrance btn-sm" data-idtype="5" data-namepag="<%= doc.sysapp_name %>" data-url="<%= doc.urluri %>" data-titlepag="<%= doc.titlepag %>" data-app_legend="<%= doc.app_legend %>" data-app_desc="<%= doc.app_desc %>" data-id="<%= doc.id_sysapp %>" data-fk-id-sysapp-type="<%= doc.fk_id_sysapp_type %>" data-responsable-id="<%= doc.responsable_id_user != null && doc.responsable_id_user !== '' ? doc.responsable_id_user : '' %>" data-logo="<%= doc.app_logo %>" data-favicon="<%= doc.app_favicon %>" data-hover="EDITAR">
                            <i class="fa-regular fa-pen-to-square"></i>
                        </button>
                        <% if (puedeEliminar) { %>
                            <button class="btnAct guinda deletepag btn-sm" data-id="<%= doc.id_sysapp %>" data-hover="BORRAR"><i class="fa-solid fa-trash"></i></button>
                        <% } %>
                    </div>
                </div>
            </div>
            <% } %>
        </div>

        <nav class="mt-4 d-flex justify-content-center align-items-center flex-column" id="paginationHosting" aria-label="Paginación de instancias"></nav>
    </div>

</div>

