<%- include('partials/footerNoMx'); %>

<script>
    //MODAL NUEVA PÁGINA PRINCIPAL
    $('#crear_pagaPrincipal').on('click', NuevaPagPrincipalModal);

    function NuevaPagPrincipalModal(){
        limpieza_modalGral();
        modalGral_addTit('NUEVA PÁGINA PRINCIPAL');
        modalGral_addSubtit('Completa la información que se solicita.');
        modalGral_bodyAppend(getHtmlTemplate('NuevapagPrincipal'));
        modalGral_addFooter(
            `<button class="btnGral guinda_t" type="button" data-bs-dismiss="modal">
                <p>CANCELAR</p>
                <div class="btnIcon">
                    <div class="boxIcon guinda"><img src="assets/img/TIMES.svg"></div>
                    <span class="s-guinda"></span>
                </div>
            </button>
            <a href="/nueva_pagina_principal" class="btnGral verde_t">
                <p>CREAR</p>
                <div class="btnIcon">
                    <div class="boxIcon verde"><img src="assets/img/GUARDAR.svg"></div>
                    <span class="s-verde"></span>
                </div>
            </a>`
        );

        // $('#').on('click', funcionNombre);
        (new bootstrap.Modal($('#modalGral')[0],{backdrop:"static",keyboard:false})).show();
    }

