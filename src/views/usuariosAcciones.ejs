<%- include('partials/footerNoMx'); %>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
    const USUARIOS_SCOPE = '<%= usuarios_scope %>';
    let dataTableOptions={
        language:{
            info:       'Registro _START_ al  _END_ de _TOTAL_ , (Página _PAGE_ de _PAGES_ Páginas)',
            paginate: {
                first:      'Primero',
                last:       'Último',
                next:       'Siguiente',
                previous:   'Anterior'
            },
            lengthMenu: 'Ver _MENU_ Registros por página',
            search:     'Buscar por nombre o CURP:',
            zeroRecords:'No existe registro'
        }
    };
    $(document).ready(()=>{
        $('#Tabla_UsuariosAdministracion').dataTable(dataTableOptions);
    });

    $('#NuevoUsuarioButton').on('click',NuevoUsuarioModal);



    function restaurar(){
        $.alert({
            title: "CAMBIO DE PERMISOS",
            content: '<strong>Confirma que deseas restaurar todos los permisos de acuerdo al tipo de usuario seleccionado, se seleccionarán los permisos sin embargo deberás dar guardar para hacer permanente el cambio.</strong>',
            theme: 'modern',
            icon: 'fa-solid fa-circle-check',
            type: "blue",
            buttons: {
                Aceptar: {
                    text: 'Aceptar',
                    btnClass: 'btn-success',
                    action: function () {
                        $('input[name="EditarPermisos_submodulo"]').each(function () {
                            if ($(this).data('perm') === 'user') {
                                $(this).prop('checked', true);
                            } else {
                                $(this).prop('checked', false);
                            }
                        });
                        validaEncabezadoPermiso();
                    }
                },
                Cancelar: {
                    text: 'Cancelar',
                    btnClass: 'btn-alert',
                    action: function () {
                    }
                }
            }
        });
    }
    /** Limpia bloqueo de entidad al abrir el modal (alcance global e instancia). */
    function resetNuevoUsuarioEntidadFieldState() {
        var $f = $('#NuevoUsuarioModal_Form');
        if (!$f.length) return;
        $f.find('#NuevoUsuarioEntidad').prop('disabled', false).removeClass('bg-light').attr('name', 'NuevoUsuarioEntidad');
        $f.find('#NuevoUsuarioEntidadMirror').removeAttr('name').val('');
    }
    function NuevoUsuarioModal(){
        limpieza_modalGral();
        modalGral_addTit('NUEVO USUARIO');
        if (typeof USUARIOS_SCOPE !== 'undefined' && USUARIOS_SCOPE === 'instance') {
            modalGral_addSubtit(
                'Usuarios de tus instancias asignadas: valida la CURP primero. Si ya existe en el sistema, se completarán nombre, correos y estado; cuando el estado venga del registro no podrá editarse. El mensaje de validación correcta permanece visible unos segundos.'
            );
        } else {
            modalGral_addSubtit('Completa la información que se solicita.');
        }
        modalGral_bodyAppend(getHtmlTemplate('NuevoUsuarioModalTemplate'));
        modalGral_addFooter(
            `<button class="btnGral guinda_t" type="button" data-bs-dismiss="modal">
                    <p>CANCELAR</p>
                    <div class="btnIcon">
                        <div class="boxIcon guinda"><img src="assets/img/TIMES.svg"></div>
                        <span class="s-guinda"></span>
                    </div>
                </button>
                <button class="btnGral verde_t" type="button" id="NuevoUsuario_guardar">
                    <p>GUARDAR</p>
                    <div class="btnIcon">
                        <div class="boxIcon verde"><img src="assets/img/GUARDAR.svg"></div>
                        <span class="s-verde"></span>
                    </div>
                </button>`
        );
        $('#NuevoUsuario_guardar').on('click',NuevoUsuario);
        (new bootstrap.Modal($('#modalGral')[0], { backdrop: 'static', keyboard: false })).show();
        resetNuevoUsuarioEntidadFieldState();
        const scope = $('#NuevoUsuarioModal_Form #usuarios_scope').val();
        if (scope === 'instance') {
            $('#NuevoUsuarioTipo').val('13');
        }
    }
    function applyNuevoUsuarioCurpResult(data) {
        const ex = data.existingUser === true;
        const d = data.data || {};
        const curpVal = d.curp || $('#modalGral #NuevoUsuarioCurp').val();
        $('#NuevoUsuarioModal_Form #NuevoUsuarioCurpValidada').val(curpVal);
        $('#NuevoUsuarioModal_Form #NuevoUsuarioNombre').val(d.nombre || '').prop('readonly', ex);
        $('#NuevoUsuarioModal_Form #NuevoUsuarioPrimerA').val(d.primerA || '').prop('readonly', ex);
        $('#NuevoUsuarioModal_Form #NuevoUsuarioSegundoA').val(d.segundoA || '').prop('readonly', ex);
        if (ex && d.correo) {
            $('#NuevoUsuarioModal_Form #NuevoUsuarioCorreo').val(d.correo).prop('readonly', true);
            $('#NuevoUsuarioModal_Form #NuevoUsuarioCorreoConfirmar').val(d.correo).prop('readonly', true);
        } else {
            $('#NuevoUsuarioModal_Form #NuevoUsuarioCorreo').prop('readonly', false);
            $('#NuevoUsuarioModal_Form #NuevoUsuarioCorreoConfirmar').prop('readonly', false);
        }
        if (!ex) {
            $('#NuevoUsuarioModal_Form #NuevoUsuarioNombre').prop('readonly', false);
            $('#NuevoUsuarioModal_Form #NuevoUsuarioPrimerA').prop('readonly', false);
            $('#NuevoUsuarioModal_Form #NuevoUsuarioSegundoA').prop('readonly', false);
        }
        var rawEst = d.fk_id_estado;
        var $ent = $('#NuevoUsuarioModal_Form #NuevoUsuarioEntidad');
        var $mir = $('#NuevoUsuarioModal_Form #NuevoUsuarioEntidadMirror');
        var hasEst = rawEst != null && rawEst !== '' && !Number.isNaN(Number(rawEst));
        if (hasEst) {
            $ent.val(String(Number(rawEst)));
        } else {
            $ent.val('');
        }
        if (ex && hasEst) {
            $ent.prop('disabled', true).addClass('bg-light');
            $mir.val($ent.val()).attr('name', 'NuevoUsuarioEntidad');
            $ent.removeAttr('name');
        } else {
            $ent.prop('disabled', false).removeClass('bg-light');
            if (!$ent.attr('name')) {
                $ent.attr('name', 'NuevoUsuarioEntidad');
            }
            $mir.removeAttr('name').val('');
        }
        $('#NuevoUsuarioModal_Form').data('existingUser', ex);
    }
    function clearNuevoUsuarioResolvedFields(){
        $('#NuevoUsuarioModal_Form #NuevoUsuarioCurpValidada').val('');
        $('#NuevoUsuarioModal_Form #NuevoUsuarioNombre').val('').prop('readonly', true);
        $('#NuevoUsuarioModal_Form #NuevoUsuarioPrimerA').val('').prop('readonly', true);
        $('#NuevoUsuarioModal_Form #NuevoUsuarioSegundoA').val('').prop('readonly', true);
        $('#NuevoUsuarioModal_Form #NuevoUsuarioCorreo').val('').prop('readonly', false);
        $('#NuevoUsuarioModal_Form #NuevoUsuarioCorreoConfirmar').val('').prop('readonly', false);
        $('#NuevoUsuarioModal_Form #NuevoUsuarioEntidad').val('');
        resetNuevoUsuarioEntidadFieldState();
        $('#NuevoUsuarioModal_Form').data('existingUser', false);
    }
    // CURP base por posición: LLLLDDDDDDLLLLLLAD (18) + hasta 2 alfanuméricos extra.
    // L = letra [A-Z], D = dígito [0-9], A = alfanumérico [A-Z0-9]
    function sanitizeCurpValue(raw) {
        const chars = String(raw || '').toUpperCase().replace(/[^A-Z0-9]/g, '').split('');
        const mask = ['L','L','L','L','D','D','D','D','D','D','L','L','L','L','L','L','A','D','A','A'];
        const out = [];
        let i = 0;
        while (i < chars.length && out.length < mask.length) {
            const ch = chars[i];
            const slot = mask[out.length];
            const ok =
                (slot === 'L' && /[A-Z]/.test(ch)) ||
                (slot === 'D' && /[0-9]/.test(ch)) ||
                (slot === 'A' && /[A-Z0-9]/.test(ch));
            if (ok) out.push(ch);
            i++;
        }
        return out.join('');
    }
    function sanitizeCurpField(el) {
        if (!el) return;
        el.value = sanitizeCurpValue(el.value);
