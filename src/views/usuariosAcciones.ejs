        let paramScope = 'id_user=' + encodeURIComponent(id_user);
        const scopeOpts = [
            { v: 1, title: 'Página principal', hint: 'Inicio del sitio', icon: 'fa-house' },
            { v: 2, title: 'Páginas interiores', hint: 'Secciones y contenidos', icon: 'fa-file-lines' },
            { v: 5, title: 'Entradas', hint: 'Blog y notas', icon: 'fa-newspaper' },
            { v: 6, title: 'Regeneración', hint: 'Sección de documentos', icon: 'fa-file-pdf' },
        ];
        Promise.all([
            fetch('/obtenerAdminViewInstancia', {
                method: 'POST',
                body: paramAdmin,
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            }).then((r) => r.json()),
            fetch('/obtenerPaginaScopeUserInstancia', {
                method: 'POST',
                body: paramScope,
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            }).then((r) => r.json()),
        ]).then(function (results) {
            const adminData = results[0];
            const scopeData = results[1];
            if (!adminData.success) return;
            const allowedList = scopeData.success
                ? scopeData.allowed_instances || []
                : Object.values(adminData.data).map(function (app) {
                      return app.id;
                  });
            const scopeMap = scopeData.success && scopeData.data ? scopeData.data : {};
            const scopeAppIds = allowedList.filter(function (aid) {
                return Object.values(adminData.data).some(function (app) {
                    return Number(app.id) === Number(aid);
                });
            });
            const finish = function (opcionesPorApp) {
                opcionesPorApp = opcionesPorApp || {};
                let html = '';
                html += '<div class="accordion psc-inst-accordion" id="acordeon-perfil-inst">';
