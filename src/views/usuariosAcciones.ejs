    function pscPaginasSubmoduloCheckedForApp(appId) {
        var $m = $(
            'input[name="EditarPermisos_submodulo"][data-psc-paginas="1"][data-idapp="' +
                appId +
                '"]'
        );
        return $m.length && $m.is(':checked') && !$m.is(':disabled');
    }
    function pscApplyPaginasAlcanceGate(cbEl) {
        var $cb = $(cbEl);
        var collapseId = $cb.attr('data-psc-alcance-collapse');
        if (!collapseId) return;
        var $col = $('#' + collapseId);
        var $btn = $cb.closest('tr').find('.psc-paginas-toggle');
        var on = $cb.is(':checked') && !$cb.is(':disabled');
        if (on) {
            $btn.removeClass('psc-paginas-panel-locked').attr('aria-disabled', 'false').css('pointer-events', '');
        } else {
            $btn.addClass('psc-paginas-panel-locked').attr('aria-disabled', 'true').css('pointer-events', 'none');
            if ($col.length && typeof bootstrap !== 'undefined' && bootstrap.Collapse) {
                try {
                    var ci = bootstrap.Collapse.getInstance($col[0]);
                    if (ci) ci.hide();
                    else bootstrap.Collapse.getOrCreateInstance($col[0], { toggle: false }).hide();
                } catch (e) {}
            }
        }
    }
    function pscInitPaginasAlcancePanelGate() {
        $('#EditarPermisosModal_Form #muestrapermisos')
            .find('input[name="EditarPermisos_submodulo"][data-psc-paginas="1"]')
            .each(function () {
                pscApplyPaginasAlcanceGate(this);
            });
    }
    function EditarPermisosInstance(){
        let id_user = $('#EditarPermisosModal_Form #EditarPermisosIdUser').val();
        let correo = $('#EditarPermisosModal_Form #EditarPermisosCorreo').val();
        let permisosSeleccionados = [];
        $('input[name="EditarPermisos_submodulo"]:checked:not(:disabled)').each(function () {
            permisosSeleccionados.push({
                id_app: $(this).data('idapp'),
                id_syssubmod: $(this).val(),
            });
        });
        let pagina_scope = {};
        let scopeErr = null;
        $('.pagina-scope-cb:checked').each(function () {
            var app = String($(this).data('app'));
            if (!pscPaginasSubmoduloCheckedForApp(app)) {
                return;
            }
            let tipo = String($(this).val());
            if (!pagina_scope[app]) pagina_scope[app] = {};
            if (tipo === '5' || tipo === '6') {
                pagina_scope[app][tipo] = { all: true };
                return;
            }
            var $lines = $(
                '.psc-page-cb[data-app="' + app + '"][data-tipo="' + tipo + '"]'
            );
            var sk = pscScopeStateKey(app, tipo);
            var pages = pscPageUiState.pages[sk] || [];
            var selectedSet = pscPageUiState.selected[sk] instanceof Set ? pscPageUiState.selected[sk] : new Set();
            var selectedIds = Array.from(selectedSet);
            var total = pages.length || $lines.length;
            if (!total) {
                pagina_scope[app][tipo] = { all: true };
                return;
            }
            if (!selectedIds.length) {
                scopeErr =
                    'En página principal e interiores: marque al menos una página o desactive el tipo en el acordeón.';
                return false;
            }
            if (selectedIds.length === total) {
                pagina_scope[app][tipo] = { all: true };
            } else {
                pagina_scope[app][tipo] = {
                    all: false,
                    pageIds: selectedIds
                        .map(function (pid) {
                            return parseInt(pid, 10);
                        })
                        .filter(function (n) {
                            return Number.isFinite(n);
                        }),
                };
            }
        });
        if (scopeErr) {
            $.alert({
                title: 'Atención',
                content: '<strong>' + scopeErr + '</strong>',
                theme: 'modern',
                icon: 'fa-solid fa-triangle-exclamation',
                type: 'blue',
            });
            return;
        }
        let param = JSON.stringify({
            id_user: id_user,
            correo: correo,
            id_type: 13,
            permisosSeleccionados: permisosSeleccionados,
            pagina_scope: pagina_scope,
        });
        fetch('/editarPermisosUserInstancia', {
            method: 'POST',
            body: param,
            headers: { 'Content-Type': 'application/json' },
        })
            .then((r) => r.json())
            .then((data) => {
                if (data.success) {
                    $.alert({
                        title: 'Correcto',
                        content: '<strong>Guardado</strong>',
                        theme: 'modern',
                        icon: 'fa-solid fa-circle-check',
                        type: 'blue',
                        buttons: {
                            Aceptar: {
                                text: 'Aceptar',
                                btnClass: 'btn-success',
                                action: function () {
                                    setTimeout(() => window.location.reload(), 250);
                                },
                            },
                        },
                    });
                } else {
                    $.alert({
                        title: 'Advertencia',
                        content: '<strong>' + (data.msg || 'Error') + '</strong>',
                        theme: 'modern',
                        icon: 'fa-solid fa-triangle-exclamation',
                        type: 'blue',
                    });
                }
            });
    }

