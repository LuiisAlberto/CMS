        let id_user = $('#EditarPermisosModal_Form #EditarPermisosIdUser').val();
        let correo = $('#EditarPermisosModal_Form #EditarPermisosCorreo').val();
        let id_type = $('input[name="EditarPermisos_tipous"]:checked').val();

        let permisosSeleccionados = [];
        $('input[name="EditarPermisos_submodulo"]').each(function () {
            if ($(this).is(':checked')) {
                permisosSeleccionados.push({
                    id_app: $(this).data('idapp'),
                    id_syssubmod: $(this).val()
                });
            }
        });

        if (id_type == null || id_type === '') {
            $.alert({
                title: 'Datos incompletos',
                content: '<strong>Seleccione el tipo de usuario.</strong>',
                theme: 'modern',
                icon: 'fa-solid fa-triangle-exclamation',
                type: 'blue',
            });
            return;
        }

        let param = JSON.stringify({
            id_user: id_user,
            correo: correo,
            id_type: id_type,
            permisosSeleccionados: permisosSeleccionados
        });

        fetch('/editarPermisosUser',{
            method: 'POST',
            body:   param,
            headers: {
                'Content-Type': 'application/json'
            },
        })
            .then(response=>response.json())
            .then(data=>{
                if(data.success){
                    $.alert({
                        title: "Correcto",
                        content: '<strong></strong>',
                        theme: 'modern',
                        icon: 'fa-solid fa-circle-check',
                        type: "blue",
                        buttons: {
                            Aceptar: {
                                text: 'Aceptar',
                                btnClass: 'btn-success',
                                action: function () {
                                    setTimeout(()=>window.location.reload(),250);
                                }
                            }
                        }
                    });
                }
                else{
                    $.alert({
                        title: "Advertencia",
                        content: '<strong>'+data.msg+'</strong>',
                        theme: 'modern',
                        icon: 'fa-solid fa-triangle-exclamation',
                        type: "blue"
                    });
                }
            });
    }
