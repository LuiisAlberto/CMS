<div id="templateDer">
    <div class="limit-administrador">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8 col-sm-10 col-12 ma-b3 t-c">
                <h5 class="tit-seccion guinda_t">
                    <% if (usuarios_scope === 'instance') { %>
                        USUARIOS <b>DE INSTANCIA</b>
                    <% } else { %>
                        ADMINISTRADOR <b>DE USUARIOS</b>
                    <% } %>
                </h5>
                <div class="l-div">
                    <label class="borde-izq oroMorena"><span class="diagonal gris_t"></span></label>
                    <label class="borde-der solid_bg"><span></span></label>
                </div>
            </div>
            <div class="col-12 sp-bis">
                <div class="subenun">
                    <p class="subtit">
                        <%= usuarios_scope === 'instance'
                            ? 'Gestiona usuarios de tus instancias asignadas. No se muestran usuarios globales del sistema.'
                            : 'Para editar la información de un usuario seleccionalo de la lista, filtralo o genera un nuevo usuario.' %>
                    </p>
                    <span></span>
                </div>
            </div>
            <div class="col-12 t-r sp-bis">
                <button class="btnGral auburn_t" type="button" id="NuevoUsuarioButton">
                    <p>NUEVO USUARIO</p>
                    <div class="btnIcon">
                        <div class="boxIcon auburn_bg"><img src="assets/img/AGREGAR.svg"></div>
                        <span class="s-guinda"></span>
                    </div>
                </button>
            </div>
            <style>
                .dataTables_wrapper .dataTables_length,
                .dataTables_wrapper .dataTables_filter,
                .dataTables_wrapper .dataTables_info,
                .dataTables_wrapper .dataTables_paginate
                {
                    display: inline-block;
                    padding: 5px 10px;
                    color: #7E2D43;
                    font-size: 15px;
                    font-weight: 700;
                }
                .dataTables_wrapper .dataTables_filter{
                    display: inline-block;
                    padding: 5px 10px;
                    color: #7E2D43;
                    font-size: 15px;
                    font-weight: 700;

                    width: 70%;
                }.dataTables_wrapper .dataTables_filter label{
                     width: 100%;
                 }
                .dataTables_wrapper .dataTables_filter input{
                    padding: .375rem .75rem;
                    font-size: 14px;
                    font-weight: 500;
                    border: 1.5px solid #cccaca;
                    background: #f0f0f0;
                    margin-top: 0;
                    border-radius: 8px;
                    display: inline-block;
                    width: 70%;
                }
                .table {
                    border-collapse: collapse !important;
                }
                .table-head th{
                    text-align: center !important;
                }
                /* Cuerpo: texto oscuro; encabezado: blanco como el resto de columnas */
                .table-head.verde th.usuarios-col-instancias {
                    color: #fff !important;
                    font-size: 12px;
                    font-weight: 700;
                    text-transform: uppercase;
                    letter-spacing: 0.03em;
                }
                td.usuarios-col-instancias {
                    max-width: 300px;
                    min-width: 160px;
                    text-align: left !important;
                    font-size: 0.88rem;
                    line-height: 1.35;
                    word-break: break-word;
                    color: #3a3530;
                }
            </style>
            <div class="col-lg-10 col-md-11 col-sm-12 col-12 ma-t2 sp-bis">
                <div id="bandejaUsu">
                    <!--div class="headTable row">
                        <div class="col-lg-4 col-md-6 col-sm-5 col-12 sp-bis">
                            <label class="formLabel verde_t">Buscar por nombre o CURP:</label>
                        </div>
                        <div class="col-lg-8 col-md-6 col-sm-7 col-12">
                            <input type="text" name="" class="form-control form-text">
                        </div>
                    </div-->
                    <div class="table-responsive">
                        <table id="Tabla_UsuariosAdministracion" class="table">
                            <thead class="table-head verde">
                            <tr>
                                <th scope="col">#</th>
                                <th scope="col">NOMBRE</th>
                                <th scope="col">CURP</th>
                                <th scope="col">TIPO DE USUARIO</th>
                                <% if (usuarios_scope === 'instance') { %>
                                <th scope="col" class="usuarios-col-instancias">Instancias asignadas</th>
                                <% } %>
                                <th scope="col">ESTADO</th>
                                <th scope="col">ACCIÓN</th>
                            </tr>
                            </thead>
                            <tbody>

                            <%for (const usuario of listaUsuarios){%>
                            <tr>
                                <th scope="row"><%=usuario.id_user%></th>
                                <td><%=usuario.nombre%> <%=usuario.paterno%> <%=usuario.materno%></td>
                                <td><%=usuario.curp%></td>
                                <td><%=usuario.type_user || ''%></td>
                                <% if (usuarios_scope === 'instance') { %>
                                <td class="usuarios-col-instancias"><%= (usuario.instancias_asignadas && String(usuario.instancias_asignadas).trim()) ? usuario.instancias_asignadas : '—' %></td>
                                <% } %>
                                <td><%=usuario.estado || ''%></td>
                                <td>
                                    <% if (usuarios_scope !== 'instance') { %>
                                    <button class="btnAct oro" data-hover="EDITAR" onclick="EditarPermisosModal('<%=usuario.id_user%>')"><i class="fa-regular fa-pen-to-square" aria-hidden="true"></i></button>
                                    <%if(usuario.activo){%>
                                    <button class="btnAct guinda" data-hover="Desactivar" onclick="DesactivarUserConfirm('<%=usuario.id_user%>')"><i class="fa-regular fa-trash-alt" aria-hidden="true"></i></button>
                                    <%if(directorio_activo == "false"){%>
                                    <button class="btnAct oro" data-hover="Contraseña" onclick="ActualizarContraenaConfirm('<%=usuario.id_user%>')"><i class="fas fa-key" aria-hidden="true"></i></button>
                                    <%}%>
                                    <%} else{%>
                                    <button class="btnAct oro" data-hover="Reactivar" onclick="ReactivarUserConfirm('<%=usuario.id_user%>')"><i class="fa-regular fa-check-circle" aria-hidden="true"></i></button>
                                    <%}%>
                                    <% } else { %>
                                    <button class="btnAct oro" data-hover="Permisos" onclick="EditarPermisosModalInstance('<%=usuario.id_user%>')"><i class="fa-regular fa-pen-to-square" aria-hidden="true"></i></button>
                                    <% } %>
                                </td>
                            </tr>
                            <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<template id="NuevoUsuarioModalTemplate">
    <form id="NuevoUsuarioModal_Form" class="limit-form row">
        <input type="hidden" id="usuarios_scope" name="usuarios_scope" value="<%= usuarios_scope %>">
        <% if (usuarios_scope === 'instance') { %>
        <div class="col-lg-8 ma-g">
            <label class="titForm verde_t">Instancia(s) asignada(s) *</label>
            <select id="instancias_ids" name="instancias_ids" class="form-control form-input">
                <% if (assigned_instances && assigned_instances.length) { %>
                <option value="" selected disabled>Seleccione instancia</option>
                <% for(const app of assigned_instances){ %>
                <option value="<%= app.id_sysapp %>"><%= app.app_legend %></option>
                <% } %>
                <% } else { %>
                <option value="" selected disabled>No hay instancias disponibles para tu usuario</option>
                <% } %>
            </select>
        </div>
        <% } %>
        <div class="col-lg-8 ma-g">
            <label class="titForm verde_t">Tipo de Usuario</label>
            <select id="NuevoUsuarioTipo" name="NuevoUsuarioTipo" class="form-control form-input">
                <% for(const type_user of cat_type_users){ %>
                <option value="<%=type_user.id_cat_type_users%>"><%=type_user.type_user%></option>
                <% } %>
            </select>
        </div>
        <div class="col-lg-8 ma-g">
            <label class="titForm verde_t">CURP</label>
            <input type="text" id="NuevoUsuarioCurp" name="NuevoUsuarioCurp" class="form-control form-input" maxlength="20" autocomplete="off" oninput="sanitizeCurpField(this)">
            <input type="hidden" id="NuevoUsuarioCurpValidada" name="NuevoUsuarioCurpValidada">
        </div>
        <div class="col-lg-4 ma-g">
            <label class="titForm ghost">CURP</label>
            <button type="button" class="btnVal guinda" onclick="NuevoUsuarioValidarCurp()">VALIDAR CURP</button>
        </div>
        <div class="col-lg-4 ma-g">
            <label class="titForm verde_t">Nombre (s)</label>
            <input id="NuevoUsuarioNombre" name="NuevoUsuarioNombre" class="form-control form-basic-lleno" placeholder="NOMBRE" readonly>
        </div>
        <div class="col-lg-4 ma-g">
            <label class="titForm verde_t">Primer apellido</label>
            <input id="NuevoUsuarioPrimerA" name="NuevoUsuarioPrimerA" class="form-control form-basic-lleno" placeholder="PRIMER APELLIDO" readonly>
        </div>
        <div class="col-lg-4 ma-g">
            <label class="titForm verde_t">Segundo apellido</label>
            <input id="NuevoUsuarioSegundoA" name="NuevoUsuarioSegundoA" class="form-control form-basic-lleno" placeholder="SEGUNDO APELLIDO" readonly>
        </div>
        <div class="col-lg-4 ma-g">
            <label class="titForm verde_t">Correo electrónico</label>
            <input id="NuevoUsuarioCorreo" name="NuevoUsuarioCorreo" class="form-control form-input">
        </div>
                        <div class="col-lg-4 ma-g">
            <label class="titForm verde_t">Confirmar Correo electrónico</label>
            <input id="NuevoUsuarioCorreoConfirmar" name="NuevoUsuarioCorreoConfirmar" class="form-control form-input">
        </div>
        <div class="col-lg-8 ma-g">
            <label class="titForm verde_t">Estado</label>
            <select id="NuevoUsuarioEntidad" name="NuevoUsuarioEntidad" class="form-control form-input">
                <option value="">Seleccione estado</option>
                <% for(const estado of cat_entidades_admins){ %>
                <option value="<%=estado.id_estado%>"><%=estado.estado%></option>
                <% } %>
            </select>
            <!-- Con select deshabilitado, serialize() no envía el valor; el mirror lleva NuevoUsuarioEntidad -->
            <input type="hidden" id="NuevoUsuarioEntidadMirror" value="">
        </div>
        <!-- <div class="col-lg-4 ma-g">
            <label class="titForm verde_t">Teléfono fijo</label>
            <input id="NuevoUsuarioTelefonoFijo" name="NuevoUsuarioTelefonoFijo" class="form-control form-input">
        </div>
        <div class="col-lg-4 ma-g">
            <label class="titForm verde_t">Teléfono celular</label>
            <input id="NuevoUsuarioTelefonoCelular" name="NuevoUsuarioTelefonoCelular" class="form-control form-input">
        </div><br> -->
        <br>
        <!-- <div class="col-lg-4 ma-g">
                <label class="titForm verde_t">Confirmar Teléfono celular</label>
            <input id="NuevoUsuarioTelefonoConfirmar" name="NuevoUsuarioTelefonoConfirmar" class="form-control form-input">
        </div> -->

    </form>
</template>
