                        '<div class="accordion-body aco-body scroll-hor">' +
                        '<div class="min-tab">';
                    Object.values(app.modulos).forEach(function (modulo) {
                        html +=
                            '<div class="">' +
                            '<div class="psc-modulo-head"><p class="subtit mb-0"><span class="psc-mod-title">' + modulo.mod_legend + '</span></p><span class="psc-mod-line" aria-hidden="true"></span></div>' +
                            '<div class="cont-gral row">' +
                            '<table class="table">' +
                            '<thead class="table-head verde">' +
                            '<tr><th class="whiteletter">Submódulo</th><th class="whiteletter">Permitido</th></tr>' +
                            '</thead><tbody>';
                        Object.values(modulo.submodulos).forEach(function (submodulo) {
                            let checkus = submodulo.perm_user ? 'checked' : '';
                            let perm_us = submodulo.perm_type ? 'user' : 'times';
                            let dis = submodulo.perm_type ? '' : ' disabled';
                            if (isPscSubmoduloPaginas(submodulo)) {
