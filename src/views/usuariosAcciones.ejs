                                    '<button type="button" class="btn btn-link text-start text-dark text-decoration-none p-0 d-inline-flex align-items-center psc-paginas-toggle" data-bs-toggle="collapse" data-bs-target="#' +
                                    pagCollapseId +
                                    '" data-psc-alcance-collapse="' +
                                    pagCollapseId +
                                    '" aria-expanded="false">';
                                html +=
                                    '<i class="fa-solid fa-chevron-right me-2 small psc-paginas-chevron"></i><span>' +
                                    submodulo.legend +
                                    '</span>';
                                html += '</button></td>';
                                html +=
                                    '<td class="align-middle"><input type="checkbox" data-perm="' +
                                    perm_us +
                                    '" data-idapp="' +
                                    app.id +
                                    '" value="' +
                                    submodulo.id_syssubmod +
                                    '" name="EditarPermisos_submodulo" class="form-check-input" ' +
                                    checkus +
                                    dis +
                                    ' data-psc-paginas="1" data-psc-alcance-collapse="' +
                                    pagCollapseId +
                                    '" onchange="validaEncabezadoPermiso()"></td></tr>';
                                html +=
                                    '<tr class="psc-paginas-alcance-row"><td colspan="2" class="p-0 border-top-0 psc-paginas-block-end">';
                                html +=
                                    '<div class="collapse pagina-scope-submod-collapse border-top bg-light" id="' +
                                    pagCollapseId +
                                    '">';
                                html += alcHtmlForApp;
                                html += '</div></td></tr>';
                                return;
                            }
                            html +=
                                '<tr id="id_submod' + submodulo.id_syssubmod + '" data-app="' + app.id + '">' +
                                '<td>' +
                                submodulo.legend +
                                '</td>' +
                                '<td><input type="checkbox" data-perm="' +
                                perm_us +
                                '" data-idapp="' +
                                app.id +
                                '" value="' +
                                submodulo.id_syssubmod +
                                '" name="EditarPermisos_submodulo" class="form-check-input" ' +
                                checkus +
                                dis +
                                ' onchange="validaEncabezadoPermiso()"></td>' +
                                '</tr>';
                        });
                        html += '</tbody></table></div></div>';
                    });
                    html += '</div></div></div></div>';
                });
                html += '</div>';
                $('#EditarPermisosModal_Form #muestrapermisos').html(html);
                $('#EditarPermisosModal_Form #muestrapermisos')
                    .off('click.pscpaglock')
                    .on('click.pscpaglock', '.psc-paginas-toggle.psc-paginas-panel-locked', function (e) {
                        e.preventDefault();
                        e.stopImmediatePropagation();
                        return false;
                    });
                $('#EditarPermisosModal_Form #muestrapermisos')
                    .off('change.pscpagparent')
                    .on(
                        'change.pscpagparent',
                        'input[name="EditarPermisos_submodulo"][data-psc-paginas="1"]',
                        function () {
                            if (!this.checked) {
                                var app = String($(this).data('idapp'));
                                $('.pagina-scope-cb[data-app="' + app + '"]').prop('checked', false);
                                $('.psc-page-cb[data-app="' + app + '"]').prop('checked', false);
                                pscResetSelectionForApp(app);
                            }
                            pscApplyPaginasAlcanceGate(this);
                        }
                    );
                if (scopeAppIds.length) {
                    pscInitPaginaScopeChecklists(scopeMap, opcionesPorApp, scopeAppIds, scopeOpts);
                }
                pscInitPaginasAlcancePanelGate();
                validaEncabezadoPermiso();
            };
            if (!scopeAppIds.length) {
                finish({});
                return;
            }
            Promise.all(
                scopeAppIds.map(function (aid) {
                    return fetch('/opcionesPaginasAlcanceInstancia', {
                        method: 'POST',
                        body: 'fk_id_sysapp=' + encodeURIComponent(aid),
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    }).then(function (r) {
                        return r.json();
                    });
                })
            ).then(function (opcResponses) {
                const opcionesPorApp = {};
                scopeAppIds.forEach(function (aid, i) {
                    var o = opcResponses[i];
                    opcionesPorApp[String(aid)] = o && o.success && o.data ? o.data : { '1': [], '2': [], '5': [] };
                });
                finish(opcionesPorApp);
            });
        });
    }

