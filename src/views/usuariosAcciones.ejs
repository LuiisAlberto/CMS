    function pscIsSinAlcance(tiposRaw) {
        if (tiposRaw == null) return true;
        if (Array.isArray(tiposRaw)) return tiposRaw.length === 0;
        if (typeof tiposRaw === 'object') return Object.keys(tiposRaw).length === 0;
        return true;
    }
    const PSC_PAGE_SIZE = 8;
    const pscPageUiState = {
        pager: {},
        pages: {},
        selected: {},
    };
    function pscScopeStateKey(app, tipo) {
        return String(app) + '|' + String(tipo);
    }
    function pscGetSelectedSet(app, tipo) {
        var sk = pscScopeStateKey(app, tipo);
        if (!(pscPageUiState.selected[sk] instanceof Set)) {
            pscPageUiState.selected[sk] = new Set();
        }
        return pscPageUiState.selected[sk];
    }
    function pscInitTipoSelectionState(app, tipo, pages, st) {
        var set = pscGetSelectedSet(app, tipo);
        set.clear();
        if (!st || !st.checked) return;
        if (st.all) {
            (pages || []).forEach(function (p) {
                set.add(String(p.id));
            });
            return;
        }
        (st.pageIds || []).forEach(function (pid) {
            set.add(String(pid));
        });
    }
    function pscEscapeHtml(s) {
        if (s == null) return '';
        return String(s)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }
    function pscBuildPaginaChecklistHtml(key, tipo, pages) {
        tipo = String(tipo);
        var html =
            '<p class="small text-muted mb-2">Marque las páginas a las que aplica el permiso.</p>';
        if (!pages || !pages.length) {
            html +=
                '<p class="small text-muted fst-italic mb-0">No hay páginas de este tipo registradas en la instancia.</p>';
            return html;
        }
        var sk = pscScopeStateKey(key, tipo);
        var currentPage = Number(pscPageUiState.pager[sk] || 1);
        var totalPages = Math.max(1, Math.ceil(pages.length / PSC_PAGE_SIZE));
        if (!Number.isFinite(currentPage) || currentPage < 1) currentPage = 1;
        if (currentPage > totalPages) currentPage = totalPages;
        pscPageUiState.pager[sk] = currentPage;
        var start = (currentPage - 1) * PSC_PAGE_SIZE;
        var end = Math.min(start + PSC_PAGE_SIZE, pages.length);
        var pageRows = pages.slice(start, end);
        var selected = pscGetSelectedSet(key, tipo);
        html +=
            '<div class="list-group list-group-flush border rounded overflow-hidden psc-page-checklist">';
        pageRows.forEach(function (p) {
            var pid = String(p.id);
            var lineOn = selected.has(pid);
            var ck = lineOn ? ' checked' : '';
            var nid = 'psc-pg-' + key + '-' + tipo + '-' + pid;
            html +=
                '<label class="list-group-item d-flex align-items-center gap-3 py-3 px-3 mb-0 psc-page-row" for="' +
                nid +
                '">';
            html +=
                '<input type="checkbox" class="form-check-input flex-shrink-0 psc-page-cb" id="' +
                nid +
                '" data-app="' +
                key +
                '" data-tipo="' +
                tipo +
                '" data-page-id="' +
                pid +
                '"' +
                ck +
                '>';
            html += '<span class="small flex-grow-1 min-w-0"><span class="text-body fw-medium">' + pscEscapeHtml(p.nombre || '') + '</span>';
            html += '</span></label>';
        });
        html += '</div>';
        if (totalPages > 1) {
            var prevDisabled = currentPage <= 1 ? ' disabled' : '';
            var nextDisabled = currentPage >= totalPages ? ' disabled' : '';
            html +=
                '<div class="d-flex align-items-center justify-content-between gap-2 mt-2 psc-page-pager">' +
                '<button type="button" class="btn btn-sm btn-outline-secondary psc-page-nav" data-app="' +
                key +
                '" data-tipo="' +
                tipo +
                '" data-dir="-1"' +
                prevDisabled +
                '>Anterior</button>' +
                '<span class="small text-muted">Página ' +
                currentPage +
                ' de ' +
                totalPages +
                '</span>' +
                '<button type="button" class="btn btn-sm btn-outline-secondary psc-page-nav" data-app="' +
                key +
                '" data-tipo="' +
                tipo +
                '" data-dir="1"' +
                nextDisabled +
                '>Siguiente</button>' +
                '</div>';
        }
        return html;
    }
    function pscRenderPaginaChecklist(key, tipo) {
        var sk = pscScopeStateKey(key, tipo);
        var pages = pscPageUiState.pages[sk] || [];
        var $slot = $('#psc-pages-list-' + key + '-' + tipo);
        if (!$slot.length) return;
        $slot.html(pscBuildPaginaChecklistHtml(key, tipo, pages));
    }
    function pscResetSelectionForApp(app) {
        var pref = String(app) + '|';
        Object.keys(pscPageUiState.selected).forEach(function (k) {
            if (k.indexOf(pref) === 0 && pscPageUiState.selected[k] instanceof Set) {
                pscPageUiState.selected[k].clear();
            }
        });
        Object.keys(pscPageUiState.pages).forEach(function (k) {
            if (k.indexOf(pref) !== 0) return;
            var parts = k.split('|');
            if (parts.length !== 2) return;
            pscRenderPaginaChecklist(parts[0], parts[1]);
        });
    }
    function pscScopeTipoState(raw, tipo, sinAlcanceGuardado) {
        var tNum = Number(tipo);
        if (tNum === 5) {
            if (sinAlcanceGuardado) return { checked: true, all: true, pageIds: [], esEntrada: true };
            if (Array.isArray(raw)) {
                return { checked: raw.indexOf(5) >= 0, all: true, pageIds: [], esEntrada: true };
            }
            var sp5 = raw && raw['5'];
            if (!sp5) return { checked: false, all: true, pageIds: [], esEntrada: true };
            return { checked: true, all: true, pageIds: [], esEntrada: true };
        }
        if (tNum === 6) {
            if (sinAlcanceGuardado) return { checked: true, all: true, pageIds: [], esEntrada: false };
            if (Array.isArray(raw)) {
                return { checked: raw.indexOf(6) >= 0, all: true, pageIds: [], esEntrada: false };
            }
            var sp6 = raw && raw['6'];
            if (!sp6) return { checked: false, all: true, pageIds: [], esEntrada: false };
            return { checked: true, all: true, pageIds: [], esEntrada: false };
        }
        if (sinAlcanceGuardado) return { checked: true, all: true, pageIds: [], esEntrada: false };
        if (Array.isArray(raw)) {
            return { checked: raw.indexOf(tipo) >= 0, all: true, pageIds: [], esEntrada: false };
        }
        var tStr = String(tipo);
        var sp = raw && raw[tStr];
        if (!sp) return { checked: false, all: true, pageIds: [], esEntrada: false };
        if (sp.all === true) return { checked: true, all: true, pageIds: [], esEntrada: false };
        if (sp.all === false && Array.isArray(sp.pageIds) && sp.pageIds.length) {
            return { checked: true, all: false, pageIds: sp.pageIds.map(String), esEntrada: false };
        }
        if (sp.all === false && sp.pageId != null && sp.pageId !== '') {
            return { checked: true, all: false, pageIds: [String(sp.pageId)], esEntrada: false };
        }
        return { checked: true, all: true, pageIds: [], esEntrada: false };
    }
    function pscInitPaginaScopeChecklists(scopeMap, opcionesPorApp, scopeAppIds, scopeOpts) {
        var $root = $('#EditarPermisosModal_Form #muestrapermisos');
        scopeAppIds.forEach(function (aid) {
            var key = String(aid);
            var opc = opcionesPorApp[key] || { '1': [], '2': [], '5': [], '6': [] };
            var tiposRaw = scopeMap[key] != null ? scopeMap[key] : null;
            var sinAlcanceGuardado = pscIsSinAlcance(tiposRaw);
            scopeOpts.forEach(function (opt) {
                if (opt.v === 5 || opt.v === 6) return;
                var st = pscScopeTipoState(tiposRaw, opt.v, sinAlcanceGuardado);
                var pages = opc[String(opt.v)] || [];
                var sk = pscScopeStateKey(key, opt.v);
                pscPageUiState.pages[sk] = pages;
                pscPageUiState.pager[sk] = 1;
                pscInitTipoSelectionState(key, opt.v, pages, st);
                pscRenderPaginaChecklist(key, opt.v);
            });
        });
        $root.off('change.psc');
        $root.on('change.psc', '.pagina-scope-cb', function () {
            var key = String($(this).data('app'));
            var tv = String($(this).val());
            $('#psc-ext-' + key + '-' + tv).toggle(this.checked);
            if (tv === '5' || tv === '6') return;
            var sk = pscScopeStateKey(key, tv);
            var pages = pscPageUiState.pages[sk] || [];
            var selected = pscGetSelectedSet(key, tv);
            if (this.checked) {
                pages.forEach(function (p) {
                    selected.add(String(p.id));
                });
            } else {
                selected.clear();
            }
            pscRenderPaginaChecklist(key, tv);
        });
        $root.on('change.psc', '.psc-page-cb', function () {
            var key = String($(this).data('app'));
            var tv = String($(this).data('tipo'));
            var pid = String($(this).data('page-id'));
            var selected = pscGetSelectedSet(key, tv);
            if (this.checked) selected.add(pid);
            else selected.delete(pid);
        });
        $root.on('click.psc', '.psc-page-nav', function () {
            var key = String($(this).data('app'));
            var tv = String($(this).data('tipo'));
            var dir = Number($(this).data('dir') || 0);
            var sk = pscScopeStateKey(key, tv);
            var pages = pscPageUiState.pages[sk] || [];
            var totalPages = Math.max(1, Math.ceil(pages.length / PSC_PAGE_SIZE));
            var page = Number(pscPageUiState.pager[sk] || 1);
            page += dir;
            if (page < 1) page = 1;
            if (page > totalPages) page = totalPages;
            pscPageUiState.pager[sk] = page;
            pscRenderPaginaChecklist(key, tv);
        });
    }

    function isPscSubmoduloPaginas(submodulo) {
        var raw = (submodulo.archivo || '').toString().trim().toLowerCase().replace(/^\//, '').replace(/_/g, '-');
        try {
            raw = raw.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
        } catch (e) {}
        if (raw.indexOf('paginas') >= 0 && raw.indexOf('users-instancia') < 0) return true;
        var leg = (submodulo.legend || '')
            .toString()
            .trim()
            .toLowerCase()
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '');
        if (leg === 'paginas') return true;
        return false;
    }

